{
  "name": "quidproquo",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node scripts/create-cron-stub.mjs && astro build && node scripts/create-cron-entry.mjs && node scripts/generate-og-images.mjs",
    "deploy": "pnpm build && wrangler deploy --config dist/server/wrangler.json",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint src/ --ignore-pattern '*.astro'",
    "session:start": "node scripts/session-start.mjs",
    "check:post-quality": "node scripts/check-post-quality.mjs",
    "check:references": "node scripts/check-post-references.mjs",
    "sync": "tsx scripts/sync-to-d1.ts",
    "sync:prod": "tsx scripts/sync-to-d1.ts --prod",
    "prepare": "simple-git-hooks",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:rag": "node scripts/eval-rag-baseline.mjs"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.0",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@langchain/core": "^1.1.41",
    "@langchain/google-genai": "^2.1.28",
    "@langchain/groq": "^1.2.0",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/openai": "^1.4.4",
    "@playwright/test": "^1.58.2",
    "astro": "^6.0.3",
    "langfuse": "^3.38.20",
    "mdast-util-to-string": "^4.0.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260510.1",
    "@fontsource/noto-sans-tc": "^5.2.9",
    "@resvg/resvg-js": "^2.6.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "gray-matter": "^4.0.3",
    "oxlint": "^1.54.0",
    "pagefind": "^1.4.0",
    "satori": "^0.25.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "^4.21.0",
    "vfile": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && pnpm check:references"
  },
  "pnpm": {
    "overrides": {
      "picomatch": "4.0.3"
    }
  }
}
