---
import type { FlowCardData } from '@/lib/agent-console/flow-selector'

interface Props {
  card: FlowCardData
}

const { card } = Astro.props

const statusColors: Record<string, string> = {
  succeeded: 'var(--color-success)',
  failed: 'var(--color-error)',
  running: 'var(--color-accent)',
  queued: 'var(--color-muted)',
  cancelled: 'var(--color-muted)',
}

const statusColor = card.lastStatus ? (statusColors[card.lastStatus] ?? 'var(--color-muted)') : 'var(--color-muted)'
const lastRunLabel = card.lastRunAt
  ? new Date(card.lastRunAt).toLocaleString('zh-TW', { dateStyle: 'short', timeStyle: 'short' })
  : '—'
const lastStatusLabel = card.lastStatus ?? '—'
const versionLabel = card.currentVersion != null ? `v${card.currentVersion}` : '—'
const costLabel = card.estimatedCostUsd == null ? '—' : `$${card.estimatedCostUsd.toFixed(2)}`
const categoryLabel = card.category ?? 'general'

const flowHref = `/admin/console/flows/${encodeURIComponent(card.id)}`
const launchHref = `/admin/console/runs/launch?flowId=${encodeURIComponent(card.id)}`
---

<article class="flow-card">
  <a href={flowHref} class="flow-card__title">Flow: {card.name}</a>
  <div class="flow-card__header">
    <span class="flow-card__status-wrap">
      {card.lastStatus && (
        <span class="flow-card__status" style={`color: ${statusColor}`}>{card.lastStatus}</span>
      )}
    </span>
    <a href={launchHref} class="flow-card__launch">Launch</a>
  </div>
  <div class="flow-card__meta-grid">
    <span>Category: {categoryLabel}</span>
    <span>Status: {lastStatusLabel}</span>
    <span>Version: {versionLabel}</span>
    <span>Estimated cost: {costLabel}</span>
    {card.costBand && <span>Band: {card.costBand}</span>}
  </div>
  {card.description && <p class="flow-card__desc">{card.description}</p>}
  <span class="flow-card__meta">Last run: {lastRunLabel}</span>
</article>

<style>
  .flow-card {
    display: grid;
    gap: 0.45rem;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 8px;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .flow-card:hover {
    border-color: var(--color-accent, #4f46e5);
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }
  .flow-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }

  .flow-card__meta-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.75rem;
    font-size: 0.74rem;
    color: var(--color-muted-text, #64748b);
  }

  .flow-card__title {
    font-weight: 600;
    text-decoration: none;
    color: inherit;
  }

  .flow-card__status-wrap {
    display: inline-flex;
  }

  .flow-card__launch {
    font-size: 0.74rem;
    line-height: 1.4;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-accent, #4f46e5);
    border-radius: 999px;
    text-decoration: none;
    color: var(--color-accent, #4f46e5);
  }

  .flow-card__launch:hover {
    background: rgba(79, 70, 229, 0.08);
  }

  .flow-card__status-wrap .flow-card__status {
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .flow-card__desc {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    color: var(--color-muted-text, #64748b);
    line-height: 1.4;
  }
  .flow-card__meta {
    display: block;
    margin-top: 0.5rem;
    font-size: 0.75rem;
    color: var(--color-muted-text, #64748b);
  }
</style>
