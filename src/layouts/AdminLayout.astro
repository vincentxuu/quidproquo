---
import { verifySession } from '../lib/auth/session';
import Icons from '../components/Icons.astro';
import '../styles/admin-tokens.css';

export const prerender = false;

interface Props {
  title: string;
}

const { title } = Astro.props;

// Check authentication
const session = Astro.cookies.get('session')?.value;
const isLoggedIn = session ? await verifySession(session) : false;

// Get current path for redirect
const currentPath = Astro.url.pathname;
const loginUrl = `/login?next=${encodeURIComponent(currentPath)}`;

if (!isLoggedIn) {
  return Astro.redirect(loginUrl);
}

const navItems = [
  { href: '/admin', label: '總覽', section: 'Monitor', icon: 'layout-dashboard' },
  { href: '/admin/content', label: '內容', section: 'Content', icon: 'file-text' },
  { href: '/admin/content-pipelines', label: '流程', section: 'Content', icon: 'workflow' },
  { href: '/admin/jobs', label: '任務', section: 'Content', icon: 'list-checks' },
  { href: '/admin/stats', label: '統計', section: 'Insight', icon: 'bar-chart-3' },
  { href: '/admin/rag', label: 'RAG', section: 'AI', icon: 'brain-circuit' },
  { href: '/admin/providers', label: '模型供應商', section: 'AI', icon: 'plug' },
  { href: '/admin/traces', label: '追蹤紀錄', section: 'AI', icon: 'activity' },
  { href: '/admin/deep-research', label: 'Deep Research', section: 'AI', icon: 'brain-circuit' },
  { href: '/admin/ops', label: '維運', section: 'System', icon: 'server-cog' },
  { href: '/admin/settings', label: '設定', section: 'System', icon: 'settings' },
] as const;

const groupedNav = navItems.reduce<Record<string, (typeof navItems)[number][]>>((groups, item) => {
  groups[item.section] ??= [];
  groups[item.section].push(item);
  return groups;
}, {});
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — Admin</title>
</head>
<body>
  <div class="admin-container">
    <aside class="admin-sidebar">
      <div class="sidebar-header">
        <a href="/admin" class="admin-brand" aria-label="Admin dashboard">
          <span class="brand-mark">qp</span>
          <span class="brand-text">
            <strong>quidproquo</strong>
            <span>Operations</span>
          </span>
        </a>
      </div>
      <nav class="sidebar-nav" aria-label="Admin navigation">
        {Object.entries(groupedNav).map(([section, items]) => (
          <div class="nav-group">
            <span class="nav-section">{section}</span>
            {items.map(item => (
              <a
                href={item.href}
                class:list={['nav-item', { active: currentPath === item.href }]}
                aria-current={currentPath === item.href ? 'page' : undefined}
                title={item.label}
              >
                <Icons name={item.icon} size={16} />
                <span class="nav-label">{item.label}</span>
              </a>
            ))}
          </div>
        ))}
      </nav>
      <div class="sidebar-footer">
        <a href="/" class="nav-item" title="回到網站">
          <Icons name="home" size={16} />
          <span class="nav-label">回到網站</span>
        </a>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="logout-btn" title="登出">
            <Icons name="log-out" size={16} />
            <span class="nav-label">登出</span>
          </button>
        </form>
      </div>
    </aside>
    <main class="admin-main">
      <header class="admin-header">
        <div>
          <p class="admin-kicker">Admin Console</p>
          <h2>{title}</h2>
        </div>
        <div class="header-actions" aria-label="Admin shortcuts">
          <a href="/admin/jobs" class="admin-icon-button" title="任務">
            <Icons name="list-checks" size={16} />
          </a>
          <a href="/admin/settings" class="admin-icon-button" title="設定">
            <Icons name="settings" size={16} />
          </a>
        </div>
      </header>
      <div class="admin-content">
        <slot />
      </div>
    </main>
  </div>
</body>
</html>

<style>
  :root {
    --sidebar-width: 264px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Noto Sans TC Local', 'PingFang TC', 'Microsoft JhengHei', Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--admin-bg);
    color: var(--admin-text);
    min-height: 100vh;
    line-height: 1.5;
  }

  a,
  button,
  select,
  input {
    font: inherit;
  }

  a:focus-visible,
  button:focus-visible,
  select:focus-visible,
  input:focus-visible {
    outline: none;
    box-shadow: var(--admin-focus);
  }

  .admin-container {
    display: flex;
    min-height: 100vh;
  }

  .admin-sidebar {
    width: var(--sidebar-width);
    background: var(--admin-surface);
    border-right: 1px solid var(--admin-border);
    display: flex;
    flex-direction: column;
    position: fixed;
    top: 0;
    left: 0;
    height: 100vh;
    overflow-y: auto;
    z-index: 20;
  }

  .sidebar-header {
    padding: 1rem 0.9rem;
    border-bottom: 1px solid var(--admin-border);
  }

  .admin-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--admin-text);
    text-decoration: none;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border: 1px solid var(--brand-700);
    border-radius: var(--admin-radius);
    background: var(--brand-900);
    color: var(--admin-surface);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.78rem;
    letter-spacing: 0;
  }

  .brand-text {
    display: grid;
    gap: 0.05rem;
  }

  .brand-text strong {
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: -0.01em;
  }

  .brand-text span {
    color: var(--admin-text-muted);
    font-size: 0.76rem;
  }

  .sidebar-nav {
    flex: 1;
    padding: 0.85rem 0.75rem;
  }

  .nav-group + .nav-group {
    margin-top: 0.95rem;
  }

  .nav-section {
    display: block;
    padding: 0 0.65rem 0.35rem;
    color: var(--admin-text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 38px;
    padding: 0.5rem 0.65rem;
    border-radius: var(--admin-radius);
    color: var(--admin-text-muted);
    text-decoration: none;
    margin-bottom: 0.15rem;
    transition: background 0.15s ease, color 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
  }

  .nav-item:hover {
    background: var(--admin-muted);
    color: var(--brand-900);
  }

  .nav-item.active {
    background: var(--brand-900);
    color: #ffffff;
    font-weight: 650;
    box-shadow: 0 1px 2px rgba(26, 46, 26, 0.16);
  }

  .nav-label {
    font-size: 0.9rem;
  }

  .sidebar-footer {
    padding: 0.75rem;
    border-top: 1px solid var(--admin-border);
  }

  .logout-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 38px;
    padding: 0.5rem 0.65rem;
    border: none;
    border-radius: var(--admin-radius);
    background: transparent;
    color: var(--admin-text-muted);
    cursor: pointer;
    font-size: 0.9rem;
    text-align: left;
    transition: background 0.15s;
  }

  .logout-btn:hover {
    background: var(--admin-muted);
    color: var(--brand-900);
  }

  .admin-main {
    flex: 1;
    margin-left: var(--sidebar-width);
    min-height: 100vh;
    min-width: 0;
    max-width: calc(100vw - var(--sidebar-width));
  }

  .admin-header {
    min-height: 68px;
    padding: 0.85rem 1.75rem;
    border-bottom: 1px solid var(--admin-border);
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .admin-header h2 {
    font-size: clamp(1.1rem, 1.4vw, 1.35rem);
    font-weight: 800;
    letter-spacing: 0;
  }

  .admin-kicker {
    margin-bottom: 0.1rem;
    color: var(--admin-text-soft);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .admin-content {
    width: 100%;
    max-width: 1600px;
    min-width: 0;
    padding: 1.25rem 1.75rem 2.5rem;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .admin-icon-button,
  :global(.icon-button) {
    display: inline-grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    color: var(--admin-text-muted);
    text-decoration: none;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease;
  }

  .admin-icon-button:hover,
  :global(.icon-button:hover) {
    border-color: var(--admin-accent);
    color: var(--brand-900);
    background: var(--brand-50);
  }

  :global(.admin-panel),
  :global(.status-card),
  :global(.content-section),
  :global(.inventory-panel) {
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    box-shadow: var(--admin-shadow);
    min-width: 0;
    max-width: 100%;
  }

  :global(.admin-content > *),
  :global(.dashboard-grid > *),
  :global(.stats-grid > *),
  :global(.content-grid > *),
  :global(.providers-grid > *),
  :global(.pipeline-grid > *),
  :global(.action-grid > *),
  :global(.traces-container > *) {
    min-width: 0;
  }

  :global(code),
  :global(pre),
  :global(.post-slug),
  :global(.post-path),
  :global(.job-pipeline),
  :global(.trace-id),
  :global(.trace-summary),
  :global(.trace-error),
  :global(.issue-slug),
  :global(.link-from),
  :global(.link-to) {
    overflow-wrap: anywhere;
  }

  :global(pre) {
    max-width: 100%;
    overflow: auto;
  }

  :global(table) {
    max-width: 100%;
  }

  :global(.admin-panel h2),
  :global(.content-section h2),
  :global(.status-card h3) {
    color: var(--admin-text);
    letter-spacing: 0;
    text-transform: none;
  }

  :global(.page-desc),
  :global(.section-desc),
  :global(.empty) {
    color: var(--admin-text-muted);
  }

  :global(a) {
    color: inherit;
  }

  :global(.text-link),
  :global(.card-link),
  :global(.settings-link) {
    color: var(--admin-accent);
  }

  :global(.text-link:hover),
  :global(.card-link:hover),
  :global(.settings-link:hover) {
    color: var(--admin-accent-hover);
  }

  :global(input),
  :global(select),
  :global(textarea) {
    border-color: var(--admin-border);
  }

  :global(input:focus),
  :global(select:focus),
  :global(textarea:focus) {
    border-color: var(--admin-accent);
    box-shadow: var(--admin-focus);
    outline: none;
  }

  :global(.action-btn),
  :global(.mini-btn),
  :global(#save-settings),
  :global(.ops-grid button),
  :global(.form-actions button) {
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    color: var(--admin-text);
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease, color 0.15s ease;
  }

  :global(.action-btn:hover),
  :global(.mini-btn:hover),
  :global(#save-settings:hover),
  :global(.ops-grid button:hover),
  :global(.form-actions button:hover) {
    border-color: var(--admin-accent);
    background: var(--brand-50);
    color: var(--brand-900);
  }

  :global(.job-row:hover),
  :global(.post-table tbody tr:hover),
  :global(.trace-row:hover) {
    background: var(--admin-surface-subtle);
  }

  @media (max-width: 768px) {
    :root {
      --sidebar-width: 72px;
    }

    .admin-sidebar {
      width: var(--sidebar-width);
    }

    .nav-label,
    .nav-section,
    .brand-text {
      display: none;
    }

    .sidebar-header,
    .sidebar-nav,
    .sidebar-footer {
      padding-left: 0.55rem;
      padding-right: 0.55rem;
    }

    .nav-item {
      justify-content: center;
      min-height: 42px;
      padding: 0.55rem;
    }

    .admin-main {
      margin-left: var(--sidebar-width);
      min-width: 0;
      max-width: calc(100vw - var(--sidebar-width));
    }

    .admin-header {
      padding: 0.9rem 1rem;
    }

    .admin-content {
      padding: 1rem;
    }

    .header-actions {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }
</style>
