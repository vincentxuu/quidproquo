---
// src/layouts/PostLayout.astro
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
import Icons from '../components/Icons.astro';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  ogImage?: string;
  articleDate?: Date;
  articleTags?: string[];
}
const { title, description, lang: langProp, ogImage, articleDate, articleTags } = Astro.props;
const isArticle = !!articleDate;
const lang = langProp ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const homeHref = lang === 'en' ? '/en' : '/';
const categoriesHref = lang === 'en' ? '/en/categories' : '/categories';
const tagsHref = lang === 'en' ? '/en/tags' : '/tags';
const switchHref = t('lang.switch.href');
const switchLabel = t('lang.switch');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://quidproquo.cc');
---
<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — quidproquo</title>
  <link rel="canonical" href={canonicalURL} />
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={`${title} — quidproquo`} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'zh_TW'} />
  <meta property="og:type" content={isArticle ? 'article' : 'website'} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}
  {ogImage && <meta property="og:image:width" content="1200" />}
  {ogImage && <meta property="og:image:height" content="630" />}
  {isArticle && <meta property="article:published_time" content={articleDate!.toISOString()} />}
  {isArticle && <meta property="article:author" content="xiaoxu" />}
  {isArticle && articleTags?.map(tag => <meta property="article:tag" content={tag} />)}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={`${title} — quidproquo`} />
  {description && <meta name="twitter:description" content={description} />}
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  <link rel="alternate" type="application/rss+xml" title="quidproquo RSS" href={lang === 'en' ? '/en/rss.xml' : '/rss.xml'} />
  <slot name="head" />
  <script is:inline>
    // Apply theme before page renders to avoid flash
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (stored === 'dark' || (!stored && prefersDark)) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  </script>
</head>
<body>
  <header>
    <nav>
      <a href={homeHref} class="logo">quidproquo</a>
      <a href={categoriesHref} class="nav-link">{t('nav.categories')}</a>
      <a href={tagsHref} class="nav-link">{t('nav.tags')}</a>
      <div class="nav-right">
        <a href="/search" class="nav-icon-btn" aria-label={t('nav.search')}>
          <Icons name="search" size={15} />
        </a>
        <button class="nav-icon-btn" id="theme-toggle" aria-label={t('nav.toggle-theme')}>
          <span class="icon-light"><Icons name="sun" size={15} /></span>
          <span class="icon-dark"><Icons name="moon" size={15} /></span>
        </button>
        <a href={switchHref} class="lang-badge">{switchLabel}</a>
      </div>
      <div class="progress-bar" id="progress-bar"></div>
    </nav>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <span>quidproquo.cc</span>
    <a href={lang === 'en' ? '/en/rss.xml' : '/rss.xml'} class="rss-link" aria-label="RSS">
      <Icons name="rss" size={14} />
      <span>RSS</span>
    </a>
  </footer>

  <!-- Floating scroll-to-top -->
  <button class="scroll-top" id="scroll-top" aria-label="Scroll to top">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
    <span class="scroll-pct" id="scroll-pct">0%</span>
  </button>
</body>
</html>

<style is:global>
  /* ── Dark Navy Design Tokens (inspired by DJ MYG) ── */
  :root {
    --brand-900: #1a2e1a;
    --brand-700: #2d4a2d;
    --brand-500: #4a9e6a;
    --brand-300: #a7c4a0;
    --brand-100: #e8f5e8;
    --brand-50:  #f0f7f0;
    --border:    #d1e8d1;
    --text-primary:    #1a1a1a;
    --text-secondary:  #4a7c59;
    --text-muted:      #999;
    --bg-page:   #ffffff;
    --bg-subtle: #f5f7f5;
    --bg-card:   #ffffff;
    --bg-code:   #1e1e2e;
    --heading-accent: #e8657a;
    --info-bg:    #eef6ff;
    --info-border: #3b82f6;
    --info-icon:   #3b82f6;
    --success-bg:    #eefbf3;
    --success-border: #22c55e;
    --success-icon:   #22c55e;
    --warning-bg:    #fffbeb;
    --warning-border: #f59e0b;
    --shadow-card-hover: 0 2px 12px rgba(0, 0, 0, 0.08);
    --shadow-floating: 0 2px 12px rgba(0, 0, 0, 0.15);
    --code-dot-red: #ff5f57;
    --code-dot-yellow: #febc2e;
    --code-dot-green: #28c840;

    /* Category badge colors */
    --cat-tech:      #1a1a1a;
    --cat-ai:        #6d28d9;
    --cat-product:   #0369a1;
    --cat-education: #b45309;
    --cat-life:      #15803d;
  }

  [data-theme="dark"] {
    --brand-900: #e8e8e8;
    --brand-700: #c0c0c0;
    --brand-500: #5cb87a;
    --brand-300: #2d4a2d;
    --brand-100: #1c2833;
    --brand-50:  #151d26;
    --border:    #2a3545;
    --text-primary:    #d1d5db;
    --text-secondary:  #5cb87a;
    --text-muted:      #6b7280;
    --bg-page:   #0f1419;
    --bg-subtle: #151d26;
    --bg-card:   #1a2332;
    --bg-code:   #0d1117;
    --heading-accent: #f472b6;
    --info-bg:    #151d26;
    --info-border: #3b82f6;
    --info-icon:   #60a5fa;
    --success-bg:    #151d26;
    --success-border: #22c55e;
    --success-icon:   #4ade80;
    --warning-bg:    #1a1a0f;
    --warning-border: #f59e0b;
    --shadow-card-hover: 0 2px 12px rgba(0, 0, 0, 0.25);
    --shadow-floating: 0 2px 12px rgba(0, 0, 0, 0.4);
  }

  /* ── Reset & Base ── */
  *, *::before, *::after { box-sizing: border-box; }

  body {
    font-family: system-ui, -apple-system, sans-serif;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    color: var(--text-primary);
    background: var(--bg-page);
    transition: background 0.2s, color 0.2s;
  }

  /* ── Nav ── */
  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border);
    position: relative;
  }
  .logo {
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: -0.5px;
    text-decoration: none;
    color: var(--brand-900);
  }
  .nav-link {
    font-size: 0.8rem;
    text-decoration: none;
    color: var(--text-secondary);
  }
  .nav-link:hover { color: var(--brand-900); }
  .nav-right {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  /* Circular icon buttons (like DJ MYG) */
  .nav-icon-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .nav-icon-btn:hover {
    color: var(--brand-500);
    border-color: var(--brand-500);
    background: var(--bg-card);
  }

  /* Dark mode toggle */
  .icon-dark { display: none; }
  [data-theme="dark"] .icon-light { display: none; }
  [data-theme="dark"] .icon-dark  { display: flex; }

  /* Language badge */
  .lang-badge {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    border: 1px solid var(--border);
    padding: 0.12rem 0.45rem;
    border-radius: 3px;
    text-decoration: none;
  }
  .lang-badge:hover { border-color: var(--brand-500); }

  /* Reading progress bar */
  .progress-bar {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0%;
    height: 2px;
    background: var(--brand-500);
    transition: width 0.1s linear;
  }

  /* ── Floating scroll-to-top ── */
  .scroll-top {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    width: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem 0.35rem;
    color: var(--heading-accent);
    cursor: pointer;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.2s, transform 0.2s, color 0.15s;
    pointer-events: none;
    z-index: 100;
    box-shadow: var(--shadow-floating);
  }
  .scroll-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .scroll-top:hover { color: var(--brand-500); }
  .scroll-pct {
    font-size: 0.6rem;
    font-weight: 700;
    line-height: 1;
  }

  /* ── Footer ── */
  footer {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .rss-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.78rem;
  }
  .rss-link:hover { color: var(--brand-500); }

  /* ── Category badges (global, used in PostCard + slug page) ── */
  .cat-badge {
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.12rem 0.45rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #fff;
    text-decoration: none;
  }
  .cat-tech      { background: var(--cat-tech); }
  .cat-ai        { background: var(--cat-ai); }
  .cat-product   { background: var(--cat-product); }
  .cat-education { background: var(--cat-education); }
  .cat-life      { background: var(--cat-life); }

  /* ── Type badges ── */
  .type-badge {
    font-size: 0.62rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid currentColor;
    text-decoration: none;
  }
  .type-badge:hover { opacity: 0.75; }
  .type-debug     { color: #d97706; }
  .type-deep-dive { color: #4f46e5; }
  .type-guide     { color: #0d9488; }
  .type-project   { color: #64748b; }

  /* ── Type filter tabs ── */
  .type-filter {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .filter-btn {
    background: none;
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.25rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .filter-btn:hover { border-color: var(--brand-500); color: var(--brand-500); }
  .filter-btn.active { background: var(--brand-900); border-color: var(--brand-900); color: var(--bg-page); }

  /* ── Tags ── */
  .tag-pill {
    background: var(--brand-100);
    font-size: 0.72rem;
    padding: 0.08rem 0.45rem;
    border-radius: 3px;
    color: var(--brand-700);
    text-decoration: none;
  }
  .tag-pill:hover { background: var(--brand-300); }

  /* ── Prose: all MDX/markdown rendered content ── */
  .content { line-height: 1.8; margin-bottom: 3rem; }

  /* Headings — with colored underline accent (like DJ MYG) */
  .content h1 { font-size: 1.7rem; font-weight: 900; margin: 2.5rem 0 1rem; color: var(--brand-900); }
  .content h2 {
    font-size: 1.3rem;
    font-weight: 800;
    margin: 2.5rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: none;
    color: var(--brand-900);
    position: relative;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .content h2::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 3rem;
    height: 3px;
    background: var(--heading-accent);
    border-radius: 2px;
  }
  .content h3 { font-size: 1.05rem; font-weight: 700; margin: 1.5rem 0 0.5rem; color: var(--brand-900); }
  .content h4 { font-size: 0.95rem; font-weight: 700; margin: 1.25rem 0 0.4rem; color: var(--brand-900); }
  .content h5, .content h6 { font-size: 0.9rem; font-weight: 600; margin: 1rem 0 0.35rem; color: var(--text-secondary); }

  /* Heading anchor links */
  .content h2 .heading-anchor,
  .content h3 .heading-anchor {
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 400;
    font-size: 0.85em;
    opacity: 0;
    transition: opacity 0.15s;
    margin-left: 0.5rem;
  }
  .content h2:hover .heading-anchor,
  .content h3:hover .heading-anchor { opacity: 1; }

  /* Paragraph & inline */
  .content p { margin-bottom: 1rem; }
  .content strong { font-weight: 700; color: var(--text-primary); }
  .content em { font-style: italic; }
  .content del { text-decoration: line-through; color: var(--text-muted); }
  .content mark { background: #fef08a; color: #1a1a1a; padding: 0.05em 0.2em; border-radius: 2px; }

  /* Links */
  .content a { color: var(--brand-500); text-decoration: underline; text-decoration-color: var(--brand-300); text-underline-offset: 2px; }
  .content a:hover { color: var(--brand-900); text-decoration-color: var(--brand-500); }

  /* ── macOS-style Code Blocks (like DJ MYG) ── */
  .content pre {
    position: relative;
    background: var(--bg-code);
    color: #d4d4d4;
    padding: 0;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 1.25rem;
    border: 1px solid var(--border);
  }
  .content pre::before {
    content: '';
    display: block;
    padding: 0.6rem 1rem;
    background: rgba(0,0,0,0.15);
    background-image: radial-gradient(circle at 16px 50%, var(--code-dot-red) 5px, transparent 5px),
                      radial-gradient(circle at 36px 50%, var(--code-dot-yellow) 5px, transparent 5px),
                      radial-gradient(circle at 56px 50%, var(--code-dot-green) 5px, transparent 5px);
    background-repeat: no-repeat;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .content pre code {
    display: block;
    padding: 1rem 1.5rem;
    overflow-x: auto;
    font-size: 0.88rem;
    line-height: 1.6;
    counter-reset: line;
  }

  .content :not(pre) > code { background: var(--brand-100); color: var(--brand-700); padding: 0.1em 0.35em; border-radius: 3px; font-size: 0.9em; }
  .content kbd { background: var(--bg-subtle); border: 1px solid var(--border); border-radius: 3px; padding: 0.1em 0.4em; font-size: 0.85em; font-family: monospace; }

  /* ── Callout / Blockquote boxes (like DJ MYG info/success/warning) ── */
  .content blockquote {
    background: var(--info-bg);
    border-left: 4px solid var(--info-border);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    color: var(--text-primary);
    margin: 1.25rem 0;
    font-style: normal;
  }
  .content blockquote p { margin-bottom: 0.35rem; }
  .content blockquote p:last-child { margin-bottom: 0; }

  /* Tip callout (blockquote starting with [!TIP] or > **tip**) */
  .content blockquote.callout-success,
  .content blockquote:has(> p:first-child > strong:first-child:is([data-type="success"])) {
    background: var(--success-bg);
    border-left-color: var(--success-border);
  }

  /* Lists */
  .content ul, .content ol { padding-left: 1.5rem; margin-bottom: 1rem; }
  .content ul { list-style-type: disc; }
  .content ol { list-style-type: decimal; }
  .content li { margin-bottom: 0.35rem; }
  .content li > ul, .content li > ol { margin-top: 0.25rem; margin-bottom: 0.25rem; }
  .content input[type="checkbox"] { margin-right: 0.4rem; accent-color: var(--brand-500); }

  /* Horizontal rule — dashed style (like DJ MYG) */
  .content hr {
    border: none;
    border-top: 2px dashed var(--border);
    margin: 2.5rem 0;
  }

  /* Images */
  .content img { max-width: 100%; height: auto; border-radius: 8px; margin: 1rem 0; display: block; }
  .content figure { margin: 1.5rem 0; }
  .content figcaption { font-size: 0.8rem; color: var(--text-muted); text-align: center; margin-top: 0.4rem; }

  /* ── Dark styled Tables (like DJ MYG) ── */
  .content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
  }
  .content th {
    background: var(--bg-subtle);
    font-weight: 700;
    text-align: left;
    padding: 0.7rem 1rem;
    border-bottom: 2px solid var(--border);
    color: var(--text-primary);
  }
  .content td {
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
  }
  .content tr:last-child td { border-bottom: none; }
  .content tbody tr:hover { background: var(--bg-subtle); }
  .content th:not(:last-child),
  .content td:not(:last-child) {
    border-right: 1px solid var(--border);
  }
</style>

<script>
  // Dark mode toggle
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
    localStorage.setItem('theme', isDark ? 'light' : 'dark');
  });

  // Reading progress bar + scroll-to-top with percentage
  const bar = document.getElementById('progress-bar');
  const scrollBtn = document.getElementById('scroll-top');
  const scrollPct = document.getElementById('scroll-pct');
  const SCROLL_VISIBLE_THRESHOLD = 300;

  function updateScroll() {
    const max = document.body.scrollHeight - window.innerHeight;
    if (max <= 0) return;
    const pct = Math.round((window.scrollY / max) * 100);
    if (bar) bar.style.width = `${pct}%`;
    if (scrollPct) scrollPct.textContent = `${pct}%`;
    if (scrollBtn) {
      scrollBtn.classList.toggle('visible', window.scrollY > SCROLL_VISIBLE_THRESHOLD);
    }
  }

  window.addEventListener('scroll', updateScroll, { passive: true });
  updateScroll();

  scrollBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
