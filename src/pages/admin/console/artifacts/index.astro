---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('artifactViewer');
---

<AdminConsoleLayout title="Artifacts" section="artifacts">
  {!ready && (
    <AdminState tone="empty">{`Artifact viewer ships in ${consolePhaseFor('artifactViewer')}.`}</AdminState>
  )}
  {ready && (
    <AdminState tone="empty">Select a run to view its artifacts.</AdminState>
  )}
</AdminConsoleLayout>
