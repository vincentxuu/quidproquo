---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminMetric from '@/components/admin/AdminMetric.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('costDashboard');

const dimensions = [
  { value: 'flow_id', label: 'Flow' },
  { value: 'policy_id', label: 'Policy' },
  { value: 'user_id', label: 'User' },
  { value: 'agent_id', label: 'Agent' },
  { value: 'preset_id', label: 'Preset' },
  { value: 'provider_id', label: 'Provider' },
] as const;

const periods = [
  { value: 'daily', label: 'Daily', rangeDays: 30 },
  { value: 'weekly', label: 'Weekly', rangeDays: 84 },
  { value: 'monthly', label: 'Monthly', rangeDays: 365 },
] as const;

type Dimension = typeof dimensions[number]['value'];
type Period = typeof periods[number]['value'];

// --- dimension + range from URL ---
const url = Astro.url;
const requestedDimension = url.searchParams.get('dimension');
const dimension = dimensions.some((item) => item.value === requestedDimension)
  ? requestedDimension as Dimension
  : 'flow_id';
const dimensionLabel = dimensions.find((item) => item.value === dimension)?.label ?? 'Flow';
const requestedPeriod = url.searchParams.get('period');
const period = periods.some((item) => item.value === requestedPeriod)
  ? requestedPeriod as Period
  : 'daily';
const activePeriod = periods.find((item) => item.value === period) ?? periods[0];

// --- time helpers ---
const nowMs = Date.now();
const todayDay = Math.floor(nowMs / 86_400_000);
const day24hAgo = todayDay - 1;
const day7dAgo = todayDay - 7;
const day30dAgo = todayDay - 30;
// month-to-date: days elapsed since start of current month
const now = new Date();
const daysMtd = now.getDate() - 1; // days back from today's start
const dayMtdStart = todayDay - daysMtd;

// started_at threshold for 24h ago in epoch ms
const startedAt24hMs = nowMs - 86_400_000;

interface RollupRow {
  day: number;
  dimension_value: string;
  tokens_in: number;
  tokens_out: number;
  cost_usd: number;
  run_count: number;
}

interface TopRunRow {
  run_id: string;
  agent_id: string;
  total_cost: number;
  total_tokens: number;
}

interface BudgetRunRow {
  flow_run_id: string;
  flow_id: string;
  cost_usd: number;
  policy_key: string | null;
  frozen_effective_json: string | null;
}

interface BudgetAlert {
  runId: string;
  flowId: string;
  policyKey: string;
  costUsd: number;
  limitUsd: number;
  ratio: number;
}

function emptyAll<T>(): D1Result<T> {
  return {
    results: [],
    success: true,
    meta: {} as D1Meta,
  };
}

let cost24h = 0;
let cost7d = 0;
let cost30d = 0;
let costMtd = 0;
let dailyRows: RollupRow[] = [];
let topRuns: TopRunRow[] = [];
let budgetAlerts: BudgetAlert[] = [];
let loadError = false;

if (ready) {
  try {
    const db = getEnv().DB;

    const [metrics24h, metrics7d, metrics30d, metricsMtd, daily, runs, budgetRuns] = await Promise.all([
      // 24h total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day24hAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // 7d total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day7dAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // 30d total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day30dAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // month-to-date total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, dayMtdStart)
        .first<{ total: number }>()
        .catch(() => null),

      // selected period grouped by dimension, ordered by day desc then cost desc
      db
        .prepare(
          `SELECT day, dimension_value, tokens_in, tokens_out, cost_usd, run_count
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?
           ORDER BY day DESC, cost_usd DESC`,
        )
        .bind(dimension, todayDay - activePeriod.rangeDays)
        .all<RollupRow>()
        .catch(() => emptyAll<RollupRow>()),

      // top-10 costliest runs in last 24h
      db
        .prepare(
          `SELECT ar.run_id, ar.agent_id,
                  SUM(tc.cost_usd) as total_cost,
                  SUM(tc.tokens_in + tc.tokens_out) as total_tokens
           FROM agent_runs ar
           JOIN agent_tool_calls tc ON tc.run_id = ar.run_id
           WHERE ar.started_at >= ?
           GROUP BY ar.run_id
           ORDER BY total_cost DESC
           LIMIT 10`,
        )
        .bind(startedAt24hMs)
        .all<TopRunRow>()
        .catch(() => emptyAll<TopRunRow>()),

      // recent runs nearing policy budget ceilings
      db
        .prepare(
          `SELECT fr.flow_run_id,
                  fr.flow_id,
                  COALESCE(SUM(tc.cost_usd), fr.cost_usd, 0) AS cost_usd,
                  pd.policy_key,
                  pb.frozen_effective_json
           FROM flow_runs fr
           LEFT JOIN agent_runs ar ON ar.flow_run_id = fr.flow_run_id
           LEFT JOIN agent_tool_calls tc ON tc.run_id = ar.run_id
           LEFT JOIN policy_bindings pb ON CAST(pb.flow_run_id AS TEXT) = fr.flow_run_id
           LEFT JOIN policy_definitions pd ON pd.policy_id = pb.policy_id
           WHERE fr.started_at >= ?
           GROUP BY fr.flow_run_id, fr.flow_id, pd.policy_key, pb.frozen_effective_json
           ORDER BY cost_usd DESC
           LIMIT 40`,
        )
        .bind(nowMs - 30 * 86_400_000)
        .all<BudgetRunRow>()
        .catch(() => emptyAll<BudgetRunRow>()),
    ]);

    cost24h = metrics24h?.total ?? 0;
    cost7d = metrics7d?.total ?? 0;
    cost30d = metrics30d?.total ?? 0;
    costMtd = metricsMtd?.total ?? 0;
    dailyRows = daily.results ?? [];
    topRuns = runs.results ?? [];
    budgetAlerts = (budgetRuns.results ?? [])
      .map((run) => {
        let limitUsd = 0;
        try {
          const policy = JSON.parse(run.frozen_effective_json ?? '{}') as {
            budget?: { max_cost_usd?: number };
          };
          limitUsd = Number(policy.budget?.max_cost_usd ?? 0);
        } catch {
          limitUsd = 0;
        }

        if (!Number.isFinite(limitUsd) || limitUsd <= 0) return null;
        const costUsd = Number(run.cost_usd ?? 0);
        const ratio = costUsd / limitUsd;
        if (ratio < 0.8) return null;

        return {
          runId: run.flow_run_id,
          flowId: run.flow_id,
          policyKey: run.policy_key ?? '(bound policy)',
          costUsd,
          limitUsd,
          ratio,
        };
      })
      .filter((alert): alert is BudgetAlert => alert !== null)
      .slice(0, 8);
  } catch {
    loadError = true;
  }
}

function formatCost(usd: number): string {
  return `$${usd.toFixed(4)}`;
}

function formatDay(day: number): string {
  const ms = day * 86_400_000;
  const d = new Date(ms);
  const yyyy = d.getUTCFullYear();
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(d.getUTCDate()).padStart(2, '0');
  return `${yyyy}-${mm}-${dd}`;
}

// Build the switcher URL helper
function switcherHref(dim: string): string {
  const u = new URL(url.toString());
  u.searchParams.set('dimension', dim);
  return u.pathname + u.search;
}

function periodHref(nextPeriod: string): string {
  const u = new URL(url.toString());
  u.searchParams.set('period', nextPeriod);
  return u.pathname + u.search;
}

const topEntities = Array.from(
  dailyRows.reduce((map, row) => {
    const current = map.get(row.dimension_value) ?? { value: row.dimension_value, cost: 0, runs: 0 };
    current.cost += Number(row.cost_usd ?? 0);
    current.runs += Number(row.run_count ?? 0);
    map.set(row.dimension_value, current);
    return map;
  }, new Map<string, { value: string; cost: number; runs: number }>()).values(),
).sort((a, b) => b.cost - a.cost).slice(0, 10);

// Detect today's day value to identify the "latest" row for live badge
const latestDay = dailyRows.length > 0 ? dailyRows[0].day : -1;
---

<AdminConsoleLayout title="Cost" section="cost">
  {!ready && (
    <AdminState tone="empty">{`Cost dashboard ships in ${consolePhaseFor('costDashboard')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">Could not load cost data.</AdminState>
  )}
  {ready && !loadError && (
    <>
      <div class="metrics-row">
        <AdminMetric label="Last 24 h" value={formatCost(cost24h)} id="metric-24h" />
        <AdminMetric label="Last 7 days" value={formatCost(cost7d)} />
        <AdminMetric label="Last 30 days" value={formatCost(cost30d)} />
        <AdminMetric label="Month to date" value={formatCost(costMtd)} />
      </div>

      <div class="dimension-bar">
        <span class="dimension-label">Group by:</span>
        <div class="dimension-tabs" role="tablist">
          {dimensions.map((item) => (
            <a
              href={switcherHref(item.value)}
              class:list={['dim-tab', { active: dimension === item.value }]}
              role="tab"
              aria-selected={dimension === item.value ? 'true' : 'false'}
            >{item.label}</a>
          ))}
        </div>
        <span class="dimension-label period-label">Period:</span>
        <div class="dimension-tabs" role="tablist">
          {periods.map((item) => (
            <a
              href={periodHref(item.value)}
              class:list={['dim-tab', { active: period === item.value }]}
              role="tab"
              aria-selected={period === item.value ? 'true' : 'false'}
            >{item.label}</a>
          ))}
        </div>
      </div>

      <div class="cost-layout">
        <AdminPanel title={`Cost by ${dimensionLabel} — ${activePeriod.label}`} class="cost-main">
          {dailyRows.length === 0 ? (
            <AdminState tone="empty">No rollup data yet. Run the cost backfill to populate this table.</AdminState>
          ) : (
            <AdminTable minWidth="640px" flush>
              <thead>
                <tr>
                  <th>Day</th>
                  <th>{dimensionLabel} ID</th>
                  <th>Cost USD</th>
                  <th>Tokens In</th>
                  <th>Tokens Out</th>
                  <th>Runs</th>
                </tr>
              </thead>
              <tbody>
                {dailyRows.map((row) => (
                  <tr>
                    <td class="mono">
                      {formatDay(row.day)}
                      {row.day === latestDay && (
                        <span class="live-badge" id="live-badge" aria-live="polite">Live · updates every 60s</span>
                      )}
                    </td>
                    <td class="flow-id">{row.dimension_value}</td>
                    <td class="cost">{formatCost(row.cost_usd)}</td>
                    <td class="num">{row.tokens_in.toLocaleString()}</td>
                    <td class="num">{row.tokens_out.toLocaleString()}</td>
                    <td class="num">{row.run_count}</td>
                  </tr>
                ))}
              </tbody>
            </AdminTable>
          )}
        </AdminPanel>

        <div class="cost-rail-stack">
          <AdminPanel title={`Top ${dimensionLabel} Spenders`} class="cost-rail">
            {topEntities.length === 0 ? (
              <AdminState tone="empty">No rollup data for this period.</AdminState>
            ) : (
              <AdminTable minWidth="320px" flush>
                <thead>
                  <tr>
                    <th>{dimensionLabel}</th>
                    <th>Cost</th>
                    <th>Runs</th>
                  </tr>
                </thead>
                <tbody>
                  {topEntities.map((entity) => (
                    <tr>
                      <td class="flow-id">{entity.value}</td>
                      <td class="cost">{formatCost(entity.cost)}</td>
                      <td class="num">{entity.runs.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </AdminTable>
            )}
          </AdminPanel>

          <AdminPanel title="Budget Alerts" class="cost-rail">
            {budgetAlerts.length === 0 ? (
              <AdminState tone="empty">No runs are above 80% of a budget ceiling.</AdminState>
            ) : (
              <div class="budget-list">
                {budgetAlerts.map((alert) => (
                  <a class="budget-alert" href={`/admin/console/runs/${alert.runId}`}>
                    <span class="budget-head">
                      <span class="flow-id">{alert.flowId}</span>
                      <strong>{Math.round(alert.ratio * 100)}%</strong>
                    </span>
                    <span class="budget-meta">{alert.policyKey}</span>
                    <span class="budget-bar" aria-hidden="true">
                      <span style={`width: ${Math.min(alert.ratio * 100, 100)}%`}></span>
                    </span>
                    <span class="budget-cost">{formatCost(alert.costUsd)} / {formatCost(alert.limitUsd)}</span>
                  </a>
                ))}
              </div>
            )}
          </AdminPanel>

          <AdminPanel title="Top Runs — Last 24 h" class="cost-rail">
            {topRuns.length === 0 ? (
              <AdminState tone="empty">No runs in the last 24 hours.</AdminState>
            ) : (
              <AdminTable minWidth="320px" flush>
                <thead>
                  <tr>
                    <th>Run ID</th>
                    <th>Agent</th>
                    <th>Cost</th>
                    <th>Tokens</th>
                  </tr>
                </thead>
                <tbody>
                  {topRuns.map((run) => (
                    <tr>
                      <td class="mono run-id">
                        <a href={`/admin/console/runs/${run.run_id}`}>{run.run_id.slice(0, 8)}&hellip;</a>
                      </td>
                      <td class="flow-id">{run.agent_id}</td>
                      <td class="cost">{formatCost(run.total_cost)}</td>
                      <td class="num">{run.total_tokens.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </AdminTable>
            )}
          </AdminPanel>
        </div>
      </div>
    </>
  )}
</AdminConsoleLayout>

<script is:inline>
  // Live 24h polling — updates the "Last 24 h" metric tile every 60s
  (function startLivePoll() {
    const tile = document.getElementById('metric-24h');
    if (!tile) return;

    const params = new URLSearchParams(window.location.search);
    const dimension = params.get('dimension') ?? 'flow_id';

    async function poll() {
      try {
        const res = await fetch(
          `/api/admin/console/cost?dimension=${encodeURIComponent(dimension)}&range=24h&live=true`,
        );
        if (!res.ok) return;
        const data = await res.json();
        const rows = data.rows ?? [];
        const total = rows.reduce((sum, r) => sum + (r.cost_usd ?? 0), 0);
        const valueEl = tile.querySelector('[data-value], .metric-value, strong, span');
        if (valueEl) {
          valueEl.textContent = '$' + total.toFixed(4);
        } else {
          // Fallback: update any text node in the tile
          tile.dataset.liveValue = '$' + total.toFixed(4);
        }
      } catch {
        // silent — polling failures should not surface UI errors
      }
    }

    setInterval(poll, 60_000);
  })();
</script>

<style>
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--admin-space-3, 0.75rem);
    margin-bottom: var(--admin-space-4, 1rem);
  }

  @media (max-width: 900px) {
    .metrics-row {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .metrics-row {
      grid-template-columns: 1fr;
    }
  }

  .dimension-bar {
    display: flex;
    align-items: center;
    gap: var(--admin-space-3, 0.75rem);
    margin-bottom: var(--admin-space-3, 0.75rem);
    flex-wrap: wrap;
  }

  .dimension-label {
    font-size: 0.85em;
    color: var(--admin-text-muted);
    white-space: nowrap;
  }

  .dimension-tabs {
    display: flex;
    gap: 0;
    border: 1px solid var(--admin-border, #e2e8f0);
    border-radius: 6px;
    overflow: hidden;
    flex-wrap: wrap;
  }

  .dim-tab {
    padding: 0.3rem 0.9rem;
    font-size: 0.85em;
    text-decoration: none;
    color: var(--admin-text-muted, #64748b);
    background: transparent;
    border-right: 1px solid var(--admin-border, #e2e8f0);
    transition: background 0.1s;
  }

  .dim-tab:last-child {
    border-right: none;
  }

  .dim-tab:hover {
    background: var(--admin-surface-hover, #f8fafc);
    color: var(--admin-text, #0f172a);
  }

  .dim-tab.active {
    background: var(--admin-accent, #2563eb);
    color: #fff;
    font-weight: 600;
  }

  .period-label {
    margin-left: var(--admin-space-2, 0.5rem);
  }

  .cost-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--admin-space-4, 1rem);
    align-items: start;
  }

  .cost-rail-stack {
    display: grid;
    gap: var(--admin-space-4, 1rem);
  }

  @media (max-width: 1100px) {
    .cost-layout {
      grid-template-columns: 1fr;
    }
  }

  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .run-id a {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
  }

  .run-id a:hover {
    text-decoration: underline;
  }

  .flow-id {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.82em;
    color: var(--admin-text-muted);
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .cost {
    font-variant-numeric: tabular-nums;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .num {
    text-align: right;
    font-variant-numeric: tabular-nums;
    font-size: 0.85em;
  }

  .budget-list {
    display: grid;
    gap: var(--admin-space-3, 0.75rem);
  }

  .budget-alert {
    display: grid;
    gap: 0.35rem;
    padding: 0.75rem;
    border: 1px solid var(--admin-border, #e2e8f0);
    border-radius: 6px;
    color: inherit;
    text-decoration: none;
  }

  .budget-alert:hover {
    border-color: var(--admin-accent, #2563eb);
    background: var(--admin-surface-hover, #f8fafc);
  }

  .budget-head {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: center;
  }

  .budget-meta,
  .budget-cost {
    color: var(--admin-text-muted, #64748b);
    font-size: 0.82em;
  }

  .budget-bar {
    display: block;
    height: 6px;
    overflow: hidden;
    border-radius: 999px;
    background: var(--admin-border, #e2e8f0);
  }

  .budget-bar span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: var(--admin-warning, #d97706);
  }

  .live-badge {
    display: inline-block;
    margin-left: 0.5em;
    padding: 0.1em 0.5em;
    font-size: 0.75em;
    font-family: ui-sans-serif, system-ui, sans-serif;
    background: var(--admin-success-bg, #dcfce7);
    color: var(--admin-success, #166534);
    border-radius: 999px;
    vertical-align: middle;
    white-space: nowrap;
  }
</style>
