---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminMetric from '@/components/admin/AdminMetric.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('costDashboard');

const dimensions = [
  { value: 'flow_id', label: '工作流程' },
  { value: 'policy_id', label: '政策' },
  { value: 'user_id', label: '使用者' },
  { value: 'agent_id', label: '代理程式' },
  { value: 'preset_id', label: '預設配置' },
  { value: 'provider_id', label: '提供者' },
] as const;

const periods = [
  { value: 'daily', label: '每日', rangeDays: 30 },
  { value: 'weekly', label: '每週', rangeDays: 84 },
  { value: 'monthly', label: '每月', rangeDays: 365 },
] as const;

type Dimension = typeof dimensions[number]['value'];
type Period = typeof periods[number]['value'];

// --- dimension + range from URL ---
const url = Astro.url;
const requestedDimension = url.searchParams.get('dimension');
const dimension = dimensions.some((item) => item.value === requestedDimension)
  ? requestedDimension as Dimension
  : 'flow_id';
const dimensionLabel = dimensions.find((item) => item.value === dimension)?.label ?? 'Flow';
const requestedPeriod = url.searchParams.get('period');
const period = periods.some((item) => item.value === requestedPeriod)
  ? requestedPeriod as Period
  : 'daily';
const activePeriod = periods.find((item) => item.value === period) ?? periods[0];

// --- time helpers ---
const nowMs = Date.now();
const todayDay = Math.floor(nowMs / 86_400_000);
const day24hAgo = todayDay - 1;
const day7dAgo = todayDay - 7;
const day30dAgo = todayDay - 30;
// month-to-date: days elapsed since start of current month
const now = new Date();
const daysMtd = now.getDate() - 1; // days back from today's start
const dayMtdStart = todayDay - daysMtd;

// started_at threshold for 24h ago in epoch ms
const startedAt24hMs = nowMs - 86_400_000;

interface RollupRow {
  day: number;
  dimension_value: string;
  tokens_in: number;
  tokens_out: number;
  cost_usd: number;
  run_count: number;
}

interface TopRunRow {
  run_id: string;
  agent_id: string;
  total_cost: number;
  total_tokens: number;
}

interface BudgetRunRow {
  flow_run_id: string;
  flow_id: string;
  cost_usd: number;
  policy_key: string | null;
  frozen_effective_json: string | null;
}

interface BudgetAlert {
  runId: string;
  flowId: string;
  policyKey: string;
  costUsd: number;
  limitUsd: number;
  ratio: number;
}

interface BackfillAuditRow {
  audit_id: number;
  user_email: string | null;
  payload_json: string | null;
  created_at: number;
}

function emptyAll<T>(): D1Result<T> {
  return {
    results: [],
    success: true,
    meta: {} as unknown as D1Meta & Record<string, unknown>,
  };
}

let cost24h = 0;
let cost7d = 0;
let cost30d = 0;
let costMtd = 0;
let dailyRows: RollupRow[] = [];
let topRuns: TopRunRow[] = [];
let budgetAlerts: BudgetAlert[] = [];
let recentBackfills: BackfillAuditRow[] = [];
let loadError = false;

if (ready) {
  try {
    const db = getEnv().DB;

    const [metrics24h, metrics7d, metrics30d, metricsMtd, daily, runs, budgetRuns, backfillAudit] = await Promise.all([
      // 24h total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day24hAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // 7d total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day7dAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // 30d total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, day30dAgo)
        .first<{ total: number }>()
        .catch(() => null),

      // month-to-date total
      db
        .prepare(
          `SELECT COALESCE(SUM(cost_usd), 0) as total
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?`,
        )
        .bind(dimension, dayMtdStart)
        .first<{ total: number }>()
        .catch(() => null),

      // selected period grouped by dimension, ordered by day desc then cost desc
      db
        .prepare(
          `SELECT day, dimension_value, tokens_in, tokens_out, cost_usd, run_count
           FROM cost_rollup_daily
           WHERE dimension = ? AND day >= ?
           ORDER BY day DESC, cost_usd DESC`,
        )
        .bind(dimension, todayDay - activePeriod.rangeDays)
        .all<RollupRow>()
        .catch(() => emptyAll<RollupRow>()),

      // top-10 costliest runs in last 24h
      db
        .prepare(
          `SELECT ar.run_id, ar.agent_id,
                  SUM(tc.cost_usd) as total_cost,
                  SUM(tc.tokens_in + tc.tokens_out) as total_tokens
           FROM agent_runs ar
           JOIN agent_tool_calls tc ON tc.run_id = ar.run_id
           WHERE ar.started_at >= ?
           GROUP BY ar.run_id
           ORDER BY total_cost DESC
           LIMIT 10`,
        )
        .bind(startedAt24hMs)
        .all<TopRunRow>()
        .catch(() => emptyAll<TopRunRow>()),

      // recent runs nearing policy budget ceilings
      db
        .prepare(
          `SELECT fr.flow_run_id,
                  fr.flow_id,
                  COALESCE(SUM(tc.cost_usd), fr.cost_usd, 0) AS cost_usd,
                  pd.policy_key,
                  pb.frozen_effective_json
           FROM flow_runs fr
           LEFT JOIN agent_runs ar ON ar.flow_run_id = fr.flow_run_id
           LEFT JOIN agent_tool_calls tc ON tc.run_id = ar.run_id
           LEFT JOIN policy_bindings pb ON CAST(pb.flow_run_id AS TEXT) = fr.flow_run_id
           LEFT JOIN policy_definitions pd ON pd.policy_id = pb.policy_id
           WHERE fr.started_at >= ?
           GROUP BY fr.flow_run_id, fr.flow_id, pd.policy_key, pb.frozen_effective_json
           ORDER BY cost_usd DESC
           LIMIT 40`,
        )
        .bind(nowMs - 30 * 86_400_000)
        .all<BudgetRunRow>()
        .catch(() => emptyAll<BudgetRunRow>()),

      db
        .prepare(
          `SELECT al.audit_id,
                  u.email as user_email,
                  al.payload_json,
                  al.created_at
           FROM console_audit_log al
           LEFT JOIN console_users u ON u.user_id = al.user_id
           WHERE al.action = 'cost.backfill'
           ORDER BY al.created_at DESC
           LIMIT 8`,
        )
        .all<BackfillAuditRow>()
        .catch(() => emptyAll<BackfillAuditRow>()),
    ]);

    cost24h = metrics24h?.total ?? 0;
    cost7d = metrics7d?.total ?? 0;
    cost30d = metrics30d?.total ?? 0;
    costMtd = metricsMtd?.total ?? 0;
    dailyRows = daily.results ?? [];
    topRuns = runs.results ?? [];
    recentBackfills = backfillAudit.results ?? [];
    budgetAlerts = (budgetRuns.results ?? [])
      .map((run) => {
        let limitUsd = 0;
        try {
          const policy = JSON.parse(run.frozen_effective_json ?? '{}') as {
            budget?: { max_cost_usd?: number };
          };
          limitUsd = Number(policy.budget?.max_cost_usd ?? 0);
        } catch {
          limitUsd = 0;
        }

        if (!Number.isFinite(limitUsd) || limitUsd <= 0) return null;
        const costUsd = Number(run.cost_usd ?? 0);
        const ratio = costUsd / limitUsd;
        if (ratio < 0.8) return null;

        return {
          runId: run.flow_run_id,
          flowId: run.flow_id,
          policyKey: run.policy_key ?? '(bound policy)',
          costUsd,
          limitUsd,
          ratio,
        };
      })
      .filter((alert): alert is BudgetAlert => alert !== null)
      .slice(0, 8);
  } catch {
    loadError = true;
  }
}

function formatCost(usd: number): string {
  return `$${usd.toFixed(4)}`;
}

function formatDay(day: number): string {
  const ms = day * 86_400_000;
  const d = new Date(ms);
  const yyyy = d.getUTCFullYear();
  const mm = String(d.getUTCMonth() + 1).padStart(2, '0');
  const dd = String(d.getUTCDate()).padStart(2, '0');
  return `${yyyy}-${mm}-${dd}`;
}

function formatTs(ms: number): string {
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

function parseBackfillPayload(raw: string | null): {
  range: string;
  fromDay: number | null;
  toDay: number | null;
  rows: string;
  cost: string;
  tokens: string;
} {
  if (!raw) return { range: '—', fromDay: null, toDay: null, rows: '—', cost: '—', tokens: '—' };
  try {
    const summary = JSON.parse(raw) as {
      fromDay?: number;
      toDay?: number;
      rowsWritten?: number;
      costUsd?: number;
      tokensIn?: number;
      tokensOut?: number;
    };
    const from = typeof summary.fromDay === 'number' ? formatDay(summary.fromDay) : '?';
    const to = typeof summary.toDay === 'number' ? formatDay(summary.toDay) : '?';
    const tokens = Number(summary.tokensIn ?? 0) + Number(summary.tokensOut ?? 0);
    return {
      range: `${from} → ${to}`,
      fromDay: typeof summary.fromDay === 'number' ? summary.fromDay : null,
      toDay: typeof summary.toDay === 'number' ? summary.toDay : null,
      rows: Number(summary.rowsWritten ?? 0).toLocaleString(),
      cost: formatCost(Number(summary.costUsd ?? 0)),
      tokens: tokens.toLocaleString(),
    };
  } catch {
    return { range: '—', fromDay: null, toDay: null, rows: '—', cost: '—', tokens: '—' };
  }
}

// Build the switcher URL helper
function switcherHref(dim: string): string {
  const u = new URL(url.toString());
  u.searchParams.set('dimension', dim);
  return u.pathname + u.search;
}

function periodHref(nextPeriod: string): string {
  const u = new URL(url.toString());
  u.searchParams.set('period', nextPeriod);
  return u.pathname + u.search;
}

function budgetWidthStyle(ratio: number): string {
  return `width: ${Math.min(ratio * 100, 100)}%`;
}

const topEntities = Array.from(
  dailyRows.reduce((map, row) => {
    const current = map.get(row.dimension_value) ?? { value: row.dimension_value, cost: 0, runs: 0 };
    current.cost += Number(row.cost_usd ?? 0);
    current.runs += Number(row.run_count ?? 0);
    map.set(row.dimension_value, current);
    return map;
  }, new Map<string, { value: string; cost: number; runs: number }>()).values(),
).sort((a, b) => b.cost - a.cost).slice(0, 10);

const recentBackfillRows = recentBackfills.map((row) => ({
  auditId: row.audit_id,
  userEmail: row.user_email ?? 'admin',
  createdAt: formatTs(row.created_at),
  ...parseBackfillPayload(row.payload_json),
}));

// Detect today's day value to identify the "latest" row for live badge
const latestDay = dailyRows.length > 0 ? dailyRows[0].day : -1;
---

<AdminConsoleLayout title="費用總覽" section="cost">
  {!ready && (
    <AdminState tone="empty">{`費用儀表板將於 ${consolePhaseFor('costDashboard')} 推出。`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">無法載入費用資料。</AdminState>
  )}
  {ready && !loadError && (
    <>
      <div class="metrics-row">
        <AdminMetric label="近 24 小時" value={formatCost(cost24h)} id="metric-24h" />
        <AdminMetric label="近 7 天" value={formatCost(cost7d)} />
        <AdminMetric label="近 30 天" value={formatCost(cost30d)} />
        <AdminMetric label="本月至今" value={formatCost(costMtd)} />
      </div>

      <div class="dimension-bar">
        <span class="dimension-label">分組依據：</span>
        <div class="dimension-tabs" role="tablist">
          {dimensions.map((item) => (
            <a
              href={switcherHref(item.value)}
              class:list={['dim-tab', { active: dimension === item.value }]}
              role="tab"
              aria-selected={dimension === item.value ? 'true' : 'false'}
            >{item.label}</a>
          ))}
        </div>
        <span class="dimension-label period-label">期間：</span>
        <div class="dimension-tabs" role="tablist">
          {periods.map((item) => (
            <a
              href={periodHref(item.value)}
              class:list={['dim-tab', { active: period === item.value }]}
              role="tab"
              aria-selected={period === item.value ? 'true' : 'false'}
            >{item.label}</a>
          ))}
        </div>
      </div>

      <AdminPanel title="費用彙總回填" eyebrow="修補缺漏日期或首次部署後建立 rollup">
        <form id="cost-backfill-form" class="backfill-form">
          <div class="backfill-presets" aria-label="常用回填區間">
            <button type="button" class="backfill-preset" value="7">近 7 天</button>
            <button type="button" class="backfill-preset" value="30">近 30 天</button>
            <button type="button" class="backfill-preset" value="90">近 90 天</button>
          </div>
          <p id="cost-backfill-preview" class="backfill-preview" aria-live="polite">
            <span>回填區間</span>
            <strong id="cost-backfill-preview-range">—</strong>
            <span id="cost-backfill-preview-risk">請選擇日期。</span>
            <small id="cost-backfill-preview-estimate">估計寫入列數會在選擇日期後顯示。</small>
          </p>
          <div class="backfill-row">
            <label for="backfill-from">起始日期</label>
            <input id="backfill-from" name="from" type="date" required />
          </div>
          <div class="backfill-row">
            <label for="backfill-to">結束日期</label>
            <input id="backfill-to" name="to" type="date" required />
          </div>
          <button type="submit" class="backfill-button">執行回填</button>
          <p id="cost-backfill-warning" class="backfill-warning" hidden></p>
          <p id="cost-backfill-status" class="backfill-status" role="status" aria-live="polite" hidden></p>
          <dl id="cost-backfill-summary" class="backfill-summary" hidden>
            <div>
              <dt>處理天數</dt>
              <dd data-summary="days">—</dd>
            </div>
            <div>
              <dt>寫入列數</dt>
              <dd data-summary="rows">—</dd>
            </div>
            <div>
              <dt>費用</dt>
              <dd data-summary="cost">—</dd>
            </div>
            <div>
              <dt>Tokens</dt>
              <dd data-summary="tokens">—</dd>
            </div>
          </dl>
        </form>
        <div
          id="cost-backfill-history"
          class={recentBackfills.length === 0 ? 'backfill-history is-empty' : 'backfill-history'}
        >
          <h3>最近回填</h3>
          <div id="cost-backfill-history-body" class="backfill-history-list">
            {recentBackfillRows.length === 0 ? (
              <p data-empty-history>尚無回填紀錄。</p>
            ) : (
              recentBackfillRows.map((row) => (
                <div class="backfill-history-row">
                  <span class="mono">{row.createdAt}</span>
                  <strong class="mono">{row.range}</strong>
                  <span>{row.rows} 列</span>
                  <span class="cost">{row.cost}</span>
                  <span>{row.tokens} tokens</span>
                  <span>{row.userEmail}</span>
                  <button
                    type="button"
                    class="backfill-repeat"
                    data-repeat-backfill
                    data-from-day={row.fromDay ?? ''}
                    data-to-day={row.toDay ?? ''}
                    disabled={row.fromDay === null || row.toDay === null}
                    aria-label={`重跑回填區間 ${row.range}`}
                  >
                    重跑
                  </button>
                </div>
              ))
            )}
          </div>
        </div>
      </AdminPanel>

      <div class="cost-layout">
        <AdminPanel title={`依 ${dimensionLabel} 分類費用 — ${activePeriod.label}`} class="cost-main">
          {dailyRows.length === 0 ? (
            <AdminState tone="empty">尚無彙總資料。請執行費用回填以填入此資料表。</AdminState>
          ) : (
            <AdminTable minWidth="640px" flush>
              <thead>
                <tr>
                  <th>日期</th>
                  <th>{dimensionLabel} ID</th>
                  <th>費用 (USD)</th>
                  <th>輸入 tokens</th>
                  <th>輸出 tokens</th>
                  <th>執行次數</th>
                </tr>
              </thead>
              <tbody>
                {dailyRows.map((row) => (
                  <tr>
                    <td class="mono">
                      {formatDay(row.day)}
                      {row.day === latestDay && (
                        <span class="live-badge" id="live-badge" aria-live="polite">即時 · 每 60 秒更新</span>
                      )}
                    </td>
                    <td class="flow-id">{row.dimension_value}</td>
                    <td class="cost">{formatCost(row.cost_usd)}</td>
                    <td class="num">{row.tokens_in.toLocaleString()}</td>
                    <td class="num">{row.tokens_out.toLocaleString()}</td>
                    <td class="num">{row.run_count}</td>
                  </tr>
                ))}
              </tbody>
            </AdminTable>
          )}
        </AdminPanel>

        <div class="cost-rail-stack">
          <AdminPanel title={`${dimensionLabel} 費用排行`} class="cost-rail">
            {topEntities.length === 0 ? (
              <AdminState tone="empty">此期間無彙總資料。</AdminState>
            ) : (
              <AdminTable minWidth="320px" flush>
                <thead>
                  <tr>
                    <th>{dimensionLabel}</th>
                    <th>費用</th>
                    <th>執行次數</th>
                  </tr>
                </thead>
                <tbody>
                  {topEntities.map((entity) => (
                    <tr>
                      <td class="flow-id">{entity.value}</td>
                      <td class="cost">{formatCost(entity.cost)}</td>
                      <td class="num">{entity.runs.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </AdminTable>
            )}
          </AdminPanel>

          <AdminPanel title="預算警示" class="cost-rail">
            {budgetAlerts.length === 0 ? (
              <AdminState tone="empty">目前無執行項目超過預算上限的 80%。</AdminState>
            ) : (
              <div class="budget-list">
                {budgetAlerts.map((alert) => (
                  <a class="budget-alert" href={`/admin/console/runs/${alert.runId}`}>
                    <span class="budget-head">
                      <span class="flow-id">{alert.flowId}</span>
                      <strong>{Math.round(alert.ratio * 100)}%</strong>
                    </span>
                    <span class="budget-meta">{alert.policyKey}</span>
                    <span class="budget-bar" aria-hidden="true">
                      <span style={budgetWidthStyle(alert.ratio)}></span>
                    </span>
                    <span class="budget-cost">{formatCost(alert.costUsd)} / {formatCost(alert.limitUsd)}</span>
                  </a>
                ))}
              </div>
            )}
          </AdminPanel>

          <AdminPanel title="近 24 小時費用排行" class="cost-rail">
            {topRuns.length === 0 ? (
              <AdminState tone="empty">近 24 小時內無執行記錄。</AdminState>
            ) : (
              <AdminTable minWidth="320px" flush>
                <thead>
                  <tr>
                    <th>執行 ID</th>
                    <th>代理程式</th>
                    <th>費用</th>
                    <th>Tokens</th>
                  </tr>
                </thead>
                <tbody>
                  {topRuns.map((run) => (
                    <tr>
                      <td class="mono run-id">
                        <a href={`/admin/console/runs/${run.run_id}`}>{run.run_id.slice(0, 8)}&hellip;</a>
                      </td>
                      <td class="flow-id">{run.agent_id}</td>
                      <td class="cost">{formatCost(run.total_cost)}</td>
                      <td class="num">{run.total_tokens.toLocaleString()}</td>
                    </tr>
                  ))}
                </tbody>
              </AdminTable>
            )}
          </AdminPanel>
        </div>
      </div>
    </>
  )}
</AdminConsoleLayout>

<script is:inline>
  // Live 24h polling — updates the "Last 24 h" metric tile every 60s
  (function startLivePoll() {
    const tile = document.getElementById('metric-24h');
    if (!tile) return;

    const params = new URLSearchParams(window.location.search);
    const dimension = params.get('dimension') ?? 'flow_id';

    async function poll() {
      try {
        const res = await fetch(
          `/api/admin/console/cost?dimension=${encodeURIComponent(dimension)}&range=24h&live=true`,
        );
        if (!res.ok) return;
        const data = await res.json();
        const rows = data.rows ?? [];
        const total = rows.reduce((sum, r) => sum + (r.cost_usd ?? 0), 0);
        const valueEl = tile.querySelector('[data-value], .metric-value, strong, span');
        if (valueEl) {
          valueEl.textContent = '$' + total.toFixed(4);
        } else {
          // Fallback: update any text node in the tile
          tile.dataset.liveValue = '$' + total.toFixed(4);
        }
      } catch {
        // silent — polling failures should not surface UI errors
      }
    }

    setInterval(poll, 60_000);
  })();

  (function setupBackfillForm() {
    const form = document.getElementById('cost-backfill-form');
    const status = document.getElementById('cost-backfill-status');
    const summaryBox = document.getElementById('cost-backfill-summary');
    const warning = document.getElementById('cost-backfill-warning');
    const history = document.getElementById('cost-backfill-history');
    const historyBody = document.getElementById('cost-backfill-history-body');
    if (!(form instanceof HTMLFormElement) || !status) return;

    const fromInput = document.getElementById('backfill-from');
    const toInput = document.getElementById('backfill-to');
    const today = new Date();
    const toDate = today.toISOString().slice(0, 10);
    const fromDate = new Date(today.getTime() - 90 * 86_400_000).toISOString().slice(0, 10);
    if (fromInput instanceof HTMLInputElement && !fromInput.value) fromInput.value = fromDate;
    if (toInput instanceof HTMLInputElement && !toInput.value) toInput.value = toDate;
    if (fromInput instanceof HTMLInputElement) fromInput.max = toDate;
    if (toInput instanceof HTMLInputElement) toInput.max = toDate;

    function dayNumber(value) {
      const ms = Date.parse(`${value}T00:00:00Z`);
      return Number.isFinite(ms) ? Math.floor(ms / 86_400_000) : null;
    }

    function setStatus(message, tone = '') {
      status.hidden = false;
      status.textContent = message;
      status.className = `backfill-status ${tone}`;
    }

    function setWarning(message) {
      if (!warning) return;
      warning.hidden = !message;
      warning.textContent = message;
    }

    function formatDay(day) {
      return new Date(day * 86_400_000).toISOString().slice(0, 10);
    }

    function setRangeFromPreset(days) {
      if (!(fromInput instanceof HTMLInputElement) || !(toInput instanceof HTMLInputElement)) return;
      const end = new Date();
      const start = new Date(end.getTime() - (Number(days) - 1) * 86_400_000);
      fromInput.value = start.toISOString().slice(0, 10);
      toInput.value = end.toISOString().slice(0, 10);
      updateRangeWarning();
    }

    function setRangeFromDays(fromDay, toDay) {
      if (!(fromInput instanceof HTMLInputElement) || !(toInput instanceof HTMLInputElement)) return;
      if (!Number.isFinite(fromDay) || !Number.isFinite(toDay)) return;
      fromInput.value = formatDay(fromDay);
      toInput.value = formatDay(toDay);
      updateRangeWarning();
      setStatus(`已帶入歷史回填區間：${formatDay(fromDay)} → ${formatDay(toDay)}。確認後可重新執行。`);
      fromInput.focus();
    }

    function updateRangeWarning() {
      if (!(fromInput instanceof HTMLInputElement) || !(toInput instanceof HTMLInputElement)) return;
      const fromDay = dayNumber(fromInput.value);
      const toDay = dayNumber(toInput.value);
      const previewRange = document.getElementById('cost-backfill-preview-range');
      const previewRisk = document.getElementById('cost-backfill-preview-risk');
      const previewEstimate = document.getElementById('cost-backfill-preview-estimate');
      if (fromDay == null || toDay == null || fromDay > toDay) {
        setWarning('');
        if (previewRange) previewRange.textContent = '—';
        if (previewRisk) previewRisk.textContent = '日期區間無效。';
        if (previewEstimate) previewEstimate.textContent = '請修正日期後再送出。';
        return;
      }
      const days = toDay - fromDay + 1;
      const estimatedMaxRows = days * 6;
      if (previewRange) previewRange.textContent = `${formatDay(fromDay)} → ${formatDay(toDay)} · ${days} 天`;
      if (previewRisk) {
        previewRisk.textContent = days > 366
          ? '超過 366 天上限，請縮小區間。'
          : days > 120
            ? '大型區間，建議分批執行。'
            : days > 31
              ? '送出前會再次確認，並重寫既有 rollup。'
              : '會重寫此區間既有 rollup，可直接執行。';
      }
      if (previewEstimate) {
        previewEstimate.textContent = `最多會重建 ${estimatedMaxRows.toLocaleString()} 個每日維度 bucket；實際列數取決於此區間是否有 tool calls。`;
      }

      const submit = form.querySelector('button[type="submit"]');
      if (submit instanceof HTMLButtonElement) submit.disabled = days > 366;

      if (days > 366) {
        setWarning(`目前選擇 ${days} 天，超過單次回填 366 天上限。`);
      } else if (days > 120) {
        setWarning(`目前選擇 ${days} 天。大型回填可能需要較久，建議分批執行。`);
      } else if (days > 31) {
        setWarning(`目前選擇 ${days} 天，送出前會再次確認。`);
      } else {
        setWarning('');
      }
    }

    function setSummary(summary) {
      if (!summaryBox) return;
      const days = summaryBox.querySelector('[data-summary="days"]');
      const rows = summaryBox.querySelector('[data-summary="rows"]');
      const cost = summaryBox.querySelector('[data-summary="cost"]');
      const tokens = summaryBox.querySelector('[data-summary="tokens"]');
      const tokensTotal = Number(summary.tokensIn || 0) + Number(summary.tokensOut || 0);
      if (days) days.textContent = `${summary.daysProcessed ?? 0}`;
      if (rows) rows.textContent = `${summary.rowsWritten ?? 0}`;
      if (cost) cost.textContent = `$${Number(summary.costUsd || 0).toFixed(4)}`;
      if (tokens) tokens.textContent = tokensTotal.toLocaleString();
      summaryBox.hidden = false;
    }

    function prependHistory(summary, opts = {}) {
      if (!(historyBody instanceof HTMLElement)) return;
      history?.classList.remove('is-empty');
      historyBody.querySelector('[data-empty-history]')?.remove();
      const tokensTotal = Number(summary.tokensIn || 0) + Number(summary.tokensOut || 0);
      const row = document.createElement('div');
      row.className = opts.failed ? 'backfill-history-row failed' : 'backfill-history-row';
      row.innerHTML = `
        <span class="mono">剛剛</span>
        <strong class="mono">${formatDay(summary.fromDay)} → ${formatDay(summary.toDay)}</strong>
        <span>${opts.failed ? '失敗' : `${Number(summary.rowsWritten || 0).toLocaleString()} 列`}</span>
        <span class="cost">${opts.failed ? String(opts.error || '—') : `$${Number(summary.costUsd || 0).toFixed(4)}`}</span>
        <span>${opts.failed ? '—' : `${tokensTotal.toLocaleString()} tokens`}</span>
        <span>admin</span>
        <button type="button" class="backfill-repeat" data-repeat-backfill data-from-day="${summary.fromDay}" data-to-day="${summary.toDay}">重跑</button>
      `;
      historyBody.prepend(row);
    }

    form.querySelectorAll('.backfill-preset').forEach((button) => {
      button.addEventListener('click', () => {
        if (!(button instanceof HTMLButtonElement)) return;
        setRangeFromPreset(button.value || '90');
      });
    });

    fromInput?.addEventListener('change', updateRangeWarning);
    toInput?.addEventListener('change', updateRangeWarning);
    historyBody?.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;
      if (target.dataset.repeatBackfill === undefined) return;
      const fromDay = Number(target.dataset.fromDay);
      const toDay = Number(target.dataset.toDay);
      setRangeFromDays(fromDay, toDay);
    });
    updateRangeWarning();

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (summaryBox) summaryBox.hidden = true;
      const data = new FormData(form);
      const fromDay = dayNumber(String(data.get('from') ?? ''));
      const toDay = dayNumber(String(data.get('to') ?? ''));
      if (fromDay == null || toDay == null || fromDay > toDay) {
        setStatus('日期區間無效。', 'error');
        return;
      }
      const todayDay = dayNumber(toDate);
      if (todayDay != null && (fromDay > todayDay || toDay > todayDay)) {
        setStatus('不能回填未來日期。', 'error');
        return;
      }
      const days = toDay - fromDay + 1;
      if (days > 366) {
        setStatus('單次回填不能超過 366 天，請縮小區間。', 'error');
        return;
      }
      if (days > 31 && !window.confirm(`確定要回填 ${days} 天？大型區間可能耗時較久，也會重寫既有 rollup。`)) {
        return;
      }

      const submit = form.querySelector('button[type="submit"]');
      if (submit instanceof HTMLButtonElement) {
        submit.disabled = true;
        submit.dataset.originalText = submit.textContent || '';
        submit.textContent = '回填中…';
      }
      setStatus('正在執行費用回填...');
      try {
        const res = await fetch('/api/admin/console/cost/backfill', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ fromDay, toDay }),
        });
        const body = await res.json().catch(() => ({}));
        if (!res.ok) {
          prependHistory({ fromDay, toDay }, { failed: true, error: body.error || res.status });
          setStatus(body.error || '費用回填失敗。', 'error');
          return;
        }
        if (body.summary) setSummary(body.summary);
        if (body.summary) prependHistory(body.summary);
        const days = body.summary?.daysProcessed ?? (toDay - fromDay + 1);
        const rows = body.summary?.rowsWritten ?? 0;
        setStatus(`費用回填完成：處理 ${days} 天，寫入 ${rows} 列。重新整理後可檢視最新彙總。`, 'success');
      } catch {
        prependHistory({ fromDay, toDay }, { failed: true, error: 'network' });
        setStatus('費用回填失敗。', 'error');
      } finally {
        if (submit instanceof HTMLButtonElement) {
          submit.disabled = false;
          submit.textContent = submit.dataset.originalText || '執行回填';
          delete submit.dataset.originalText;
        }
      }
    });
  })();
</script>

