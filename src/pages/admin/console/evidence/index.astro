---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('evidenceViewer');
---

<AdminConsoleLayout title="Evidence" section="evidence">
  {!ready && (
    <AdminState tone="empty">{`Evidence viewer ships in ${consolePhaseFor('evidenceViewer')}.`}</AdminState>
  )}
  {ready && (
    <AdminState tone="empty">Select a run to view its evidence.</AdminState>
  )}
</AdminConsoleLayout>
