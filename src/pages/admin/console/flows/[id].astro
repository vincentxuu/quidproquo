---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import FlowVersionList from '@/components/admin/console/FlowVersionList.astro';
import FlowPresetList from '@/components/admin/console/FlowPresetList.astro';
import RunsTable from '@/components/admin/console/RunsTable.astro';
import { getEnv } from '@/lib/config/env';
import { loadFlowDetail, type FlowDetail } from '@/lib/agent-console/flow-detail';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');
const flowId = Astro.params.id ?? '';

let detail: FlowDetail | null = null;
let loadError = false;
if (ready && flowId) {
  try {
    detail = await loadFlowDetail(getEnv().DB, flowId);
  } catch {
    loadError = true;
  }
}

const currentYaml = detail?.versions[0]?.yaml ?? '';
const breadcrumb = [
  { label: 'Flows', href: '/admin/console/flows' },
  { label: detail?.definition.name ?? flowId },
];
---

<AdminConsoleLayout title="Flow Detail" section="flows" breadcrumb={breadcrumb}>
  {!ready && (
    <AdminState tone="empty">{`Flow management ships in ${consolePhaseFor('management')}.`}</AdminState>
  )}
  {ready && loadError && <AdminState tone="error">Could not load flow.</AdminState>}
  {ready && !loadError && !detail && <AdminState tone="empty">{`Flow "${flowId}" not found.`}</AdminState>}
  {ready && detail && (
    <div class="flow-detail">
      <header class="detail-head">
        <h2>{detail.definition.name} <code>{detail.definition.id}</code></h2>
        {detail.definition.description && <p class="desc">{detail.definition.description}</p>}
      </header>

      <section aria-label="Current definition">
        <h3>Current YAML (v{detail.definition.version})</h3>
        <pre class="yaml-block">{currentYaml || 'No YAML stored for this version.'}</pre>
      </section>

      <section aria-label="Inputs">
        <h3>Inputs</h3>
        {detail.definition.inputs.length === 0 ? (
          <p class="empty-note">No declared inputs.</p>
        ) : (
          <ul class="inputs">
            {detail.definition.inputs.map((input) => (
              <li>
                <code>{input.name}</code> <span class="muted">{input.type}{input.required ? ' · required' : ''}</span>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section aria-label="Versions">
        <h3>Versions</h3>
        <FlowVersionList versions={detail.versions} latestVersion={detail.definition.version} />
      </section>

      <section aria-label="Presets">
        <h3>Presets</h3>
        <FlowPresetList presets={detail.presets} />
      </section>

      <section aria-label="Recent runs">
        <h3>Recent runs</h3>
        {detail.recentRuns.length === 0 ? (
          <p class="empty-note">No runs yet.</p>
        ) : (
          <RunsTable runs={detail.recentRuns} />
        )}
      </section>
    </div>
  )}
</AdminConsoleLayout>

<style>
  .flow-detail {
    display: grid;
    gap: 1.5rem;
  }
  .detail-head h2 {
    font-size: 1.2rem;
  }
  .detail-head code {
    font-size: 0.82rem;
    color: var(--admin-text-soft);
  }
  .detail-head .desc {
    color: var(--admin-text-muted);
    margin-top: 0.25rem;
  }
  .flow-detail h3 {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .yaml-block {
    margin: 0;
    padding: 0.75rem;
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    font-size: 0.8rem;
    overflow: auto;
    max-height: 420px;
  }
  .inputs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
  }
  .inputs .muted,
  .empty-note {
    color: var(--admin-text-muted);
    font-size: 0.82rem;
  }
</style>
