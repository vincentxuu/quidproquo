---
// NOTE: This file is a copy of flows/[id].astro created to allow flows/[id]/edit.astro
// to coexist in Astro's routing. The original flows/[id].astro should be removed once
// this copy is confirmed working.
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import FlowVersionList from '@/components/admin/console/FlowVersionList.astro';
import FlowPresetList from '@/components/admin/console/FlowPresetList.astro';
import RunsTable from '@/components/admin/console/RunsTable.astro';
import { getEnv } from '@/lib/config/env';
import { loadFlowDetail, type FlowDetail } from '@/lib/agent-console/flow-detail';
import { consoleHref, createConsoleTranslator, getConsoleLang } from '@/lib/admin-console/i18n';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');
const flowId = Astro.params.id ?? '';
const lang = getConsoleLang(Astro.url);
const t = createConsoleTranslator(lang);

let detail: FlowDetail | null = null;
let loadError = false;
if (ready && flowId) {
  try {
    detail = await loadFlowDetail(getEnv().DB, flowId);
  } catch {
    loadError = true;
  }
}

const currentYaml = detail?.versions[0]?.yaml ?? '';
const breadcrumb = [
  { label: t('flows.title'), href: consoleHref('/admin/console/flows', lang) },
  { label: detail?.definition.name ?? flowId },
];
---

<AdminConsoleLayout title={t('flows.detailTitle')} section="flows" breadcrumb={breadcrumb}>
  {!ready && (
    <AdminState tone="empty">{t('flows.managementUnavailable', { phase: consolePhaseFor('management') })}</AdminState>
  )}
  {ready && loadError && <AdminState tone="error">{t('flows.loadError')}</AdminState>}
  {ready && !loadError && !detail && <AdminState tone="empty">{t('flows.notFound', { id: flowId })}</AdminState>}
  {ready && detail && (
    <div class="flow-detail">
      <header class="detail-head">
        <h2>{detail.definition.name} <code>{detail.definition.id}</code></h2>
        {detail.definition.description && <p class="desc">{detail.definition.description}</p>}
        <div class="detail-actions">
          <a href={consoleHref(`/admin/console/flows/${flowId}/edit`, lang)} class="btn-edit">{t('flows.editYaml')}</a>
          <button
            type="button"
            class="btn-danger"
            id="archive-flow-btn"
            data-flow-id={flowId}
            data-confirm={t('flows.archiveConfirm', { id: flowId })}
          >{t('flows.archiveFlow')}</button>
        </div>
      </header>

      <section aria-label="Current definition">
        <h3>{t('flows.currentYaml', { version: detail.definition.version })}</h3>
        <pre class="yaml-block">{currentYaml || t('flows.noYaml')}</pre>
      </section>

      <section aria-label="Inputs">
        <h3>{t('flows.inputs')}</h3>
        {detail.definition.inputs.length === 0 ? (
          <p class="empty-note">{t('flows.noInputs')}</p>
        ) : (
          <ul class="inputs">
            {detail.definition.inputs.map((input) => (
              <li>
                <code>{input.name}</code> <span class="muted">{input.type}{input.required ? ` · ${t('flows.required')}` : ''}</span>
              </li>
            ))}
          </ul>
        )}
      </section>

      <section aria-label="Versions">
        <h3>{t('flows.versions')}</h3>
        <FlowVersionList versions={detail.versions} latestVersion={detail.definition.version} />
      </section>

      <section aria-label="Presets">
        <h3>{t('flows.presets')}</h3>
        <FlowPresetList presets={detail.presets} />
      </section>

      <section aria-label="Recent runs">
        <h3>{t('flows.recentRuns')}</h3>
        {detail.recentRuns.length === 0 ? (
          <p class="empty-note">{t('flows.noRuns')}</p>
        ) : (
          <RunsTable runs={detail.recentRuns} />
        )}
      </section>
    </div>
  )}
</AdminConsoleLayout>

<script define:vars={{ lang, archiveFailed: t('flows.archiveFailed') }}>
  const archiveButton = document.getElementById('archive-flow-btn');
  archiveButton?.addEventListener('click', async () => {
    const flowId = archiveButton.getAttribute('data-flow-id');
    const message = archiveButton.getAttribute('data-confirm') ?? '';
    if (!flowId || !window.confirm(message)) return;

    archiveButton.setAttribute('disabled', 'true');
    try {
      const response = await fetch(`/api/admin/flows/${encodeURIComponent(flowId)}`, {
        method: 'DELETE',
      });
      if (!response.ok) throw new Error(await response.text());
      window.location.href = lang === 'en' ? '/admin/console/flows?lang=en' : '/admin/console/flows';
    } catch (error) {
      window.alert(`${archiveFailed}: ${error instanceof Error ? error.message : String(error)}`);
      archiveButton.removeAttribute('disabled');
    }
  });
</script>

<style>
  .flow-detail {
    display: grid;
    gap: 1.5rem;
  }
  .detail-head h2 {
    font-size: 1.2rem;
  }
  .detail-head code {
    font-size: 0.82rem;
    color: var(--admin-text-soft);
  }
  .detail-head .desc {
    color: var(--admin-text-muted);
    margin-top: 0.25rem;
  }
  .detail-actions {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.5rem;
  }
  .btn-edit,
  .btn-danger {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    color: var(--admin-text);
    text-decoration: none;
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .btn-edit:hover {
    border-color: var(--admin-accent);
    color: var(--brand-900);
  }
  .btn-danger {
    color: #b91c1c;
    background: #fef2f2;
    border-color: #fecaca;
  }
  .btn-danger:hover {
    border-color: #ef4444;
    color: #991b1b;
  }
  .flow-detail h3 {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .yaml-block {
    margin: 0;
    padding: 0.75rem;
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    font-size: 0.8rem;
    overflow: auto;
    max-height: 420px;
  }
  .inputs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.3rem;
  }
  .inputs .muted,
  .empty-note {
    color: var(--admin-text-muted);
    font-size: 0.82rem;
  }
</style>
