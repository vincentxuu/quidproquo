---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleBootstrap } from '@/lib/agent-console/bootstrap';
import { consoleHref, createConsoleTranslator, getConsoleLang } from '@/lib/admin-console/i18n';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');
const PAGE_SIZE = 25;

const url = new URL(Astro.url);
const lang = getConsoleLang(url);
const t = createConsoleTranslator(lang);
const pageRaw = Number.parseInt(url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageRaw) && pageRaw > 0 ? pageRaw : 1;
const offset = (page - 1) * PAGE_SIZE;
const q = url.searchParams.get('q')?.trim() ?? '';

interface FlowRow {
  flow_id: string;
  display_name: string | null;
  current_version: number | null;
  category: string;
  updated_at: number | null;
}

interface CountRow {
  total: number;
}

let flows: FlowRow[] = [];
let loadError = false;
let totalCount = 0;

if (ready) {
  try {
    const env = getEnv();
    await ensureConsoleBootstrap(env);
    const db = env.DB;
    const where = q
      ? `WHERE fd.flow_id LIKE ? OR fd.display_name LIKE ? OR CAST(fd.current_version AS TEXT) LIKE ?`
      : '';

    if (q) {
      const like = `%${q}%`;
      const countResult = await db
        .prepare(
          `SELECT COUNT(*) as total
           FROM flow_definitions fd
           ${where}`,
        )
        .bind(like, like, like)
        .first<CountRow>();
      totalCount = countResult?.total ?? 0;

      const result = await db
        .prepare(
          `SELECT fd.flow_id,
                  fd.display_name,
                  fd.current_version,
                  fd.description,
                  fd.updated_at,
                  CASE
                    WHEN INSTR(fd.flow_id, '-') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '-') - 1)
                    WHEN INSTR(fd.flow_id, '_') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '_') - 1)
                    ELSE 'general'
                  END AS category
           FROM flow_definitions fd
           ${where}
           ORDER BY updated_at DESC
           LIMIT ? OFFSET ?`,
        )
        .bind(like, like, like, PAGE_SIZE, offset)
        .all<FlowRow>();
      flows = result.results ?? [];
    } else {
      const countResult = await db
        .prepare(`SELECT COUNT(*) as total FROM flow_definitions`)
        .first<CountRow>();
      totalCount = countResult?.total ?? 0;

      const result = await db
        .prepare(
          `SELECT fd.flow_id,
                  fd.display_name,
                  fd.current_version,
                  fd.description,
                  fd.updated_at,
                  CASE
                    WHEN INSTR(fd.flow_id, '-') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '-') - 1)
                    WHEN INSTR(fd.flow_id, '_') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '_') - 1)
                    ELSE 'general'
                  END AS category
           FROM flow_definitions fd
           ORDER BY fd.updated_at DESC
           LIMIT ? OFFSET ?`,
        )
        .bind(PAGE_SIZE, offset)
        .all<FlowRow>();
      flows = result.results ?? [];
    }
  } catch {
    loadError = true;
  }
}

function formatTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

function listHref(p: number): string {
  const u = new URL(Astro.url);
  if (p <= 1) {
    u.searchParams.delete('page');
  } else {
    u.searchParams.set('page', String(p));
  }
  return u.pathname + u.search;
}

function categoryLabel(category: string): string {
  if (!category) return 'general';
  return category.replace(/-/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
}
---

<AdminConsoleLayout title={t('flows.title')} section="flows">
  {!ready && (
    <AdminState tone="empty">{t('flows.managementUnavailable', { phase: consolePhaseFor('management') })}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">{t('flows.loadError')}</AdminState>
  )}
  {ready && !loadError && (
    <AdminPanel title={t('flows.library')} eyebrow={t('flows.libraryEyebrow')}>
      <form class="toolbar" method="GET" action={consoleHref('/admin/console/flows', lang)}>
        {lang === 'en' && <input type="hidden" name="lang" value="en" />}
        <label for="q" class="search-label">{t('flows.searchLabel')}</label>
        <input
          id="q"
          name="q"
          type="search"
          value={q}
          class="search-input"
          placeholder={t('flows.searchPlaceholder')}
        />
        <button type="submit" class="btn-secondary">{t('common.search')}</button>
        {q && <a href={consoleHref('/admin/console/flows', lang)} class="btn-clear">{t('common.clear')}</a>}
        <a href={consoleHref('/admin/console/flows/new', lang)} class="btn-primary">{t('flows.newFlow')}</a>
      </form>
    </AdminPanel>
  )}
  {ready && !loadError && flows.length === 0 && (
    <AdminState tone="empty">
      {q ? t('flows.emptySearch', { q }) : t('flows.empty')}
    </AdminState>
  )}
  {ready && !loadError && flows.length > 0 && (
    <AdminPanel title={t('flows.library')}>
      <AdminTable minWidth="640px" flush>
        <thead>
          <tr>
            <th>{t('flows.flowId')}</th>
            <th>{t('common.name')}</th>
            <th>{t('flows.category')}</th>
            <th>{t('common.version')}</th>
            <th>{t('common.updatedAt')}</th>
            <th>{t('common.actions')}</th>
          </tr>
        </thead>
        <tbody>
          {flows.map((flow) => (
            <tr data-flow-row={flow.flow_id}>
              <td class="mono">
                <a href={consoleHref(`/admin/console/flows/${flow.flow_id}`, lang)} class="link flow-id">
                  {flow.flow_id}
                </a>
              </td>
              <td class="flow-name">{flow.display_name ?? flow.flow_id}</td>
              <td class="category">{categoryLabel(flow.category)}</td>
              <td class="mono">{flow.current_version ?? '—'}</td>
              <td class="mono">{formatTs(flow.updated_at)}</td>
              <td>
                <div class="row-actions">
                  <a href={consoleHref(`/admin/console/flows/${flow.flow_id}`, lang)} class="action-link">{t('common.view')}</a>
                  <a href={consoleHref(`/admin/console/flows/${flow.flow_id}/edit`, lang)} class="action-link">{t('common.edit')}</a>
                  <button
                    type="button"
                    class="action-link danger"
                    data-delete-flow={flow.flow_id}
                    data-confirm={t('flows.archiveConfirm', { id: flow.flow_id })}
                  >{t('common.archive')}</button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </AdminTable>

      {totalPages > 1 && (
        <div class="pagination">
          {page > 1 ? <a href={listHref(1)} class="page-btn">{t('common.firstPage')}</a> : <span class="page-btn disabled">{t('common.firstPage')}</span>}
          {page > 1 ? <a href={listHref(page - 1)} class="page-btn">{t('common.previousPage')}</a> : <span class="page-btn disabled">{t('common.previousPage')}</span>}
          <span class="page-info">{t('common.pageOf', { page, total: totalPages })}</span>
          {page < totalPages ? <a href={listHref(page + 1)} class="page-btn">{t('common.nextPage')}</a> : <span class="page-btn disabled">{t('common.nextPage')}</span>}
        </div>
      )}
    </AdminPanel>
  )}
</AdminConsoleLayout>

<script define:vars={{ archiveFailed: t('flows.archiveFailed') }}>
  document.querySelectorAll('[data-delete-flow]').forEach((button) => {
    button.addEventListener('click', async () => {
      const flowId = button.getAttribute('data-delete-flow');
      const message = button.getAttribute('data-confirm') ?? '';
      if (!flowId || !window.confirm(message)) return;

      button.setAttribute('disabled', 'true');
      try {
        const response = await fetch(`/api/admin/flows/${encodeURIComponent(flowId)}`, {
          method: 'DELETE',
        });
        if (!response.ok) throw new Error(await response.text());
        const row = document.querySelector(`[data-flow-row="${CSS.escape(flowId)}"]`);
        row?.remove();
      } catch (error) {
        window.alert(`${archiveFailed}: ${error instanceof Error ? error.message : String(error)}`);
        button.removeAttribute('disabled');
      }
    });
  });
</script>

<style>
  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .flow-name {
    font-size: 0.9em;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category {
    font-size: 0.84em;
    color: var(--admin-text-muted);
    text-transform: capitalize;
  }

  .link {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
  }

  .link:hover {
    text-decoration: underline;
  }

  .toolbar {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .search-label {
    color: var(--admin-text-muted);
    font-size: 0.85rem;
  }

  .search-input {
    min-width: 240px;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    padding: 0.42rem 0.65rem;
    color: var(--admin-text);
  }

  .btn-clear,
  .btn-secondary,
  .btn-primary,
  .page-btn {
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    padding: 0.35rem 0.7rem;
    text-decoration: none;
    color: var(--admin-text);
    background: var(--admin-surface);
    font-size: 0.8rem;
    line-height: 1.2;
    cursor: pointer;
  }

  .btn-primary {
    border-color: var(--brand-900);
    background: var(--brand-900);
    color: #fff;
  }

  .btn-clear:hover,
  .btn-secondary:hover,
  .page-btn:hover:not(.disabled) {
    background: var(--admin-muted);
  }

  .row-actions {
    display: flex;
    gap: 0.45rem;
  }

  .action-link {
    border: 0;
    background: transparent;
    padding: 0;
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .action-link:hover {
    text-decoration: underline;
  }

  .action-link.danger {
    color: #b91c1c;
  }

  .pagination {
    margin-top: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .page-info {
    color: var(--admin-text-muted);
    font-size: 0.83rem;
  }

  .disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .flow-id {
    font-weight: 700;
  }
</style>
