---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');
const PAGE_SIZE = 25;

const url = new URL(Astro.url);
const pageRaw = Number.parseInt(url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(pageRaw) && pageRaw > 0 ? pageRaw : 1;
const offset = (page - 1) * PAGE_SIZE;
const q = url.searchParams.get('q')?.trim() ?? '';

interface FlowRow {
  flow_id: string;
  display_name: string | null;
  current_version: number | null;
  category: string;
  updated_at: number | null;
}

interface CountRow {
  total: number;
}

let flows: FlowRow[] = [];
let loadError = false;
let totalCount = 0;

if (ready) {
  try {
    const db = getEnv().DB;
    const where = q
      ? `WHERE fd.flow_id LIKE ? OR fd.display_name LIKE ? OR CAST(fd.current_version AS TEXT) LIKE ?`
      : '';

    if (q) {
      const like = `%${q}%`;
      const countResult = await db
        .prepare(
          `SELECT COUNT(*) as total
           FROM flow_definitions fd
           ${where}`,
        )
        .bind(like, like, like)
        .first<CountRow>();
      totalCount = countResult?.total ?? 0;

      const result = await db
        .prepare(
          `SELECT fd.flow_id,
                  fd.display_name,
                  fd.current_version,
                  fd.description,
                  fd.updated_at,
                  CASE
                    WHEN INSTR(fd.flow_id, '-') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '-') - 1)
                    WHEN INSTR(fd.flow_id, '_') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '_') - 1)
                    ELSE 'general'
                  END AS category
           FROM flow_definitions fd
           ${where}
           ORDER BY updated_at DESC
           LIMIT ? OFFSET ?`,
        )
        .bind(like, like, like, PAGE_SIZE, offset)
        .all<FlowRow>();
      flows = result.results ?? [];
    } else {
      const countResult = await db
        .prepare(`SELECT COUNT(*) as total FROM flow_definitions`)
        .first<CountRow>();
      totalCount = countResult?.total ?? 0;

      const result = await db
        .prepare(
          `SELECT fd.flow_id,
                  fd.display_name,
                  fd.current_version,
                  fd.description,
                  fd.updated_at,
                  CASE
                    WHEN INSTR(fd.flow_id, '-') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '-') - 1)
                    WHEN INSTR(fd.flow_id, '_') > 0 THEN SUBSTR(fd.flow_id, 1, INSTR(fd.flow_id, '_') - 1)
                    ELSE 'general'
                  END AS category
           FROM flow_definitions fd
           ORDER BY fd.updated_at DESC
           LIMIT ? OFFSET ?`,
        )
        .bind(PAGE_SIZE, offset)
        .all<FlowRow>();
      flows = result.results ?? [];
    }
  } catch {
    loadError = true;
  }
}

function formatTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

function listHref(p: number): string {
  const u = new URL(Astro.url);
  if (p <= 1) {
    u.searchParams.delete('page');
  } else {
    u.searchParams.set('page', String(p));
  }
  return u.pathname + u.search;
}

function categoryLabel(category: string): string {
  if (!category) return 'general';
  return category.replace(/-/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
}
---

<AdminConsoleLayout title="工作流程" section="flows">
  {!ready && (
    <AdminState tone="empty">{`Flows management ships in ${consolePhaseFor('management')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">無法載入工作流程。</AdminState>
  )}
  {ready && !loadError && (
    <AdminPanel title="工作流程定義" eyebrow="搜尋並管理已登錄的工作流程定義">
      <form class="toolbar" method="GET" action="/admin/console/flows">
        <label for="q" class="search-label">搜尋工作流程</label>
        <input
          id="q"
          name="q"
          type="search"
          value={q}
          class="search-input"
          placeholder="依 id、名稱、版本搜尋"
        />
        <button type="submit" class="btn-secondary">搜尋</button>
        {q && <a href="/admin/console/flows" class="btn-clear">清除</a>}
        <a href="/admin/console/flows/new" class="btn-secondary">新增工作流程</a>
      </form>
    </AdminPanel>
  )}
  {ready && !loadError && flows.length === 0 && (
    <AdminState tone="empty">
      {q ? `沒有符合「${q}」的工作流程定義。` : '尚無已登錄的工作流程定義。'}
    </AdminState>
  )}
  {ready && !loadError && flows.length > 0 && (
    <AdminPanel title="工作流程定義">
      <AdminTable minWidth="640px" flush>
        <thead>
          <tr>
            <th>工作流程 ID</th>
            <th>名稱</th>
            <th>類別</th>
            <th>版本</th>
            <th>更新時間</th>
            <th>操作</th>
          </tr>
        </thead>
        <tbody>
          {flows.map((flow) => (
            <tr>
              <td class="mono">
                <a href={`/admin/console/flows/${flow.flow_id}`} class="link flow-id">
                  {flow.flow_id}
                </a>
              </td>
              <td class="flow-name">{flow.display_name ?? flow.flow_id}</td>
              <td class="category">{categoryLabel(flow.category)}</td>
              <td class="mono">{flow.current_version ?? '—'}</td>
              <td class="mono">{formatTs(flow.updated_at)}</td>
              <td>
                <div class="row-actions">
                  <a href={`/admin/console/flows/${flow.flow_id}`} class="action-link">檢視</a>
                  <a href={`/admin/console/flows/${flow.flow_id}/edit`} class="action-link">編輯</a>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </AdminTable>

      {totalPages > 1 && (
        <div class="pagination">
          {page > 1 ? <a href={listHref(1)} class="page-btn">第一頁</a> : <span class="page-btn disabled">第一頁</span>}
          {page > 1 ? <a href={listHref(page - 1)} class="page-btn">上一頁</a> : <span class="page-btn disabled">上一頁</span>}
          <span class="page-info">第 {page} / {totalPages} 頁</span>
          {page < totalPages ? <a href={listHref(page + 1)} class="page-btn">下一頁</a> : <span class="page-btn disabled">下一頁</span>}
        </div>
      )}
    </AdminPanel>
  )}
</AdminConsoleLayout>

<style>
  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .flow-name {
    font-size: 0.9em;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .category {
    font-size: 0.84em;
    color: var(--admin-text-muted);
    text-transform: capitalize;
  }

  .link {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
  }

  .link:hover {
    text-decoration: underline;
  }

  .toolbar {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }

  .search-label {
    color: var(--admin-text-muted);
    font-size: 0.85rem;
  }

  .search-input {
    min-width: 240px;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: var(--admin-surface);
    padding: 0.42rem 0.65rem;
    color: var(--admin-text);
  }

  .btn-clear,
  .btn-secondary,
  .page-btn {
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    padding: 0.35rem 0.7rem;
    text-decoration: none;
    color: var(--admin-text);
    background: var(--admin-surface);
    font-size: 0.8rem;
    line-height: 1.2;
    cursor: pointer;
  }

  .btn-clear:hover,
  .btn-secondary:hover,
  .page-btn:hover:not(.disabled) {
    background: var(--admin-muted);
  }

  .row-actions {
    display: flex;
    gap: 0.45rem;
  }

  .action-link {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
    font-size: 0.8rem;
  }

  .action-link:hover {
    text-decoration: underline;
  }

  .pagination {
    margin-top: 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .page-info {
    color: var(--admin-text-muted);
    font-size: 0.83rem;
  }

  .disabled {
    opacity: 0.45;
    cursor: not-allowed;
    pointer-events: none;
  }

  .flow-id {
    font-weight: 700;
  }
</style>
