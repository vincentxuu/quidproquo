---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');

interface FlowRow {
  flow_id: string;
  display_name: string | null;
  current_version: number | null;
  description: string | null;
  updated_at: number | null;
}

let flows: FlowRow[] = [];
let loadError = false;

if (ready) {
  try {
    const db = getEnv().DB;
    const result = await db
      .prepare(
        `SELECT flow_id, display_name, current_version, description, updated_at
         FROM flow_definitions
         ORDER BY display_name ASC`,
      )
      .all<FlowRow>();
    flows = result.results ?? [];
  } catch {
    loadError = true;
  }
}

function formatTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}
---

<AdminConsoleLayout title="Flows" section="flows">
  {!ready && (
    <AdminState tone="empty">{`Flows management ships in ${consolePhaseFor('management')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">Could not load flows.</AdminState>
  )}
  {ready && !loadError && flows.length === 0 && (
    <AdminState tone="empty">No flow definitions registered yet.</AdminState>
  )}
  {ready && !loadError && flows.length > 0 && (
    <AdminPanel title="Flow Definitions">
      <AdminTable minWidth="640px" flush>
        <thead>
          <tr>
            <th>Flow ID</th>
            <th>Name</th>
            <th>Version</th>
            <th>Description</th>
            <th>Last Updated</th>
          </tr>
        </thead>
        <tbody>
          {flows.map((flow) => (
            <tr>
              <td class="mono">
                <a href={`/admin/console/flows/${flow.flow_id}`} class="link">
                  {flow.flow_id}
                </a>
              </td>
              <td class="flow-name">{flow.display_name ?? flow.flow_id}</td>
              <td class="mono">{flow.current_version ?? '—'}</td>
              <td class="desc">{flow.description ?? '—'}</td>
              <td class="mono">{formatTs(flow.updated_at)}</td>
            </tr>
          ))}
        </tbody>
      </AdminTable>
    </AdminPanel>
  )}
</AdminConsoleLayout>

<style>
  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .flow-name {
    font-size: 0.9em;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .desc {
    font-size: 0.85em;
    color: var(--admin-text-muted);
    max-width: 260px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .link {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
  }

  .link:hover {
    text-decoration: underline;
  }
</style>
