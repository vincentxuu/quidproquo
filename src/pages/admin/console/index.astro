---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import ConsoleFlowCard from '@/components/admin/ConsoleFlowCard.astro';
import { getEnv } from '@/lib/config/env';
import { loadFlowCards, type FlowCardData } from '@/lib/agent-console/flow-selector';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from './_guard';
import { createBackends } from '@/lib/agent-os/storage';
import type { ApprovalRecord } from '@/lib/agent-os/storage';
import { PendingApprovalsBannerIsland } from '@/components/admin/console/BulkApprovalModal';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('flowSelector');

const url = new URL(Astro.url);
const selectedCategory = url.searchParams.get('category')?.trim() ?? '';
const selectedStatus = url.searchParams.get('status')?.trim() ?? '';
const selectedCost = url.searchParams.get('cost')?.trim() ?? '';

const urlFor = (patch: Record<string, string>) => {
  const next = new URL(url);
  for (const [k, v] of Object.entries(patch)) {
    if (v) {
      next.searchParams.set(k, v);
    } else {
      next.searchParams.delete(k);
    }
  }
  return next.pathname + next.search;
};

const filterCategories = ['research', 'content', 'system', 'analysis', 'general'];
const filterStatuses = ['published', 'draft', 'archived'];
const filterCosts = [
  { value: 'lt_0_10', label: '<$0.10' },
  { value: '0_10_1', label: '$0.10 – $1.00' },
  { value: 'gt_1', label: '>$1.00' },
];

let cards: FlowCardData[] = [];
let loadError = false;
if (ready) {
  try {
    cards = await loadFlowCards(getEnv().DB, {
      category: selectedCategory,
      status: selectedStatus,
      cost: selectedCost,
    });
  } catch {
    loadError = true;
  }
}

// Fetch pending approvals at SSR time — always shown regardless of flowSelector flag
let pendingApprovals: ApprovalRecord[] = [];
try {
  const backends = createBackends(getEnv());
  pendingApprovals = await backends.approvals.listByStatus('pending');
} catch {
  // Non-fatal: banner simply won't render if D1 is unavailable
}
---

<AdminConsoleLayout title="Flow Console" section="flow-selector">
  <!-- Cost rollup: tokens_in/tokens_out/cost_usd aggregated from agent_tool_calls -->
  <!-- Updated live via SSE when a run is active — see runs/[id].astro -->
  {pendingApprovals.length > 0 && (
    <div class="approvals-banner" role="region" aria-label="Pending approvals">
      <div class="approvals-banner__body">
        <span class="approvals-banner__count">
          {pendingApprovals.length} pending approval{pendingApprovals.length !== 1 ? 's' : ''} require attention
        </span>
        <ul class="approvals-banner__list">
          {pendingApprovals.map((a) => (
            <li>
              <a href={`/admin/console/runs/${a.runId}`}>
                {a.reason || a.approvalId}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div class="approvals-banner__actions">
        <PendingApprovalsBannerIsland
          client:only="react"
          approvals={pendingApprovals.map((a) => ({
            approvalId: a.approvalId,
            runId: a.runId,
            reason: a.reason,
            stepId: undefined,
          }))}
        />
      </div>
    </div>
  )}
  {!ready && (
    <AdminState tone="empty">{`Flow selector ships in ${consolePhaseFor('flowSelector')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">Could not load flows.</AdminState>
  )}
  {ready && !loadError && cards.length === 0 && (
    <AdminState tone="empty">No flows are registered yet.</AdminState>
  )}
  {ready && !loadError && cards.length > 0 && (
  <section class="flow-grid" aria-label="Available flows">
      {cards.map((card) => <ConsoleFlowCard card={card} />)}
    </section>
  )}
  <section class="flow-filter-bar">
    <form class="filter-form" method="GET" action="/admin/console">
      <label for="category" class="filter-label">Category</label>
      <select id="category" name="category">
        <option value="" selected={selectedCategory === ''}>All</option>
        {filterCategories.map((value) => (
          <option value={value} selected={selectedCategory === value}>
            {value}
          </option>
        ))}
      </select>

      <label for="status" class="filter-label">Status</label>
      <select id="status" name="status">
        <option value="" selected={selectedStatus === ''}>All</option>
        {filterStatuses.map((value) => (
          <option value={value} selected={selectedStatus === value}>
            {value}
          </option>
        ))}
      </select>

      <label for="cost" class="filter-label">Cost</label>
      <select id="cost" name="cost">
        <option value="" selected={selectedCost === ''}>All</option>
        {filterCosts.map((item) => (
          <option value={item.value} selected={selectedCost === item.value}>
            {item.label}
          </option>
        ))}
      </select>

      <button type="submit" class="btn-secondary">Apply</button>
      {(selectedCategory || selectedStatus || selectedCost) && (
        <a href="/admin/console" class="btn-clear">Clear</a>
      )}
    </form>
  </section>
</AdminConsoleLayout>

<style>
  .flow-filter-bar {
    margin-top: 0.75rem;
    margin-bottom: 1rem;
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .filter-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .filter-label {
    font-size: 0.8rem;
    color: var(--admin-text-muted, #64748b);
  }

  .filter-form select {
    border: 1px solid var(--admin-border, #e2e8f0);
    border-radius: var(--admin-radius, 6px);
    background: var(--admin-surface, #fff);
    padding: 0.35rem 0.6rem;
    min-width: 120px;
  }

  .btn-clear,
  .btn-secondary {
    border: 1px solid var(--admin-border, #e2e8f0);
    background: var(--admin-surface, #fff);
    padding: 0.38rem 0.75rem;
    border-radius: var(--admin-radius, 6px);
    color: var(--admin-text, #1e293b);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.82rem;
  }

  .btn-secondary:hover,
  .btn-clear:hover {
    background: var(--admin-muted, #f1f5f9);
  }

  .approvals-banner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 0.875rem 1rem;
    border-radius: 0.375rem;
    background: var(--color-warning-bg, #fefce8);
    border: 1px solid var(--color-warning-border, #fde047);
    color: var(--color-warning-text, #713f12);
  }

  .approvals-banner__body {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 0;
  }

  .approvals-banner__count {
    font-weight: 600;
    font-size: 0.9375rem;
  }

  .approvals-banner__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.75rem;
    font-size: 0.8125rem;
  }

  .approvals-banner__list a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .approvals-banner__actions {
    flex-shrink: 0;
    display: flex;
    align-items: center;
  }
</style>
