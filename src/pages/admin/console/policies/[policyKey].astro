---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import PolicyAssignmentList from '@/components/admin/console/PolicyAssignmentList.astro';
import { FlowAssignIsland } from '@/components/admin/console/FlowAssignModal';
import { fetchPolicyDetail } from '@/lib/agent-console/management';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('management');
const policyKey = Astro.params.policyKey ?? '';

const result = ready
  ? await fetchPolicyDetail(Astro.request, policyKey)
  : { ok: false, detail: null, assignments: [] };

const breadcrumb = [
  { label: 'Policies', href: '/admin/console/policies' },
  { label: result.detail?.label ?? policyKey },
];
---

<AdminConsoleLayout title="Policy Detail" section="policies" breadcrumb={breadcrumb}>
  {!ready && (
    <AdminState tone="empty">{`Policy management ships in ${consolePhaseFor('management')}.`}</AdminState>
  )}
  {ready && !result.ok && (
    <AdminState tone="error">Could not load policy. Ensure the agent-policy feature is enabled.</AdminState>
  )}
  {ready && result.ok && !result.detail && (
    <AdminState tone="empty">{`Policy "${policyKey}" not found.`}</AdminState>
  )}
  {ready && result.detail && (
    <div class="policy-detail">
      <header class="detail-head">
        <h2>{result.detail.label} <code>{result.detail.policyKey}</code></h2>
        <p class="meta">
          <span class="category-chip">{result.detail.category}</span>
          <span>v{result.detail.version}</span>
        </p>
      </header>

      <section aria-label="Definition">
        <h3>Definition</h3>
        <pre class="body-block">{result.detail.body}</pre>
      </section>

      <section aria-label="Assignments">
        <div class="section-head">
          <h3>Assignments</h3>
          <FlowAssignIsland client:only="react" policyId={result.detail.policyKey} />
        </div>
        <PolicyAssignmentList assignments={result.assignments} />
      </section>

      <section aria-label="Recent decisions">
        <h3>Recent decisions</h3>
        <p class="empty-note">Decision history requires the agent-policy violations read API (not yet available).</p>
      </section>
    </div>
  )}
</AdminConsoleLayout>

<style>
  .policy-detail {
    display: grid;
    gap: 1.5rem;
  }
  .detail-head h2 {
    font-size: 1.2rem;
  }
  .detail-head code {
    font-size: 0.82rem;
    color: var(--admin-text-soft);
  }
  .detail-head .meta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
    margin-top: 0.3rem;
    color: var(--admin-text-muted);
    font-size: 0.85rem;
  }
  .category-chip {
    padding: 0.05rem 0.5rem;
    border: 1px solid var(--admin-border);
    border-radius: 999px;
    font-size: 0.74rem;
    text-transform: capitalize;
  }
  .section-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }
  .section-head h3 {
    margin: 0;
  }
  .policy-detail h3 {
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .body-block {
    margin: 0;
    padding: 0.75rem;
    background: var(--admin-bg);
    border: 1px solid var(--admin-border);
    border-radius: 8px;
    font-size: 0.8rem;
    overflow: auto;
    max-height: 420px;
  }
  .empty-note {
    color: var(--admin-text-muted);
    font-size: 0.85rem;
  }
</style>
