---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { PERMISSION_PRESETS, formatGrant } from '@/lib/admin-console/rbac/presets';
import { ensureConsoleUmbrella, isPageEnabled } from '../../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('rbac');
const roleId = Astro.params.id ?? '';
const rbacSuccess = Astro.url.searchParams.get('rbac_success');
const rbacError = Astro.url.searchParams.get('rbac_error');

const breadcrumb = [
  { label: '權限管理', href: '/admin/console/rbac?tab=roles' },
  { label: `角色 ${roleId}` },
];

interface RoleRow {
  role_id: number;
  name: string;
  description: string | null;
}

interface PermissionRow {
  permission_id: number;
  resource_kind: string;
  action: string;
  resource_id: string | null;
}

interface AssignedUserRow {
  user_id: number;
  email: string;
  disabled_at: number | null;
  assigned_at: number | null;
}

interface UserOptionRow {
  user_id: number;
  email: string;
  disabled_at: number | null;
}

interface RoleNameRow {
  name: string;
}

const RESOURCE_KINDS = ['flow', 'policy', 'provider', 'run', 'approval', 'artifact', 'cost', 'rbac'] as const;
const ACTIONS = ['view', 'invoke', 'edit', 'delete', 'approve', 'reject', 'cancel', 'export'] as const;
const RESERVED_ROLES = ['admin', 'operator', 'approver', 'viewer'];
let role: RoleRow | null = null;
let permissions: PermissionRow[] = [];
let assignedUsers: AssignedUserRow[] = [];
let unassignedUsers: UserOptionRow[] = [];
let otherRoleNames: string[] = [];
let loadError = false;

if (ready && roleId) {
  try {
    const db = getEnv().DB;

    const [roleResult, permResult, assignedResult, unassignedResult, otherRolesResult] = await Promise.all([
      db.prepare(`
        SELECT role_id, name, description
        FROM console_roles
        WHERE role_id = ?
      `).bind(roleId).first<RoleRow>(),

      db.prepare(`
        SELECT permission_id, resource_kind, action, resource_id
        FROM console_permissions
        WHERE role_id = ?
        ORDER BY resource_kind, action
      `).bind(roleId).all<PermissionRow>(),

      db.prepare(`
        SELECT u.user_id, u.email, u.disabled_at, ur.assigned_at
        FROM console_user_roles ur
        JOIN console_users u ON u.user_id = ur.user_id
        WHERE ur.role_id = ?
        ORDER BY u.email
      `).bind(roleId).all<AssignedUserRow>(),

      db.prepare(`
        SELECT u.user_id, u.email, u.disabled_at
        FROM console_users u
        WHERE NOT EXISTS (
          SELECT 1
          FROM console_user_roles ur
          WHERE ur.user_id = u.user_id
            AND ur.role_id = ?
        )
        ORDER BY u.disabled_at IS NOT NULL, u.email
      `).bind(roleId).all<UserOptionRow>(),

      db.prepare(`
        SELECT name
        FROM console_roles
        WHERE role_id != ?
        ORDER BY name
      `).bind(roleId).all<RoleNameRow>(),
    ]);

    role = roleResult ?? null;
    permissions = permResult.results ?? [];
    assignedUsers = assignedResult.results ?? [];
    unassignedUsers = unassignedResult.results ?? [];
    otherRoleNames = (otherRolesResult.results ?? []).map((row) => row.name);
  } catch {
    loadError = true;
  }
}

const isReservedRole = role ? RESERVED_ROLES.includes(role.name) : false;

function formatTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

const permissionGrantsJson = JSON.stringify(
  permissions.map((permission) => ({
    id: permission.permission_id,
    kind: permission.resource_kind,
    action: permission.action,
    resourceId: permission.resource_id ?? '',
  })),
);
const otherRoleNamesJson = JSON.stringify(otherRoleNames);
const unassignedUsersJson = JSON.stringify(
  unassignedUsers.map((user) => ({
    id: String(user.user_id),
    email: user.email,
    disabled: Boolean(user.disabled_at),
  })),
);
---

<AdminConsoleLayout title={role ? `角色：${role.name}` : `角色 ${roleId}`} section="rbac" breadcrumb={breadcrumb}>
  {!ready && (
    <AdminState tone="empty">權限管理功能尚未啟用。</AdminState>
  )}
  {ready && !roleId && (
    <AdminState tone="error">未指定角色 ID。</AdminState>
  )}
  {ready && roleId && loadError && (
    <AdminState tone="error">無法載入角色資料。</AdminState>
  )}
  {ready && roleId && !loadError && !role && (
    <AdminState tone="error">找不到該角色。</AdminState>
  )}
  {ready && roleId && !loadError && role && (
    <div class="role-detail">
      {(rbacSuccess || rbacError) && (
        <p
          class:list={['notice', { success: Boolean(rbacSuccess), error: Boolean(rbacError) }]}
          role="status"
        >
          {rbacSuccess ?? rbacError}
        </p>
      )}

      <AdminPanel title="角色資訊">
        <div class="info-grid">
          <div class="info-row">
            <span class="info-label">角色 ID</span>
            <code>{role.role_id}</code>
          </div>
          <div class="info-row">
            <span class="info-label">名稱</span>
            <code>{role.name}</code>
          </div>
          <div class="info-row">
            <span class="info-label">描述</span>
            <span class="muted">{role.description ?? '—'}</span>
          </div>
        </div>
      </AdminPanel>

      <AdminPanel title="已指派使用者" eyebrow={`共 ${assignedUsers.length} 位使用者擁有此角色`}>
        <form
          method="POST"
          action={`/api/admin/console/rbac/roles/${roleId}/users/add`}
          class="assign-user-form"
          data-confirm={`確定要將選取的使用者加入角色 ${role.name}？`}
          data-assign-user-form
          data-role-name={role.name}
          data-unassigned-users={unassignedUsersJson}
        >
          <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
          <label for="assign-user" class="form-label">加入既有使用者</label>
          <select id="assign-user" name="user_id" class="form-select" disabled={unassignedUsers.length === 0} required>
            <option value="">選擇使用者</option>
            {unassignedUsers.map((user) => (
              <option value={user.user_id}>
                {user.email}{user.disabled_at ? ' (已停用)' : ''}
              </option>
            ))}
          </select>
          <button type="submit" class="btn-primary" disabled={unassignedUsers.length === 0}>加入角色</button>
          <p class="operation-preview" data-assign-user-preview role="status" aria-live="polite">
            選擇使用者後會顯示角色指派預覽。
          </p>
          {unassignedUsers.length === 0 && (
            <span class="muted">所有使用者都已擁有此角色。</span>
          )}
        </form>
        {assignedUsers.length === 0 ? (
          <AdminState tone="empty">目前沒有使用者被指派此角色。</AdminState>
        ) : (
          <AdminTable minWidth="560px" flush>
            <thead>
              <tr>
                <th>電子郵件</th>
                <th>狀態</th>
                <th>指派時間</th>
                <th>管理</th>
              </tr>
            </thead>
            <tbody>
              {assignedUsers.map((user) => (
                <tr>
                  <td>
                    <a href={`/admin/console/rbac/users/${user.user_id}`} class="link">
                      {user.email}
                    </a>
                  </td>
                  <td>
                    {user.disabled_at ? (
                      <span class="badge disabled">停用</span>
                    ) : (
                      <span class="badge active">啟用中</span>
                    )}
                  </td>
                  <td class="mono">{formatTs(user.assigned_at)}</td>
                  <td>
                    <form
                      method="POST"
                      action={`/api/admin/console/rbac/roles/${roleId}/users/${user.user_id}/remove`}
                      class="inline-form"
                      data-confirm={`確定要從 ${user.email} 移除角色 ${role.name}？`}
                      data-remove-role-form
                    >
                      <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
                      <button type="submit" class="btn-danger">移除此角色</button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </AdminTable>
        )}
      </AdminPanel>

      <AdminPanel
        title="編輯角色"
        eyebrow={isReservedRole ? '內建角色可更新描述，但不可改名或刪除' : '更新角色名稱與描述'}
      >
        <form
          method="POST"
          action={`/api/admin/console/rbac/roles/${roleId}`}
          class="edit-role-form"
          data-role-edit-form
          data-initial-name={role.name}
          data-initial-description={role.description ?? ''}
          data-other-role-names={otherRoleNamesJson}
        >
          <input type="hidden" name="action" value="update" />
          <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
          <div class="form-row">
            <label for="role_name" class="form-label">名稱</label>
            <input
              id="role_name"
              type="text"
              name="name"
              class="form-input"
              value={role.name}
              pattern="[a-z][a-z0-9_-]{1,63}"
              autocomplete="off"
              readonly={isReservedRole}
              required
            />
          </div>
          <div class="form-row">
            <label for="role_description" class="form-label">描述</label>
            <textarea
              id="role_description"
              name="description"
              class="form-input"
              rows="3"
              maxlength="500"
            >{role.description ?? ''}</textarea>
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-primary">儲存角色</button>
          </div>
          <p class="operation-preview" data-role-edit-preview role="status" aria-live="polite">
            角色資料尚未變更。
          </p>
        </form>
      </AdminPanel>

      <AdminPanel title="權限範本" eyebrow="一鍵套用常見權限組合，已存在的權限會略過">
        <div class="preset-grid">
          {PERMISSION_PRESETS.map((preset) => (
            <form
              method="POST"
              action={`/api/admin/console/rbac/roles/${roleId}/permissions/preset`}
              class="preset-card"
              data-confirm={`確定要將「${preset.label}」權限範本套用到角色 ${role.name}？已存在的權限會略過。`}
              data-preset-form
            >
              <input type="hidden" name="preset" value={preset.id} />
              <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
              <strong>{preset.label}</strong>
              <span>{preset.description}</span>
              <span class="preset-count">{preset.grants.length} 項權限</span>
              <ul class="preset-grants" aria-label={`${preset.label} 權限明細`}>
                {preset.grants.map((grant) => (
                  <li>{formatGrant(grant)}</li>
                ))}
              </ul>
              <button type="submit" class="btn-secondary">套用範本</button>
            </form>
          ))}
        </div>
      </AdminPanel>

      <AdminPanel title="權限" eyebrow={`共 ${permissions.length} 項權限`}>
        {permissions.length === 0 ? (
          <AdminState tone="empty">此角色尚未指派任何權限。</AdminState>
        ) : (
          <AdminTable minWidth="480px" flush>
            <thead>
              <tr>
                <th>資源類型</th>
                <th>操作</th>
                <th>Resource ID</th>
                <th>管理</th>
              </tr>
            </thead>
            <tbody>
              {permissions.map((p) => (
                <tr>
                  <td colspan="3">
                    <form
                      method="POST"
                      action={`/api/admin/console/rbac/roles/${roleId}/permissions/${p.permission_id}`}
                      class="permission-row-form"
                      data-permission-row-form
                      data-permission-id={p.permission_id}
                      data-existing-permissions={permissionGrantsJson}
                    >
                      <input type="hidden" name="form_action" value="update" />
                      <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
                      <label class="sr-only" for={`perm-kind-${p.permission_id}`}>資源類型</label>
                      <select
                        id={`perm-kind-${p.permission_id}`}
                        name="resource_kind"
                        class="form-select compact"
                      >
                        {RESOURCE_KINDS.map((k) => (
                          <option value={k} selected={k === p.resource_kind}>{k}</option>
                        ))}
                      </select>
                      <label class="sr-only" for={`perm-action-${p.permission_id}`}>操作</label>
                      <select
                        id={`perm-action-${p.permission_id}`}
                        name="permission_action"
                        class="form-select compact"
                      >
                        {ACTIONS.map((a) => (
                          <option value={a} selected={a === p.action}>{a}</option>
                        ))}
                      </select>
                      <label class="sr-only" for={`perm-resource-${p.permission_id}`}>Resource ID</label>
                      <input
                        id={`perm-resource-${p.permission_id}`}
                        name="resource_id"
                        type="text"
                        class="form-input compact"
                        value={p.resource_id ?? ''}
                        placeholder="*"
                        autocomplete="off"
                      />
                      <button type="submit" class="btn-primary compact">儲存</button>
                      <p class="permission-preview" data-permission-preview role="status" aria-live="polite"></p>
                    </form>
                  </td>
                  <td>
                    <form
                      method="POST"
                      action={`/api/admin/console/rbac/roles/${roleId}/permissions/${p.permission_id}`}
                      class="inline-form"
                      data-confirm={`確定移除 ${p.resource_kind} ${p.action} 權限？`}
                    >
                      <input type="hidden" name="form_action" value="delete" />
                      <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
                      <button
                        type="submit"
                        class="btn-danger"
                        aria-label={`移除 ${p.resource_kind} ${p.action} 權限`}
                      >
                        移除
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </AdminTable>
        )}
      </AdminPanel>

      <AdminPanel title="新增權限" eyebrow="授予此角色新的權限">
        <form
          method="POST"
          action={`/api/admin/console/rbac/roles/${roleId}/permissions`}
          class="add-perm-form"
          data-add-perm-form
          data-existing-permissions={permissionGrantsJson}
        >
          <input type="hidden" name="redirect" value={`/admin/console/rbac/roles/${roleId}`} />
          <div class="form-row">
            <label for="resource_kind" class="form-label">資源類型</label>
            <select id="resource_kind" name="resource_kind" class="form-select">
              {RESOURCE_KINDS.map((k) => (
                <option value={k}>{k}</option>
              ))}
            </select>
          </div>
          <div class="form-row">
            <label for="action" class="form-label">操作</label>
            <select id="action" name="action" class="form-select">
              {ACTIONS.map((a) => (
                <option value={a}>{a}</option>
              ))}
            </select>
          </div>
          <div class="form-row">
            <label for="resource_id" class="form-label">Resource ID <span class="optional">（選填，留空表示萬用字元）</span></label>
            <input
              id="resource_id"
              type="text"
              name="resource_id"
              class="form-input"
              placeholder="* (萬用字元)"
              autocomplete="off"
            />
          </div>
          <p class="operation-preview" data-add-perm-preview role="status" aria-live="polite">
            留空 Resource ID 會授予此資源類型的所有對象。
          </p>
          <div class="form-actions">
            <button type="submit" class="btn-primary">新增權限</button>
          </div>
        </form>
      </AdminPanel>

      {!isReservedRole && (
        <AdminPanel title="刪除角色" eyebrow="移除自訂角色與其權限">
          <form
            method="POST"
            action={`/api/admin/console/rbac/roles/${roleId}`}
            class="danger-form"
            data-confirm={`確定要刪除角色 ${role.name}？這會移除 ${assignedUsers.length} 位使用者指派與 ${permissions.length} 項權限。`}
            data-delete-role-form
          >
            <input type="hidden" name="action" value="delete" />
            <input type="hidden" name="redirect" value="/admin/console/rbac?tab=roles" />
            <button type="submit" class="btn-danger">刪除角色</button>
            <span class="muted">刪除後無法從主控台還原。</span>
          </form>
        </AdminPanel>
      )}

    </div>
  )}
</AdminConsoleLayout>

<script
  is:inline
  set:html={`function parseExistingPermissions(form) {
  try {
    return JSON.parse(form.dataset.existingPermissions || '[]');
  } catch {
    return [];
  }
}

function parseJsonDataset(form, key, fallback) {
  try {
    return JSON.parse(form.dataset[key] || JSON.stringify(fallback));
  } catch {
    return fallback;
  }
}

function setSubmitBusy(form) {
  var button = form.querySelector('button[type="submit"]');
  if (!(button instanceof HTMLButtonElement)) return;
  button.disabled = true;
  if (form.matches('[data-assign-user-form]')) button.textContent = '加入中...';
  else if (form.matches('[data-role-edit-form]')) button.textContent = '儲存中...';
  else if (form.matches('[data-preset-form]')) button.textContent = '套用中...';
  else if (form.matches('[data-delete-role-form]')) button.textContent = '刪除中...';
  else if (form.matches('[data-remove-role-form]')) button.textContent = '移除中...';
  else button.textContent = '處理中...';
}

function updateAssignUserPreview() {
  var form = document.querySelector('[data-assign-user-form]');
  if (!(form instanceof HTMLFormElement)) return;
  var preview = form.querySelector('[data-assign-user-preview]');
  var select = form.querySelector('select[name="user_id"]');
  var button = form.querySelector('button[type="submit"]');
  if (!preview || !(select instanceof HTMLSelectElement)) return;
  var users = parseJsonDataset(form, 'unassignedUsers', []);
  var selected = users.find(function (user) { return user.id === select.value; });
  if (!selected) {
    preview.textContent = '選擇使用者後會顯示角色指派預覽。';
    preview.className = 'operation-preview';
    if (button instanceof HTMLButtonElement) button.disabled = true;
    return;
  }
  var roleName = form.dataset.roleName || '此角色';
  preview.textContent = '將 ' + selected.email + ' 加入角色 ' + roleName + (selected.disabled ? '。此使用者目前已停用，啟用前不會取得有效權限。' : '。');
  preview.className = selected.disabled ? 'operation-preview warning' : 'operation-preview';
  if (button instanceof HTMLButtonElement) button.disabled = false;
}

function updateRoleEditPreview() {
  var form = document.querySelector('[data-role-edit-form]');
  if (!(form instanceof HTMLFormElement)) return;
  var preview = form.querySelector('[data-role-edit-preview]');
  var nameInput = form.querySelector('input[name="name"]');
  var descriptionInput = form.querySelector('textarea[name="description"]');
  var button = form.querySelector('button[type="submit"]');
  if (!preview || !(nameInput instanceof HTMLInputElement) || !(descriptionInput instanceof HTMLTextAreaElement)) return;
  var initialName = form.dataset.initialName || '';
  var initialDescription = form.dataset.initialDescription || '';
  var nextName = nameInput.value.trim();
  var nextDescription = descriptionInput.value.trim();
  var otherNames = parseJsonDataset(form, 'otherRoleNames', []);
  if (otherNames.includes(nextName)) {
    preview.textContent = '角色名稱已存在：' + nextName + '。';
    preview.className = 'operation-preview error';
    if (button instanceof HTMLButtonElement) button.disabled = true;
    return;
  }
  if (nextName === initialName && nextDescription === initialDescription) {
    preview.textContent = '角色資料尚未變更。';
    preview.className = 'operation-preview';
    if (button instanceof HTMLButtonElement) button.disabled = false;
    return;
  }
  var parts = [];
  if (nextName !== initialName) parts.push('名稱：' + initialName + ' → ' + nextName);
  if (nextDescription !== initialDescription) parts.push('描述將更新');
  preview.textContent = parts.join('；') + '。';
  preview.className = 'operation-preview warning';
  if (button instanceof HTMLButtonElement) button.disabled = false;
}

function formPermissionValue(form) {
  var kind = form.querySelector('select[name="resource_kind"]');
  var action = form.querySelector('select[name="action"], select[name="permission_action"]');
  var resource = form.querySelector('input[name="resource_id"]');
  return {
    kind: kind instanceof HTMLSelectElement ? kind.value : '',
    action: action instanceof HTMLSelectElement ? action.value : '',
    resourceId: resource instanceof HTMLInputElement ? resource.value.trim() : '',
  };
}

function permissionLabel(value) {
  return value.kind + ':' + (value.resourceId || '*') + ':' + value.action;
}

function findDuplicate(form, value) {
  var permissionId = form.dataset.permissionId || '';
  return parseExistingPermissions(form).find(function (permission) {
    return String(permission.id) !== permissionId
      && permission.kind === value.kind
      && permission.action === value.action
      && (permission.resourceId || '') === (value.resourceId || '');
  });
}

function updateAddPermissionPreview() {
  var form = document.querySelector('[data-add-perm-form]');
  if (!(form instanceof HTMLFormElement)) return;
  var preview = form.querySelector('[data-add-perm-preview]');
  if (!preview) return;
  var value = formPermissionValue(form);
  var duplicate = findDuplicate(form, value);
  if (duplicate) {
    preview.textContent = '權限已存在：' + permissionLabel(value) + '。';
    preview.className = 'operation-preview error';
    form.querySelector('button[type="submit"]')?.setAttribute('disabled', '');
    return;
  }
  var wildcard = !value.resourceId;
  preview.textContent = wildcard
    ? '將新增 wildcard 權限：' + permissionLabel(value) + '。此角色會套用到所有 ' + value.kind + '。'
    : '將新增 scoped 權限：' + permissionLabel(value) + '。';
  preview.className = wildcard ? 'operation-preview warning' : 'operation-preview';
  form.querySelector('button[type="submit"]')?.removeAttribute('disabled');
}

function updatePermissionRowPreview(form) {
  if (!(form instanceof HTMLFormElement)) return;
  var preview = form.querySelector('[data-permission-preview]');
  if (!preview) return;
  var button = form.querySelector('button[type="submit"]');
  var value = formPermissionValue(form);
  var duplicate = findDuplicate(form, value);
  if (duplicate) {
    preview.textContent = '已和另一筆權限重複：' + permissionLabel(value) + '。';
    preview.className = 'permission-preview error';
    if (button instanceof HTMLButtonElement) button.disabled = true;
    return;
  }
  preview.textContent = value.resourceId
    ? 'Scoped：只套用到 ' + value.resourceId + '。'
    : 'Wildcard：套用到所有 ' + value.kind + '。';
  preview.className = value.resourceId ? 'permission-preview' : 'permission-preview warning';
  if (button instanceof HTMLButtonElement) button.disabled = false;
}

document.querySelector('[data-add-perm-form]')?.addEventListener('input', updateAddPermissionPreview);
document.querySelector('[data-add-perm-form]')?.addEventListener('change', updateAddPermissionPreview);
document.querySelector('[data-assign-user-form]')?.addEventListener('change', updateAssignUserPreview);
document.querySelector('[data-role-edit-form]')?.addEventListener('input', updateRoleEditPreview);
document.querySelector('[data-role-edit-form]')?.addEventListener('change', updateRoleEditPreview);
document.querySelectorAll('[data-permission-row-form]').forEach(function (form) {
  form.addEventListener('input', function () { updatePermissionRowPreview(form); });
  form.addEventListener('change', function () { updatePermissionRowPreview(form); });
  updatePermissionRowPreview(form);
});
updateAddPermissionPreview();
updateAssignUserPreview();
updateRoleEditPreview();

document.addEventListener('submit', function (event) {
  var form = event.target;
  if (!(form instanceof HTMLFormElement)) return;
  var message = form.dataset.confirm;
  if (message && !window.confirm(message)) {
    event.preventDefault();
    return;
  }
  if (form.matches('[data-add-perm-form]')) {
    var value = formPermissionValue(form);
    var duplicate = findDuplicate(form, value);
    if (duplicate) {
      event.preventDefault();
      updateAddPermissionPreview();
      return;
    }
    if (!window.confirm('確定新增權限 ' + permissionLabel(value) + '？' + (!value.resourceId ? '這是 wildcard 權限。' : ''))) {
      event.preventDefault();
      return;
    }
  }
  if (form.matches('[data-permission-row-form]')) {
    var rowValue = formPermissionValue(form);
    var rowDuplicate = findDuplicate(form, rowValue);
    if (rowDuplicate) {
      event.preventDefault();
      updatePermissionRowPreview(form);
      return;
    }
    if (!window.confirm('確定更新權限為 ' + permissionLabel(rowValue) + '？' + (!rowValue.resourceId ? '這是 wildcard 權限。' : ''))) {
      event.preventDefault();
      return;
    }
  }
  if (form.matches('[data-role-edit-form]')) {
    updateRoleEditPreview();
    var editPreview = form.querySelector('[data-role-edit-preview]');
    if (editPreview?.classList.contains('error')) {
      event.preventDefault();
      return;
    }
  }
  setSubmitBusy(form);
});`}
