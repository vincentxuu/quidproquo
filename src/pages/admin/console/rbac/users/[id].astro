---
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled } from '../../_guard';

export const prerender = false;

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('rbac');
const userId = Astro.params.id ?? '';

const breadcrumb = [
  { label: '權限管理', href: '/admin/console/rbac' },
  { label: `使用者 ${userId}` },
];

interface UserRow {
  user_id: number;
  email: string;
  created_at: number;
  disabled_at: number | null;
}

interface RoleRow {
  role_id: number;
  name: string;
  description: string | null;
}

interface UserRoleRow {
  name: string;
}

const DEFAULT_ROLES = ['admin', 'operator', 'approver', 'viewer'];

let user: UserRow | null = null;
let allRoles: RoleRow[] = [];
let assignedRoleNames: string[] = [];
let loadError = false;

if (ready && userId) {
  try {
    const db = getEnv().DB;

    const [userResult, rolesResult, assignedResult] = await Promise.all([
      db.prepare(`
        SELECT user_id, email, created_at, disabled_at
        FROM console_users
        WHERE user_id = ?
      `).bind(userId).first<UserRow>(),

      db.prepare(`
        SELECT role_id, name, description
        FROM console_roles
        ORDER BY name
      `).all<RoleRow>(),

      db.prepare(`
        SELECT r.name
        FROM console_user_roles ur
        JOIN console_roles r ON r.role_id = ur.role_id
        WHERE ur.user_id = ?
      `).bind(userId).all<UserRoleRow>(),
    ]);

    user = userResult ?? null;
    allRoles = rolesResult.results ?? [];
    assignedRoleNames = (assignedResult.results ?? []).map((r) => r.name);
  } catch {
    loadError = true;
  }
}

function formatTs(ms: number | null): string {
  if (!ms) return '—';
  return new Date(ms).toISOString().replace('T', ' ').slice(0, 19) + ' UTC';
}

// Sort roles: default 4 first, then custom
const sortedRoles = [
  ...allRoles.filter((r) => DEFAULT_ROLES.includes(r.name)),
  ...allRoles.filter((r) => !DEFAULT_ROLES.includes(r.name)),
];
---

<AdminConsoleLayout title={user ? user.email : `使用者 ${userId}`} section="rbac" breadcrumb={breadcrumb}>
  {!ready && (
    <AdminState tone="empty">權限管理功能尚未啟用。</AdminState>
  )}
  {ready && !userId && (
    <AdminState tone="error">未指定使用者 ID。</AdminState>
  )}
  {ready && userId && loadError && (
    <AdminState tone="error">無法載入使用者資料。</AdminState>
  )}
  {ready && userId && !loadError && !user && (
    <AdminState tone="error">找不到該使用者。</AdminState>
  )}
  {ready && userId && !loadError && user && (
    <div class="user-detail">

      <AdminPanel title="使用者資訊">
        <div class="info-grid">
          <div class="info-row">
            <span class="info-label">使用者 ID</span>
            <code>{user.user_id}</code>
          </div>
          <div class="info-row">
            <span class="info-label">電子郵件</span>
            <span>{user.email}</span>
          </div>
          <div class="info-row">
            <span class="info-label">建立時間</span>
            <span class="mono">{formatTs(user.created_at)}</span>
          </div>
          <div class="info-row">
            <span class="info-label">最後登入</span>
            <span class="muted">N/A</span>
          </div>
          <div class="info-row">
            <span class="info-label">狀態</span>
            {user.disabled_at ? (
              <span class="badge disabled">停用於 {formatTs(user.disabled_at)}</span>
            ) : (
              <span class="badge active">啟用中</span>
            )}
          </div>
        </div>
      </AdminPanel>

      <AdminPanel title="角色指派" eyebrow="為此使用者選擇角色">
        <form
          method="POST"
          action={`/api/admin/console/rbac/users/${userId}/roles`}
          class="role-form"
        >
          <div class="role-checkboxes">
            {sortedRoles.map((role) => (
              <label class="role-label">
                <input
                  type="checkbox"
                  name="roles"
                  value={role.name}
                  checked={assignedRoleNames.includes(role.name)}
                />
                <span class="role-name">{role.name}</span>
                {role.description && (
                  <span class="role-desc">{role.description}</span>
                )}
              </label>
            ))}
          </div>
          <div class="form-actions">
            <button type="submit" class="btn-primary">儲存角色</button>
          </div>
        </form>
      </AdminPanel>

      <AdminPanel title="帳號操作" eyebrow="停用或重新啟用此使用者">
        <div class="actions-row">
          {user.disabled_at ? (
            <form method="POST" action={`/api/admin/console/rbac/users/${userId}/disable`}>
              <input type="hidden" name="action" value="enable" />
              <button type="submit" class="btn-enable">重新啟用使用者</button>
            </form>
          ) : (
            <form method="POST" action={`/api/admin/console/rbac/users/${userId}/disable`}>
              <input type="hidden" name="action" value="disable" />
              <button type="submit" class="btn-danger">停用使用者</button>
            </form>
          )}
          <span class="action-note">
            {user.disabled_at
              ? '此使用者目前已停用，無法登入。'
              : '停用後，此使用者將無法存取主控台。'}
          </span>
        </div>
      </AdminPanel>

    </div>
  )}
</AdminConsoleLayout>

<style>
  .user-detail {
    display: grid;
    gap: 1.25rem;
  }

  .info-grid {
    display: grid;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
  }

  .info-row {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    font-size: 0.875rem;
  }

  .info-label {
    min-width: 100px;
    color: var(--admin-text-soft);
    font-size: 0.8rem;
  }

  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.82rem;
  }

  .muted {
    color: var(--admin-text-muted);
    font-size: 0.85rem;
  }

  .badge {
    display: inline-block;
    padding: 0.1em 0.55em;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 600;
    border: 1px solid;
  }

  .badge.active {
    color: #16a34a;
    border-color: #16a34a;
    background: #f0fdf4;
  }

  .badge.disabled {
    color: #dc2626;
    border-color: #dc2626;
    background: #fef2f2;
  }

  .role-form {
    padding: 0.75rem 1rem;
    display: grid;
    gap: 1rem;
  }

  .role-checkboxes {
    display: grid;
    gap: 0.5rem;
  }

  .role-label {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .role-label input[type="checkbox"] {
    margin-top: 0.05rem;
  }

  .role-name {
    font-weight: 600;
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.82rem;
  }

  .role-desc {
    color: var(--admin-text-muted);
    font-size: 0.8rem;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-primary {
    padding: 0.4rem 1rem;
    border: 1px solid var(--admin-accent);
    border-radius: var(--admin-radius);
    background: var(--admin-accent);
    color: #fff;
    font-size: 0.85rem;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.85;
  }

  .actions-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    flex-wrap: wrap;
  }

  .btn-danger {
    padding: 0.4rem 1rem;
    border: 1px solid #dc2626;
    border-radius: var(--admin-radius);
    background: #fef2f2;
    color: #dc2626;
    font-size: 0.85rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-danger:hover {
    background: #fee2e2;
  }

  .btn-enable {
    padding: 0.4rem 1rem;
    border: 1px solid #16a34a;
    border-radius: var(--admin-radius);
    background: #f0fdf4;
    color: #16a34a;
    font-size: 0.85rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-enable:hover {
    background: #dcfce7;
  }

  .action-note {
    color: var(--admin-text-muted);
    font-size: 0.82rem;
  }
</style>
