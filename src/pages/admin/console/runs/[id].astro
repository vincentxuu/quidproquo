---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { createBackends } from '@/lib/agent-os/storage';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('runTimeline');

const runId = Astro.params.id;
if (!runId) return Astro.redirect('/admin/console/runs');

interface FlowRunRow {
  flow_run_id: string;
  flow_id: string;
  status: string;
  started_at: number;
  finished_at: number | null;
  latency_ms: number | null;
  display_name: string | null;
}

interface StepRunRow {
  step_run_id: string;
  step_id: string;
  kind: string;
  status: string;
  attempt: number;
  started_at: number | null;
  finished_at: number | null;
  latency_ms: number | null;
  step_order: number;
  created_at: number;
  updated_at: number | null;
  inputs_json: string | null;
  outputs_json: string | null;
  error_json: string | null;
  agent_run_id: string | null;
}

interface ToolCallRow {
  call_id: number;
  run_id: string;
  syscall_name: string;
  tokens_in: number | null;
  tokens_out: number | null;
  cost_usd: number | null;
  latency_ms: number | null;
  error: string | null;
}

interface AgentEventRow {
  event_id: number;
  run_id: string;
  kind: string;
  step_id: string | null;
  payload_json: string;
  at: number;
}

interface PendingApproval {
  approvalId: string;
  reason: string;
  context: unknown;
  createdAt: number;
}

let run: FlowRunRow | null = null;
let steps: StepRunRow[] = [];
let pendingApprovals: PendingApproval[] = [];
let toolCallsByRun = new Map<string, ToolCallRow[]>();
let eventsByRun = new Map<string, AgentEventRow[]>();
let loadError = false;

if (ready) {
  try {
    const db = getEnv().DB;
    const [runResult, stepsResult] = await Promise.all([
      db
        .prepare(
          `SELECT fr.flow_run_id, fr.flow_id, fr.status, fr.started_at, fr.finished_at, fr.latency_ms,
                  fd.display_name
           FROM flow_runs fr
           LEFT JOIN flow_definitions fd ON fd.flow_id = fr.flow_id
           WHERE fr.flow_run_id = ?
           LIMIT 1`,
        )
        .bind(runId)
        .first<FlowRunRow>(),
      db
        .prepare(
          `SELECT step_run_id,
                  step_id,
                  step_type AS kind,
                  status,
                  attempt,
                  started_at,
                  finished_at,
                  latency_ms,
                  step_order,
                  created_at,
                  updated_at,
                  inputs_json,
                  outputs_json,
                  error_json,
                  agent_run_id
           FROM flow_step_runs
           WHERE flow_run_id = ?
           ORDER BY step_order ASC, attempt ASC, created_at ASC`,
        )
        .bind(runId)
        .all<StepRunRow>(),
    ]);

    run = runResult;
    steps = stepsResult.results ?? [];

    const backends = createBackends(getEnv());
    const approvals = await backends.approvals.listByStatus('pending');
    pendingApprovals = approvals
      .filter((approval) => approval.runId === runId)
      .map((approval) => ({
        approvalId: approval.approvalId,
        reason: approval.reason,
        context: approval.context,
        createdAt: approval.createdAt,
      }));

    const agentRunIds = [...new Set(steps.map((step) => step.agent_run_id).filter((id): id is string => Boolean(id)))];
    if (agentRunIds.length > 0) {
      const placeholders = agentRunIds.map(() => '?').join(', ');
      const [toolResult, eventResult] = await Promise.all([
        db
          .prepare(
            `SELECT call_id, run_id, syscall_name, tokens_in, tokens_out, cost_usd, latency_ms, error
             FROM agent_tool_calls
             WHERE run_id IN (${placeholders})
             ORDER BY started_at ASC`,
          )
          .bind(...agentRunIds)
          .all<ToolCallRow>(),
        db
          .prepare(
            `SELECT event_id, run_id, kind, step_id, payload_json, at
             FROM agent_run_events
             WHERE run_id IN (${placeholders})
             ORDER BY event_id ASC`,
          )
          .bind(...agentRunIds)
          .all<AgentEventRow>(),
      ]);

      for (const call of toolResult.results ?? []) {
        const list = toolCallsByRun.get(call.run_id) ?? [];
        list.push(call);
        toolCallsByRun.set(call.run_id, list);
      }
      for (const event of eventResult.results ?? []) {
        const list = eventsByRun.get(event.run_id) ?? [];
        list.push(event);
        eventsByRun.set(event.run_id, list);
      }
    }
  } catch {
    loadError = true;
  }
}

function formatRelative(ms: number): string {
  const diffMs = Date.now() - ms;
  const diffSec = Math.floor(diffMs / 1000);
  if (diffSec < 60) return `${diffSec}s ago`;
  const diffMin = Math.floor(diffSec / 60);
  if (diffMin < 60) return `${diffMin}m ago`;
  const diffHr = Math.floor(diffMin / 60);
  if (diffHr < 24) return `${diffHr}h ago`;
  const diffDay = Math.floor(diffHr / 24);
  return `${diffDay}d ago`;
}

function formatDuration(ms: number | null): string {
  if (ms === null) return '—';
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}

function isTerminalStatus(status: string): boolean {
  return status === 'done' || status === 'failed' || status === 'cancelled';
}

function isCancellableRun(status: string): boolean {
  return status === 'queued' || status === 'running';
}

function canRetryStep(status: string): boolean {
  return status === 'failed' || status === 'cancelled';
}

function statusClass(status: string): string {
  switch (status) {
    case 'done': return 'badge-success';
    case 'failed': return 'badge-error';
    case 'running': return 'badge-running';
    case 'cancelled': return 'badge-muted';
    case 'pending': return 'badge-pending';
    default: return 'badge-muted';
  }
}

function prettyJson(raw: string | null): string {
  if (!raw) return '—';
  try {
    return JSON.stringify(JSON.parse(raw), null, 2);
  } catch {
    return raw;
  }
}

const flowName = run?.display_name ?? run?.flow_id ?? runId;
const bootstrap = run
  ? {
      run: {
        flowRunId: run.flow_run_id,
        flowId: run.flow_id,
        status: run.status,
        startedAt: run.started_at,
        latencyMs: run.latency_ms,
        displayName: flowName,
      },
      steps,
      pendingApprovals,
      uiFlags: {
        ready,
        cancellable: isCancellableRun(run.status),
      },
    }
  : null;
---

<AdminConsoleLayout
  title={`Run: ${runId.slice(0, 8)}…`}
  section="runs"
  breadcrumb={[
    { label: '執行記錄', href: '/admin/console/runs' },
    { label: run ? (run.display_name ?? run.flow_id) : runId, href: run ? `/admin/console/flows/${run.flow_id}` : undefined },
    { label: runId.slice(0, 8) + '…' },
  ]}
>
  {!ready && (
    <AdminState tone="empty">{`Run timeline ships in ${consolePhaseFor('runTimeline')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">無法載入執行資料。</AdminState>
  )}
  {ready && !loadError && !run && (
    <AdminState tone="empty">找不到此執行記錄。</AdminState>
  )}
  {ready && !loadError && run && (
    <>
      <div class="run-header">
        <div class="run-meta">
          <div class="run-meta-item">
            <span class="meta-label">工作流程</span>
            <span class="meta-value">
              <a href={`/admin/console/flows/${run.flow_id}`}>{flowName}</a>
            </span>
          </div>
          <div class="run-meta-item">
            <span class="meta-label">狀態</span>
            <span id="run-status" class:list={['badge', statusClass(run.status)]}>{run.status}</span>
          </div>
          <div class="run-meta-item">
            <span class="meta-label">開始時間</span>
            <span class="meta-value mono">{formatRelative(run.started_at)}</span>
          </div>
          <div class="run-meta-item">
            <span class="meta-label">耗時</span>
            <span class="meta-value mono">{formatDuration(run.latency_ms)}</span>
          </div>
          <div class="run-meta-item">
            <span class="meta-label">執行 ID</span>
            <span class="meta-value mono">{run.flow_run_id}</span>
          </div>
        </div>
        <div class="run-actions" id="run-actions">
          <a href={`/admin/console/runs/${runId}/evidence`} class="btn-secondary">來源證據</a>
          <button id="cancel-run-btn" type="button" class="btn-danger" disabled={!isCancellableRun(run.status)}>取消執行</button>
        </div>
      </div>

      <div id="run-action-status" class="run-action-status" role="status" aria-live="polite" hidden></div>

      {pendingApprovals.length > 0 && (
        <AdminPanel title="待審核">
          <div id="approval-panel" class="approval-panel">
            {pendingApprovals.map((approval) => (
              <div class="approval-card" data-approval-id={approval.approvalId}>
                <div class="approval-header">
                  <span class="approval-reason">{approval.reason}</span>
                  <small class="approval-time">{new Date(approval.createdAt).toLocaleString('zh-TW')}</small>
                </div>
                <pre class="approval-context">{JSON.stringify(approval.context, null, 2)}</pre>
                <textarea class="approval-comment" placeholder="備注（選填）"></textarea>
                <div class="approval-actions">
                  <button type="button" data-action="approve" class="mini-btn mini-btn-approve">核准</button>
                  <button type="button" data-action="reject" class="mini-btn mini-btn-reject">拒絕</button>
                </div>
              </div>
            ))}
          </div>
        </AdminPanel>
      )}

      <AdminPanel title="步驟時間軸">
        {steps.length === 0 ? (
          <AdminState tone="empty">尚無步驟記錄。</AdminState>
        ) : (
          <AdminTable minWidth="640px" flush>
            <thead>
              <tr>
                <th>步驟</th>
                <th>類型</th>
                <th>狀態</th>
                <th>嘗試次數</th>
                <th>耗時</th>
                <th>操作</th>
              </tr>
            </thead>
            <tbody id="timeline-body">
              {steps.map((step) => {
                const toolCalls = step.agent_run_id ? toolCallsByRun.get(step.agent_run_id) ?? [] : [];
                const events = step.agent_run_id ? eventsByRun.get(step.agent_run_id) ?? [] : [];
                return (
                  <>
                    <tr
                      class="timeline-row"
                      data-step-run-id={step.step_run_id}
                      data-step-status={step.status}
                      data-step-attempt={step.attempt}
                    >
                      <td class="mono step-id">{step.step_id}</td>
                      <td class="kind">{step.kind}</td>
                      <td>
                        <span class:list={['badge', statusClass(step.status)]}>{step.status}</span>
                      </td>
                      <td class="mono">{step.attempt}</td>
                      <td class="mono">{formatDuration(step.latency_ms)}</td>
                      <td class="timeline-actions-cell">
                        {canRetryStep(step.status) && (
                          <button
                            type="button"
                            class="btn-small"
                            data-action="retry"
                            data-step-run-id={step.step_run_id}
                          >
                            重試
                          </button>
                        )}
                      </td>
                    </tr>
                    <tr class="step-detail-row">
                      <td colspan="6">
                        <details class="step-detail">
                          <summary>步驟詳情</summary>
                          <div class="step-detail-grid">
                            <div>
                              <h4>輸入</h4>
                              <pre>{prettyJson(step.inputs_json)}</pre>
                            </div>
                            <div>
                              <h4>輸出</h4>
                              <pre>{prettyJson(step.outputs_json)}</pre>
                            </div>
                            {step.error_json && (
                              <div class="detail-wide">
                                <h4>錯誤</h4>
                                <pre>{prettyJson(step.error_json)}</pre>
                              </div>
                            )}
                            <div class="detail-wide">
                              <h4>工具呼叫 ({toolCalls.length})</h4>
                              {toolCalls.length === 0 ? (
                                <p class="detail-empty">尚無工具呼叫記錄。</p>
                              ) : (
                                <table class="detail-table">
                                  <thead>
                                    <tr>
                                      <th>ID</th>
                                      <th>Syscall</th>
                                      <th>Tokens</th>
                                      <th>費用</th>
                                      <th>延遲</th>
                                      <th>錯誤</th>
                                    </tr>
                                  </thead>
                                  <tbody>
                                    {toolCalls.map((call) => (
                                      <tr>
                                        <td class="mono">{call.call_id}</td>
                                        <td>{call.syscall_name}</td>
                                        <td class="mono">{(call.tokens_in ?? 0) + (call.tokens_out ?? 0)}</td>
                                        <td class="mono">{call.cost_usd == null ? '—' : call.cost_usd.toFixed(4)}</td>
                                        <td class="mono">{call.latency_ms == null ? '—' : `${call.latency_ms}ms`}</td>
                                        <td>{call.error ?? '—'}</td>
                                      </tr>
                                    ))}
                                  </tbody>
                                </table>
                              )}
                            </div>
                            <div class="detail-wide">
                              <h4>事件 ({events.length})</h4>
                              {events.length === 0 ? (
                                <p class="detail-empty">尚無事件記錄。</p>
                              ) : (
                                <pre>{events.map((event) => `${event.event_id} ${event.kind} ${event.payload_json}`).join('\n')}</pre>
                              )}
                            </div>
                          </div>
                        </details>
                      </td>
                    </tr>
                  </>
                );
              })}
            </tbody>
          </AdminTable>
        )}
      </AdminPanel>
    </>
  )}
</AdminConsoleLayout>

<script is:inline>
  const bootstrap = document.getElementById('run-bootstrap')?.textContent;
  const initialData = bootstrap ? JSON.parse(bootstrap) : null;
  if (!initialData?.run) {
    // no run data means render is already in fallback state
    // keep script no-op
  } else {
    const runId = initialData.run.flowRunId;
    const flowId = initialData.run.flowId;
    const statusBadge = document.getElementById('run-status');
    const cancelBtn = document.getElementById('cancel-run-btn');
    const timelineBody = document.getElementById('timeline-body');
    const runActionStatus = document.getElementById('run-action-status');
    const approvalPanel = document.getElementById('approval-panel');

    const runActionsRoot = document.getElementById('run-actions');

    function setStatusText(message, type = '') {
      if (!runActionStatus) return;
      runActionStatus.hidden = false;
      runActionStatus.textContent = message;
      runActionStatus.className = `run-action-status ${type}`;
      if (type === 'success' || type === 'error') {
        setTimeout(() => {
          if (runActionStatus) {
            runActionStatus.textContent = '';
            runActionStatus.hidden = true;
          }
        }, 5000);
      }
    }

    function cssStatusClass(status) {
      switch (status) {
        case 'done': return 'badge-success';
        case 'failed': return 'badge-error';
        case 'running': return 'badge-running';
        case 'cancelled': return 'badge-muted';
        case 'pending': return 'badge-pending';
        default: return 'badge-muted';
      }
    }

    function canCancelRun(status) {
      return status === 'queued' || status === 'running';
    }

    function canRetryStep(status) {
      return status === 'failed' || status === 'cancelled';
    }

    function setRunStatus(status) {
      if (!statusBadge) return;
      statusBadge.classList.remove('badge-success', 'badge-error', 'badge-running', 'badge-muted', 'badge-pending');
      statusBadge.classList.add(cssStatusClass(status));
      statusBadge.textContent = status;
      if (cancelBtn) cancelBtn.disabled = !canCancelRun(status);
    }

    function renderTimeline(steps) {
      if (!timelineBody) return;
      timelineBody.replaceChildren();

      if (!steps.length) {
        const row = document.createElement('tr');
        const cell = document.createElement('td');
        cell.setAttribute('colspan', '6');
        cell.textContent = '尚無步驟記錄。';
        row.append(cell);
        timelineBody.append(row);
        return;
      }

      for (const step of steps) {
        const row = document.createElement('tr');
        row.dataset.stepRunId = String(step.step_run_id);
        row.dataset.stepStatus = String(step.status);
        row.dataset.stepAttempt = String(step.attempt);
        row.className = 'timeline-row';

        const idCell = document.createElement('td');
        idCell.className = 'mono step-id';
        idCell.textContent = String(step.step_id);

        const kindCell = document.createElement('td');
        kindCell.className = 'kind';
        kindCell.textContent = String(step.kind);

        const statusCell = document.createElement('td');
        const statusBadge = document.createElement('span');
        statusBadge.className = `badge ${cssStatusClass(step.status)}`;
        statusBadge.textContent = String(step.status);
        statusCell.append(statusBadge);

        const attemptCell = document.createElement('td');
        attemptCell.className = 'mono';
        attemptCell.textContent = String(step.attempt);

        const durationCell = document.createElement('td');
        durationCell.className = 'mono';
        const latency = step.latency_ms;
        if (latency === null) {
          durationCell.textContent = '—';
        } else if (latency < 1000) {
          durationCell.textContent = `${latency}ms`;
        } else {
          durationCell.textContent = `${(latency / 1000).toFixed(1)}s`;
        }

        const actionCell = document.createElement('td');
        actionCell.className = 'timeline-actions-cell';
        if (canRetryStep(step.status)) {
          const retryBtn = document.createElement('button');
          retryBtn.type = 'button';
          retryBtn.className = 'btn-small';
          retryBtn.textContent = '重試';
          retryBtn.dataset.action = 'retry';
          retryBtn.dataset.stepRunId = String(step.step_run_id);
          actionCell.append(retryBtn);
        }

        row.append(idCell, kindCell, statusCell, attemptCell, durationCell, actionCell);
        timelineBody.append(row);
      }
    }

    function renderApprovals(approvals) {
      if (!approvalPanel) return;
      approvalPanel.innerHTML = '';
      if (!approvals.length) {
        const empty = document.createElement('div');
        empty.className = 'approval-empty';
        empty.textContent = '目前無待審核項目。';
        approvalPanel.append(empty);
        if (runActionsRoot) {
          const existing = runActionsRoot.querySelector('.run-idle-approval-hint');
          if (existing) existing.remove();
        }
        return;
      }

      for (const approval of approvals) {
        const card = document.createElement('div');
        card.className = 'approval-card';
        card.dataset.approvalId = String(approval.approvalId);

        const header = document.createElement('div');
        header.className = 'approval-header';

        const reason = document.createElement('span');
        reason.className = 'approval-reason';
        reason.textContent = String(approval.reason);

        const ts = document.createElement('small');
        ts.className = 'approval-time';
        ts.textContent = new Date(Number(approval.createdAt)).toLocaleString('zh-TW');

        const context = document.createElement('pre');
        context.className = 'approval-context';
        context.textContent = JSON.stringify(approval.context, null, 2);

        const comment = document.createElement('textarea');
        comment.className = 'approval-comment';
        comment.placeholder = '備注（選填）';

        const actions = document.createElement('div');
        actions.className = 'approval-actions';

        const approve = document.createElement('button');
        approve.type = 'button';
        approve.className = 'mini-btn mini-btn-approve';
        approve.dataset.action = 'approve';
        approve.textContent = '核准';

        const reject = document.createElement('button');
        reject.type = 'button';
        reject.className = 'mini-btn mini-btn-reject';
        reject.dataset.action = 'reject';
        reject.textContent = '拒絕';

        actions.append(approve, reject);
        header.append(reason, ts);
        card.append(header, context, comment, actions);
        approvalPanel.append(card);
      }
    }

    async function doApproveReject(event) {
      const button = event.target;
      if (!(button instanceof HTMLElement)) return;
      const action = button.dataset.action;
      if (action !== 'approve' && action !== 'reject') return;

      const card = button.closest('.approval-card');
      if (!card || !(card instanceof HTMLElement)) return;
      const approvalId = card.dataset.approvalId;
      if (!approvalId) return;

      button.disabled = true;
      const originalText = button.textContent;
      button.textContent = '送出中…';

      try {
        const res = await fetch(`/api/admin/agents/approvals/${encodeURIComponent(approvalId)}/${action}`, {
          method: 'POST',
        });
        if (!res.ok) throw new Error('request failed');
        card.remove();
        setStatusText(`審核已${action === 'approve' ? '核准' : '拒絕'}`, 'success');
      } catch {
        setStatusText(`無法${action === 'approve' ? '核准' : '拒絕'}此審核項目`, 'error');
        button.disabled = false;
        button.textContent = originalText;
        return;
      }

      const eventSource = new EventSource(`/api/admin/console/runs/${runId}/events`);
      eventSource.addEventListener('timeline', (message) => {
        const data = parsePayload(message.data);
        if (!data) return;
        renderApprovals(data.approvals);
        eventSource.close();
      });
      eventSource.onerror = () => eventSource.close();
    }

    async function doCancelRun() {
      if (!cancelBtn) return;
      cancelBtn.disabled = true;

      try {
        const res = await fetch(`/api/admin/flows/${encodeURIComponent(flowId)}/runs/${encodeURIComponent(runId)}/cancel`, {
          method: 'POST',
        });
        if (!res.ok) throw new Error('cancel failed');
        setRunStatus('cancelled');
        setStatusText('執行已取消', 'success');
      } catch {
        setStatusText('無法取消執行', 'error');
        cancelBtn.disabled = false;
      }
    }

    async function doRetryStep(stepRunId) {
      const button = timelineBody?.querySelector(`[data-step-run-id="${CSS.escape(stepRunId)}"] [data-action="retry"]`);
      if (!(button instanceof HTMLButtonElement)) return;
      button.disabled = true;
      button.textContent = '重試中…';

      try {
        const res = await fetch(`/api/admin/flows/${encodeURIComponent(flowId)}/runs/${encodeURIComponent(runId)}/steps/${encodeURIComponent(stepRunId)}/retry`, {
          method: 'POST',
        });
        if (!res.ok) throw new Error('retry failed');
        setStatusText('重試已送出', 'success');
      } catch {
        setStatusText('無法重試此步驟', 'error');
        button.disabled = false;
        button.textContent = '重試';
      }
    }

    function parsePayload(raw) {
      try {
        return JSON.parse(raw);
      } catch {
        return null;
      }
    }

    const eventSource = new EventSource(`/api/admin/console/runs/${runId}/events`);
    eventSource.addEventListener('timeline', (message) => {
      const data = parsePayload(message.data);
      if (!data) return;
      if (!data.run || !data.run.status || !Array.isArray(data.steps)) return;

      renderTimeline(data.steps);
      setRunStatus(data.run.status);
      if (Array.isArray(data.approvals)) {
        renderApprovals(data.approvals);
      }

      if (data.terminal) {
        setStatusText(`執行完成：${data.run.status}`, 'success');
        eventSource.close();
      }
    });

    eventSource.addEventListener('terminal', (message) => {
      const data = parsePayload(message.data);
      if (!data) return;
      if (data.run?.status) {
        setRunStatus(data.run.status);
        renderApprovals(data.approvals || []);
        eventSource.close();
      }
    });

    eventSource.onerror = () => {
      // keep retrying by browser EventSource
    };

    if (cancelBtn) {
      cancelBtn.addEventListener('click', doCancelRun);
    }

    if (timelineBody) {
      timelineBody.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLButtonElement)) return;
        if (target.dataset.action === 'retry' && target.dataset.stepRunId) {
          void doRetryStep(target.dataset.stepRunId);
        }
      });
    }

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLButtonElement)) return;
      if (target.dataset.action) {
        void doApproveReject(event);
      }
    });

    renderApprovals(initialData.pendingApprovals || []);
  }
</script>

