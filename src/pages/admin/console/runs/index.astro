---
export const prerender = false;
import AdminConsoleLayout from '@/layouts/AdminConsoleLayout.astro';
import AdminState from '@/components/admin/AdminState.astro';
import AdminPanel from '@/components/admin/AdminPanel.astro';
import AdminTable from '@/components/admin/AdminTable.astro';
import { getEnv } from '@/lib/config/env';
import { ensureConsoleUmbrella, isPageEnabled, consolePhaseFor } from '../_guard';

const gate = ensureConsoleUmbrella();
if (gate) return gate;

const ready = isPageEnabled('runTimeline');

interface RunRow {
  flow_run_id: string;
  flow_id: string;
  status: string;
  started_at: number;
  finished_at: number | null;
  latency_ms: number | null;
  display_name: string | null;
  cost_usd: number | null;
  updated_at: number | null;
}

interface FlowOption {
  flow_id: string;
  display_name: string | null;
}

let runs: RunRow[] = [];
let loadError = false;
let flowOptions: FlowOption[] = [];
let totalRuns = 0;

const url = new URL(Astro.url);
const selectedStatus = url.searchParams.get('status')?.trim().toLowerCase() ?? '';
const selectedFlow = url.searchParams.get('flow')?.trim() ?? '';
const selectedFrom = url.searchParams.get('from')?.trim() ?? '';
const selectedTo = url.searchParams.get('to')?.trim() ?? '';
const selectedPage = Number.parseInt(url.searchParams.get('page') ?? '1', 10);
const page = Number.isFinite(selectedPage) && selectedPage > 0 ? selectedPage : 1;
const offset = (page - 1) * 50;
const PAGE_SIZE = 50;

if (ready) {
  try {
    const db = getEnv().DB;

    const whereParts: string[] = []
    const bindings: Array<string | number> = []

    if (selectedStatus) {
      whereParts.push('fr.status = ?')
      bindings.push(selectedStatus)
    }

    if (selectedFlow) {
      whereParts.push('fr.flow_id = ?')
      bindings.push(selectedFlow)
    }

    if (selectedFrom) {
      const fromMs = new Date(selectedFrom).getTime()
      if (!Number.isNaN(fromMs)) {
        whereParts.push('fr.started_at >= ?')
        bindings.push(fromMs)
      }
    }

    if (selectedTo) {
      const toMs = new Date(selectedTo)
      toMs.setHours(23, 59, 59, 999)
      const toTs = toMs.getTime()
      if (!Number.isNaN(toTs)) {
        whereParts.push('fr.started_at <= ?')
        bindings.push(toTs)
      }
    }

    const whereClause = whereParts.length > 0 ? `WHERE ${whereParts.join(' AND ')}` : ''

    const result = await db
      .prepare(
        `SELECT fr.flow_run_id, fr.flow_id, fr.status, fr.started_at, fr.finished_at, fr.latency_ms,
                fr.cost_usd, fr.updated_at, fd.display_name
         FROM flow_runs fr
         LEFT JOIN flow_definitions fd ON fd.flow_id = fr.flow_id
         ${whereClause}
         ORDER BY fr.started_at DESC
         LIMIT ? OFFSET ?`,
      )
      .bind(...bindings, PAGE_SIZE, offset)
      .all<RunRow>();
    runs = result.results ?? [];

    const flowRows = await db
      .prepare('SELECT flow_id, display_name FROM flow_definitions ORDER BY flow_id ASC')
      .all<FlowOption>();
    flowOptions = flowRows.results ?? [];

    const countResult = await db
      .prepare(`SELECT COUNT(*) AS total
        FROM flow_runs fr ${whereClause}`)
      .bind(...bindings)
      .first<{ total: number }>()
    totalRuns = Number(countResult?.total ?? 0)
  } catch {
    loadError = true;
  }
}

const totalPages = Math.max(1, Math.ceil(totalRuns / PAGE_SIZE));

function listHref(p: number) {
  const u = new URL(url);
  if (p <= 1) {
    u.searchParams.delete('page');
  } else {
    u.searchParams.set('page', String(p));
  }
  return u.pathname + u.search;
}

function formatRelative(ms: number): string {
  const diffMs = Date.now() - ms;
  const diffSec = Math.floor(diffMs / 1000);
  if (diffSec < 60) return `${diffSec}s ago`;
  const diffMin = Math.floor(diffSec / 60);
  if (diffMin < 60) return `${diffMin}m ago`;
  const diffHr = Math.floor(diffMin / 60);
  if (diffHr < 24) return `${diffHr}h ago`;
  const diffDay = Math.floor(diffHr / 24);
  return `${diffDay}d ago`;
}

function formatDuration(ms: number | null): string {
  if (ms === null) return '—';
  if (ms < 1000) return `${ms}ms`;
  return `${(ms / 1000).toFixed(1)}s`;
}

function statusClass(status: string): string {
  switch (status) {
    case 'done': return 'badge-success';
    case 'failed': return 'badge-error';
    case 'running': return 'badge-running';
    case 'cancelled': return 'badge-muted';
    default: return 'badge-muted';
  }
}
---

<AdminConsoleLayout title="執行記錄" section="runs">
  {!ready && (
    <AdminState tone="empty">{`Run timeline ships in ${consolePhaseFor('runTimeline')}.`}</AdminState>
  )}
  {ready && loadError && (
    <AdminState tone="error">無法載入執行記錄。</AdminState>
  )}
  {ready && !loadError && runs.length === 0 && (
    <AdminState tone="empty">尚無執行記錄，請從<a href="/admin/console">工作流程選擇器</a>啟動。</AdminState>
  )}
  {ready && !loadError && runs.length > 0 && (
    <AdminPanel title="所有執行記錄 — 最近 50 筆">
      <form class="toolbar" method="GET" action="/admin/console/runs">
        <label for="status">狀態</label>
        <select id="status" name="status">
          <option value="">全部</option>
          <option value="queued" selected={selectedStatus === 'queued'}>排隊中</option>
          <option value="running" selected={selectedStatus === 'running'}>執行中</option>
          <option value="done" selected={selectedStatus === 'done'}>完成</option>
          <option value="failed" selected={selectedStatus === 'failed'}>失敗</option>
          <option value="cancelled" selected={selectedStatus === 'cancelled'}>已取消</option>
        </select>

        <label for="flow">工作流程</label>
        <select id="flow" name="flow">
          <option value="">所有工作流程</option>
          {flowOptions.map((item) => (
            <option value={item.flow_id} selected={selectedFlow === item.flow_id}>
              {item.display_name ?? item.flow_id}
            </option>
          ))}
        </select>

        <label for="from">開始日期</label>
        <input id="from" name="from" type="date" value={selectedFrom} />

        <label for="to">結束日期</label>
        <input id="to" name="to" type="date" value={selectedTo} />

        <button type="submit" class="btn-secondary">套用</button>
        {(selectedStatus || selectedFlow || selectedFrom || selectedTo) && (
          <a href="/admin/console/runs" class="btn-clear">清除</a>
        )}
      </form>
      <AdminTable minWidth="640px" flush>
        <thead>
        <tr>
            <th>開始時間</th>
            <th>工作流程</th>
            <th>狀態</th>
            <th>耗時</th>
            <th>費用 (USD)</th>
            <th>更新時間</th>
            <th>執行 ID</th>
          </tr>
        </thead>
        <tbody>
          {runs.map((run) => (
            <tr>
              <td class="mono">{formatRelative(run.started_at)}</td>
              <td class="flow-name">{run.display_name ?? run.flow_id}</td>
              <td>
                <span class:list={['badge', statusClass(run.status)]}>{run.status}</span>
              </td>
              <td class="mono">{formatDuration(run.latency_ms)}</td>
              <td class="mono">{run.cost_usd == null ? '—' : run.cost_usd.toFixed(4)}</td>
              <td class="mono">{formatRelative(run.updated_at ?? run.started_at)}</td>
              <td class="mono run-id">
                <a href={`/admin/console/runs/${run.flow_run_id}`}>
                  {run.flow_run_id.slice(0, 8)}&hellip;
                </a>
              </td>
            </tr>
          ))}
        </tbody>
      </AdminTable>

      {totalPages > 1 && (
        <div class="pagination">
          {page > 1 ? <a href={listHref(page - 1)} class="page-btn">上一頁</a> : <span class="page-btn disabled">上一頁</span>}
          <span class="page-info">第 {page} / {totalPages} 頁</span>
          {page < totalPages ? <a href={listHref(page + 1)} class="page-btn">下一頁</a> : <span class="page-btn disabled">下一頁</span>}
        </div>
      )}
    </AdminPanel>
  )}
</AdminConsoleLayout>

<style>
.toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  align-items: center;
  margin-bottom: 0.8rem;
}

.toolbar label {
  font-size: 0.8rem;
  color: var(--admin-text-muted, #64748b);
}

.toolbar select,
.toolbar input {
  border: 1px solid var(--admin-border, #e2e8f0);
  border-radius: var(--admin-radius, 6px);
  background: var(--admin-surface, #fff);
  padding: 0.35rem 0.6rem;
}

.btn-clear,
.btn-secondary {
  border: 1px solid var(--admin-border, #e2e8f0);
  border-radius: var(--admin-radius, 6px);
  padding: 0.35rem 0.7rem;
  text-decoration: none;
  color: var(--admin-text, #1e293b);
  background: var(--admin-surface, #fff);
  font-size: 0.82rem;
}

.btn-clear:hover,
.btn-secondary:hover {
  background: var(--admin-muted, #f1f5f9);
}

  .mono {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85em;
  }

  .flow-name {
    font-size: 0.9em;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .run-id a {
    color: var(--admin-accent, #2563eb);
    text-decoration: none;
  }

  .run-id a:hover {
    text-decoration: underline;
  }

  .badge {
    display: inline-block;
    padding: 0.15em 0.55em;
    border-radius: 999px;
    font-size: 0.78em;
    font-weight: 600;
    white-space: nowrap;
  }

  .badge-success {
    background: var(--admin-success-bg, #dcfce7);
    color: var(--admin-success, #166534);
  }

  .badge-error {
    background: var(--admin-error-bg, #fee2e2);
    color: var(--admin-error, #991b1b);
  }

  .badge-running {
    background: var(--admin-accent-bg, #dbeafe);
    color: var(--admin-accent, #1d4ed8);
  }

  .badge-muted {
    background: var(--admin-muted, #f1f5f9);
    color: var(--admin-text-muted, #64748b);
  }

  .filter-chip {
    margin-left: auto;
    font-size: 0.72rem;
    color: var(--admin-text-muted, #64748b);
  }

  .pagination {
    margin-top: 0.75rem;
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }

  .page-btn {
    border: 1px solid var(--admin-border, #e2e8f0);
    border-radius: var(--admin-radius, 6px);
    padding: 0.32rem 0.6rem;
    background: var(--admin-surface, #fff);
    text-decoration: none;
    color: var(--admin-text, #1e293b);
    font-size: 0.82rem;
  }

  .page-btn.disabled {
    opacity: 0.45;
    pointer-events: none;
  }

  .page-info {
    font-size: 0.82rem;
    color: var(--admin-text-muted, #64748b);
  }
</style>
