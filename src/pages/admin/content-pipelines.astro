---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="內容流程">
  <p class="page-desc">Content Agent Harness MVP：registry、guard、Worker module execution、job timeline 與 artifacts。</p>

  <section class="admin-panel">
    <div class="panel-title">
      <h2>流程清單</h2>
      <button id="refresh" type="button">重新整理</button>
    </div>
    <div id="pipeline-list" class="pipeline-grid">載入中...</div>
  </section>

  <section class="admin-panel">
    <h2>最近任務</h2>
    <div id="job-list">載入中...</div>
  </section>

  <section class="admin-panel">
    <h2>執行結果</h2>
    <pre id="run-output">尚未執行流程。</pre>
  </section>
</AdminLayout>

<script is:inline>
  const pipelineList = document.getElementById('pipeline-list');
  const jobList = document.getElementById('job-list');
  const output = document.getElementById('run-output');
  const refresh = document.getElementById('refresh');

  async function load() {
    const res = await fetch('/api/admin/pipelines');
    if (!res.ok) {
      pipelineList.textContent = '無法載入流程。';
      jobList.textContent = '';
      return;
    }
    const data = await res.json();
    const schedules = Array.isArray(data.schedules) ? data.schedules : [];
    renderPipelines(data.pipelines ?? [], schedules);
    renderJobs(data.jobs ?? []);
  }

  function renderPipelines(pipelines, schedules = []) {
    const scheduleByPipeline = new Map();
    for (const schedule of schedules) {
      if (!schedule || typeof schedule.pipelineId !== 'string' || typeof schedule.cron !== 'string') continue;
      const list = scheduleByPipeline.get(schedule.pipelineId) || [];
      list.push(schedule);
      scheduleByPipeline.set(schedule.pipelineId, list);
    }

    pipelineList.replaceChildren();
    if (!pipelines.length) {
      pipelineList.textContent = '目前沒有註冊流程。';
      return;
    }

    for (const pipeline of pipelines) {
      const card = document.createElement('article');
      card.className = 'pipeline-card';

      const header = document.createElement('div');
      header.className = 'pipeline-header';
      const title = document.createElement('h3');
      title.textContent = pipeline.title;
      const status = document.createElement('span');
      status.className = `runtime runtime-${pipeline.runtime}`;
      status.textContent = pipeline.runtime;
      header.append(title, status);

      const id = document.createElement('code');
      id.textContent = pipeline.id;

      const desc = document.createElement('p');
      desc.textContent = pipeline.description;

      const meta = document.createElement('div');
      meta.className = 'pipeline-meta';
      meta.innerHTML = `
        <span>${pipeline.category}</span>
        <span>${pipeline.risk} 風險</span>
        <span>${pipeline.stages.length} stages</span>
      `;

      const scheduleBlock = buildScheduleBlock(scheduleByPipeline.get(pipeline.id) || []);

      const inputs = document.createElement('div');
      inputs.className = 'pipeline-inputs';
      const inputControls = [];
      for (const field of pipeline.inputs ?? []) {
        const label = document.createElement('label');
        label.textContent = field.label;
        const input = document.createElement('input');
        input.dataset.inputId = field.id;
        input.type = field.type === 'number' ? 'number' : 'text';
        if (field.type === 'boolean') input.type = 'checkbox';
        if (field.type === 'boolean') {
          input.checked = field.defaultValue === true;
        } else {
          input.placeholder = field.placeholder ?? '';
          input.value = field.defaultValue === undefined ? '' : JSON.stringify(field.defaultValue).replace(/^\"|\"$/g, '');
        }
        label.append(input);
        inputs.append(label);
        inputControls.push({ field, input });
      }

      const button = document.createElement('button');
      button.type = 'button';
      button.textContent = '執行流程';
      button.addEventListener('click', () => runPipeline(pipeline, inputControls));

      card.append(header, id, desc, meta, scheduleBlock, inputs, button);
      pipelineList.append(card);
    }
  }

  async function runPipeline(pipeline, inputControls) {
    const input = {};
    for (const { field, input: control } of inputControls) {
      if (field.type === 'boolean') {
        input[field.id] = control.checked;
      } else if (field.type === 'number') {
        input[field.id] = control.value === '' ? undefined : Number(control.value);
      } else if (field.type === 'json') {
        try {
          input[field.id] = control.value ? JSON.parse(control.value) : field.defaultValue;
        } catch {
          output.textContent = `${field.label} 必須是有效 JSON。`;
          return;
        }
      } else {
        input[field.id] = control.value;
      }
    }

    output.textContent = `正在執行 ${pipeline.id}...`;
    const res = await fetch('/api/admin/pipelines', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pipelineId: pipeline.id, input }),
    });
    const data = await res.json();
    output.textContent = JSON.stringify(data, null, 2);
    await load();
  }

  function renderJobs(jobs) {
    jobList.replaceChildren();
    if (!jobs.length) {
      jobList.textContent = 'No jobs yet.';
      return;
    }

    for (const job of jobs) {
      const row = document.createElement('a');
      row.className = 'job-row';
      row.href = `/admin/jobs?id=${encodeURIComponent(job.id)}`;
      const canCancel = job.status === 'queued' || job.status === 'running' || job.status === 'waiting_review';
      const canApprove = job.status === 'waiting_review';
      row.innerHTML = `
        <span class="job-status status-${job.status}">${job.status}</span>
        <strong>${job.pipeline_id}</strong>
        <code>${job.id}</code>
        <time>${formatTime(job.created_at)}</time>
        ${canApprove ? `<button type="button" class="mini-btn approve-btn" data-action="approve" data-job-id="${job.id}">核准</button>` : ''}
        ${canApprove ? `<button type="button" class="mini-btn reject-btn" data-action="reject" data-job-id="${job.id}">拒絕</button>` : ''}
        <button type="button" class="mini-btn rerun-btn" data-action="rerun" data-job-id="${job.id}">重跑</button>
        <button type="button" class="mini-btn cancel-btn" data-action="cancel" data-job-id="${job.id}" ${canCancel ? '' : 'disabled'}>
          取消
        </button>
      `;
      jobList.append(row);
    }

    jobList.querySelectorAll('.mini-btn').forEach((button) => {
      button.addEventListener('click', async (event) => {
        event.preventDefault();
        event.stopPropagation();
        const target = event.currentTarget;
        if (!(target instanceof HTMLButtonElement)) return;
        await actionJob(target.dataset.jobId, target.dataset.action);
      });
    });
  }

  async function actionJob(jobId, action) {
    if (!jobId || !action) return;
    let reviewNote;
    if (action === 'reject') {
      reviewNote = window.prompt('請輸入 reject 原因（必填）')?.trim()
      if (!reviewNote) {
        window.alert('請輸入 reject 原因後再送出。')
        return
      }
    }
    const res = await fetch(`/api/admin/jobs/${encodeURIComponent(jobId)}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(reviewNote ? { action, reviewNote } : { action }),
    });
    const data = await res.json();
    if (!res.ok) {
      window.alert(data.error || `無法執行任務動作：${action}`);
      return;
    }
    await load();
  }

  function formatTime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function buildScheduleBlock(schedules = []) {
    const block = document.createElement('div');
    block.className = 'pipeline-schedule';
    if (!schedules.length) {
      block.innerHTML = `<span class="pipeline-schedule-none">沒有排程</span>`;
      return block;
    }

    block.innerHTML = `
      <strong>排程</strong>
    `;
    const list = document.createElement('ul');
    for (const schedule of schedules) {
      const item = document.createElement('li');
      item.textContent = `${schedule.cron}${schedule.timezone ? ` (${schedule.timezone})` : ''}${schedule.label ? ` / ${schedule.label}` : ''}`;
      list.append(item);
    }
    block.append(list);
    return block;
  }

  refresh.addEventListener('click', load);
  load();
</script>

<style>
  .page-desc {
    color: var(--admin-text-muted, #888);
    margin-bottom: 1.5rem;
  }

  .admin-panel {
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 8px;
    padding: 1.25rem;
    margin: 1rem 0;
    background: var(--admin-surface, #1a1a1a);
  }

  .panel-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .admin-panel h2 {
    font-size: 1rem;
    font-weight: 600;
  }

  .pipeline-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
  }

  .pipeline-card {
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 8px;
    padding: 1rem;
    background: var(--admin-bg, #0f0f0f);
  }

  .pipeline-header,
  .pipeline-meta,
  .job-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .pipeline-header {
    justify-content: space-between;
  }

  .pipeline-header h3 {
    font-size: 0.95rem;
  }

  .pipeline-card code,
  .job-row code {
    color: var(--admin-text-muted, #888);
    font-size: 0.78rem;
  }

  .pipeline-card p {
    margin: 0.75rem 0;
    color: var(--admin-text-muted, #888);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .runtime,
  .pipeline-meta span,
  .job-status {
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    background: var(--admin-border, #2a2a2a);
    color: var(--admin-text-muted, #888);
    font-size: 0.75rem;
  }

  .runtime-worker,
  .status-succeeded {
    color: #86efac;
  }

  .status-waiting_review {
    color: #facc15;
  }

  .status-failed {
    color: #fca5a5;
  }

  .status-dead_letter {
    color: #fb923c;
  }

  .pipeline-inputs {
    display: grid;
    gap: 0.65rem;
    margin: 1rem 0;
  }

  .pipeline-schedule {
    margin: 0.8rem 0;
    padding: 0.75rem;
    border-radius: 8px;
    border: 1px solid var(--admin-border, #2a2a2a);
    background: rgba(255, 255, 255, 0.02);
    color: var(--admin-text-muted, #888);
    font-size: 0.78rem;
    line-height: 1.5;
  }

  .pipeline-schedule strong {
    display: block;
    color: var(--admin-text, #e0e0e0);
    margin-bottom: 0.25rem;
  }

  .pipeline-schedule ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .pipeline-schedule li {
    margin: 0.15rem 0;
  }

  .pipeline-schedule-none {
    display: inline-block;
    margin-bottom: 0.2rem;
  }

  .pipeline-inputs label {
    display: grid;
    gap: 0.35rem;
    color: var(--admin-text-muted, #888);
    font-size: 0.8rem;
  }

  input,
  button {
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 8px;
    padding: 0.55rem 0.7rem;
    background: var(--admin-bg, #0f0f0f);
    color: var(--admin-text, #e0e0e0);
  }

  button {
    cursor: pointer;
  }

  .job-row {
    justify-content: space-between;
    border-top: 1px solid var(--admin-border, #2a2a2a);
    padding: 0.75rem 0;
    color: var(--admin-text, #e0e0e0);
    text-decoration: none;
  }

  .mini-btn {
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
    background: var(--admin-bg, #0f0f0f);
    color: var(--admin-text-muted, #888);
    cursor: pointer;
    text-transform: uppercase;
    font-size: 0.72rem;
  }

  .mini-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .approve-btn {
    border-color: rgba(134, 239, 172, 0.6);
    color: #86efac;
  }

  .reject-btn {
    border-color: rgba(252, 165, 165, 0.6);
    color: #fca5a5;
  }

  pre {
    white-space: pre-wrap;
    overflow-x: auto;
    color: var(--admin-text, #e0e0e0);
  }
</style>
