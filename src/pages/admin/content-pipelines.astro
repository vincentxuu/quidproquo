---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="內容流程">
  <p class="page-desc">Content Agent Harness MVP：registry、guard、Worker module execution、job timeline 與 artifacts。</p>

  <section class="admin-panel">
    <div class="panel-title">
      <h2>流程清單</h2>
      <button id="refresh" type="button" class="btn">重新整理</button>
    </div>
    <div id="pipeline-list" class="pipeline-grid">載入中...</div>
  </section>

  <section class="admin-panel">
    <h2>最近任務</h2>
    <div id="job-list">載入中...</div>
  </section>

  <section class="admin-panel">
    <h2>執行結果</h2>
    <pre id="run-output">尚未執行流程。</pre>
  </section>
</AdminLayout>

<script is:inline>
  const pipelineList = document.getElementById('pipeline-list');
  const jobList = document.getElementById('job-list');
  const output = document.getElementById('run-output');
  const refresh = document.getElementById('refresh');

  async function load() {
    const res = await fetch('/api/admin/pipelines');
    if (!res.ok) {
      pipelineList.textContent = '無法載入流程。';
      jobList.textContent = '';
      return;
    }
    const data = await res.json();
    const schedules = Array.isArray(data.schedules) ? data.schedules : [];
    renderPipelines(data.pipelines ?? [], schedules);
    renderJobs(data.jobs ?? []);
  }

  function renderPipelines(pipelines, schedules = []) {
    const scheduleByPipeline = new Map();
    for (const schedule of schedules) {
      if (!schedule || typeof schedule.pipelineId !== 'string' || typeof schedule.cron !== 'string') continue;
      const list = scheduleByPipeline.get(schedule.pipelineId) || [];
      list.push(schedule);
      scheduleByPipeline.set(schedule.pipelineId, list);
    }

    pipelineList.replaceChildren();
    if (!pipelines.length) {
      pipelineList.textContent = '目前沒有註冊流程。';
      return;
    }

    for (const pipeline of pipelines) {
      const card = document.createElement('article');
      card.className = 'pipeline-card';

      const header = document.createElement('div');
      header.className = 'pipeline-header';
      const title = document.createElement('h3');
      title.textContent = pipeline.title;
      const status = document.createElement('span');
      status.className = `runtime runtime-${pipeline.runtime}`;
      status.textContent = pipeline.runtime;
      header.append(title, status);

      const id = document.createElement('code');
      id.textContent = pipeline.id;

      const desc = document.createElement('p');
      desc.textContent = pipeline.description;

      const meta = document.createElement('div');
      meta.className = 'pipeline-meta';
      meta.append(
        createPill(pipeline.category),
        createPill(`${pipeline.risk} 風險`),
        createPill(`${pipeline.stages.length} stages`),
      );

      const scheduleBlock = buildScheduleBlock(scheduleByPipeline.get(pipeline.id) || []);

      const inputs = document.createElement('div');
      inputs.className = 'pipeline-inputs';
      const inputControls = [];
      for (const field of pipeline.inputs ?? []) {
        const label = document.createElement('label');
        label.textContent = field.label;
        const input = document.createElement('input');
        input.dataset.inputId = field.id;
        input.type = field.type === 'number' ? 'number' : 'text';
        if (field.type === 'boolean') input.type = 'checkbox';
        if (field.type === 'boolean') {
          input.checked = field.defaultValue === true;
        } else {
          input.placeholder = field.placeholder ?? '';
          input.value = field.defaultValue === undefined ? '' : JSON.stringify(field.defaultValue).replace(/^\"|\"$/g, '');
        }
        label.append(input);
        inputs.append(label);
        inputControls.push({ field, input });
      }

      const button = document.createElement('button');
      button.type = 'button';
      button.className = 'btn';
      button.textContent = '執行流程';
      button.addEventListener('click', () => runPipeline(pipeline, inputControls));

      card.append(header, id, desc, meta, scheduleBlock, inputs, button);
      pipelineList.append(card);
    }
  }

  async function runPipeline(pipeline, inputControls) {
    const input = {};
    for (const { field, input: control } of inputControls) {
      if (field.type === 'boolean') {
        input[field.id] = control.checked;
      } else if (field.type === 'number') {
        input[field.id] = control.value === '' ? undefined : Number(control.value);
      } else if (field.type === 'json') {
        try {
          input[field.id] = control.value ? JSON.parse(control.value) : field.defaultValue;
        } catch {
          output.textContent = `${field.label} 必須是有效 JSON。`;
          return;
        }
      } else {
        input[field.id] = control.value;
      }
    }

    output.textContent = `正在執行 ${pipeline.id}...`;
    const res = await fetch('/api/admin/pipelines', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ pipelineId: pipeline.id, input }),
    });
    const data = await res.json();
    output.textContent = JSON.stringify(data, null, 2);
    await load();
  }

  function renderJobs(jobs) {
    jobList.replaceChildren();
    if (!jobs.length) {
      jobList.textContent = 'No jobs yet.';
      return;
    }

    for (const job of jobs) {
      const row = document.createElement('article');
      row.className = 'job-row';
      const canCancel = job.status === 'queued' || job.status === 'running' || job.status === 'waiting_review';
      const canApprove = job.status === 'waiting_review';

      const link = document.createElement('a');
      link.className = 'mini-btn';
      link.href = `/admin/jobs?id=${encodeURIComponent(job.id)}`;
      link.textContent = '編輯';
      link.title = '前往該 job 明細，直接編輯 artifacts';

      const pipelineName = document.createElement('strong');
      pipelineName.textContent = job.pipeline_id;
      const jobId = document.createElement('code');
      jobId.textContent = job.id;
      const createdAt = document.createElement('time');
      createdAt.textContent = formatTime(job.created_at);

      row.append(
        createStatusPill(job.status),
        link,
        pipelineName,
        jobId,
        createdAt,
      );

      if (canApprove) {
        row.append(createActionButton('核准', 'approve', job.id));
        row.append(createActionButton('拒絕', 'reject', job.id));
      }
      row.append(createActionButton('重跑', 'rerun', job.id));
      row.append(createActionButton('取消', 'cancel', job.id, !canCancel));

      jobList.append(row);
    }
  }

  async function actionJob(jobId, action) {
    if (!jobId || !action) return;
    let reviewNote;
    if (action === 'reject') {
      reviewNote = window.prompt('請輸入 reject 原因（必填）')?.trim()
      if (!reviewNote) {
        window.alert('請輸入 reject 原因後再送出。')
        return
      }
    }
    const res = await fetch(`/api/admin/jobs/${encodeURIComponent(jobId)}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(reviewNote ? { action, reviewNote } : { action }),
    });
    const data = await res.json();
    if (!res.ok) {
      window.alert(data.error || `無法執行任務動作：${action}`);
      return;
    }
    await load();
  }

  function formatTime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function buildScheduleBlock(schedules = []) {
    const block = document.createElement('div');
    block.className = 'pipeline-schedule';
    if (!schedules.length) {
      const none = document.createElement('span');
      none.className = 'pipeline-schedule-none';
      none.textContent = '沒有排程';
      block.append(none);
      return block;
    }

    const heading = document.createElement('strong');
    heading.textContent = '排程';
    block.append(heading);

    const list = document.createElement('ul');
    for (const schedule of schedules) {
      const item = document.createElement('li');
      item.textContent = `${schedule.cron}${schedule.timezone ? ` (${schedule.timezone})` : ''}${schedule.label ? ` / ${schedule.label}` : ''}`;
      list.append(item);
    }
    block.append(list);
    return block;
  }

  function createPill(text) {
    const span = document.createElement('span');
    span.textContent = text;
    return span;
  }

  function createStatusPill(status) {
    const span = document.createElement('span');
    span.className = `job-status status-${String(status || 'unknown')}`;
    span.textContent = status;
    return span;
  }

  function createActionButton(label, action, jobId, disabled = false) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `mini-btn ${action}-btn`;
    button.textContent = label;
    if (disabled) button.disabled = true;
    button.addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      await actionJob(jobId, action);
    });
    return button;
  }

  refresh.addEventListener('click', load);
  load();
</script>
