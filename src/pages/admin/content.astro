---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminButton from '../../components/admin/AdminButton.astro';
import AdminField from '../../components/admin/AdminField.astro';
import AdminMetric from '../../components/admin/AdminMetric.astro';
import AdminPanel from '../../components/admin/AdminPanel.astro';
import AdminState from '../../components/admin/AdminState.astro';
import AdminTable from '../../components/admin/AdminTable.astro';
---

<AdminLayout title="Content">
  <div class="admin-page-intro">
    <p class="admin-page-desc">文章庫、草稿狀態、metadata 缺漏與內容流程檢查。</p>
    <AdminButton href="/admin/settings" icon="settings">編輯內容相關設定</AdminButton>
  </div>

  <section class="inventory-panel flush" aria-labelledby="inventory-title">
    <div class="panel-header">
      <div>
        <p class="section-kicker">Inventory</p>
        <h2 id="inventory-title">文章管理</h2>
      </div>
      <span id="result-count" class="result-count">載入中</span>
    </div>

    <div class="metric-strip" aria-label="Content summary">
      <AdminMetric id="metric-total" label="全部文章" />
      <AdminMetric id="metric-published" label="已發布" />
      <AdminMetric id="metric-drafts" label="草稿" />
      <AdminMetric id="metric-missing" label="Metadata 缺漏" />
    </div>

    <div class="toolbar" role="search">
      <AdminField label="搜尋" class="search-field">
        <input id="post-search" type="search" placeholder="標題、slug、tag" autocomplete="off" />
      </AdminField>
      <AdminField label="分類">
        <select id="category-filter">
          <option value="">全部分類</option>
        </select>
      </AdminField>
      <AdminField label="狀態">
        <select id="status-filter">
          <option value="">全部狀態</option>
          <option value="published">已發布</option>
          <option value="draft">草稿</option>
          <option value="missing">Metadata 缺漏</option>
        </select>
      </AdminField>
    </div>

    <AdminTable minWidth="1050px" flush class="post-table-shell">
        <colgroup>
          <col class="col-post" />
          <col class="col-category" />
          <col class="col-status" />
          <col class="col-date" />
          <col class="col-metadata" />
          <col class="col-actions" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">文章</th>
            <th scope="col">分類</th>
            <th scope="col">狀態</th>
            <th scope="col">日期</th>
            <th scope="col">Metadata</th>
            <th scope="col">操作</th>
          </tr>
        </thead>
        <tbody id="post-rows"></tbody>
    </AdminTable>
    <AdminState id="no-results" hidden>找不到符合條件的文章。試著清除搜尋或改用其他分類。</AdminState>
  </section>

  <div class="content-grid">
    <AdminPanel title="Content Overview" class="content-section">
      <div id="overview" class="overview-cards">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Missing Metadata" class="content-section">
      <div id="missing-metadata" class="issue-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Drafts" class="content-section">
      <div id="drafts" class="post-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Freshness Candidates" description="Posts that may need updates based on age or content type." class="content-section">
      <div id="freshness" class="post-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Internal Link Opportunities" description="Suggested internal links from content ops analysis." class="content-section">
      <div id="link-ops" class="link-list">Loading...</div>
    </AdminPanel>
  </div>
</AdminLayout>

<script is:inline>
  async function loadContent() {
    await Promise.all([
      loadInventory(),
      loadOverview(),
      loadMissingMetadata(),
      loadDrafts(),
      loadFreshness(),
      loadLinkOpportunities(),
    ]);
  }

  async function loadInventory() {
    try {
      const res = await fetch('/api/admin/content/inventory');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      renderInventory(data);
    } catch {
      resultCount.textContent = '載入失敗';
      document.getElementById('post-rows').innerHTML = '<tr><td colspan="6" class="error">Unable to load inventory</td></tr>';
    }
  }

  function renderInventory(data) {
    const posts = data.posts || [];
    const summary = data.summary || {};
    document.getElementById('metric-total').textContent = String(summary.total ?? posts.length);
    document.getElementById('metric-published').textContent = String(summary.published ?? posts.length);
    document.getElementById('metric-drafts').textContent = String(summary.drafts ?? 0);
    document.getElementById('metric-missing').textContent = String(summary.metadataMissing ?? 0);

    categoryFilter.innerHTML = '<option value="">全部分類</option>';
    for (const category of data.categories || []) {
      const option = document.createElement('option');
      option.value = category;
      option.textContent = category;
      categoryFilter.append(option);
    }

    const tbody = document.getElementById('post-rows');
    tbody.innerHTML = posts.map(post => {
      const date = post.date ? new Date(post.date).toLocaleDateString('zh-TW') : 'N/A';
      const dateTime = post.date ? new Date(post.date).toISOString() : '';
      const tags = Array.isArray(post.tags) ? post.tags : [];
      const missing = !post.hasDescription || !post.hasTldr;
      return `
        <tr
          data-title="${escapeAttr(post.title.toLowerCase())}"
          data-slug="${escapeAttr(post.slug.toLowerCase())}"
          data-tags="${escapeAttr(tags.join(' ').toLowerCase())}"
          data-category="${escapeAttr(post.category)}"
          data-status="${post.draft ? 'draft' : 'published'}"
          data-missing="${missing ? 'true' : 'false'}"
        >
          <td class="post-main">
            <a href="${escapeAttr(post.href)}" class="post-title">${escapeHTML(post.title)}</a>
            <span class="post-slug" title="${escapeAttr(post.slug)}">${escapeHTML(post.slug)}</span>
            <span class="post-path" title="${escapeAttr(post.sourcePath)}">${escapeHTML(post.sourcePath)}</span>
          </td>
          <td class="post-category-cell"><span class="pill">${escapeHTML(post.category)}</span></td>
          <td class="post-status-cell">
            <span class="status-pill ${post.draft ? 'is-draft' : 'is-published'}">
              ${post.draft ? '草稿' : '已發布'}
            </span>
          </td>
          <td class="post-date-cell"><time datetime="${dateTime}">${date}</time></td>
          <td>
            <div class="metadata-list">
              <span class="metadata-chip ${post.hasDescription ? '' : 'missing'}">description</span>
              <span class="metadata-chip ${post.hasTldr ? '' : 'missing'}">tldr</span>
              ${post.type ? `<span class="metadata-chip">${escapeHTML(post.type)}</span>` : ''}
            </div>
          </td>
          <td>
            <div class="row-actions">
              <a href="${escapeAttr(post.href)}" class="text-link">查看</a>
              <button type="button" class="text-link copy-path" data-path="${escapeAttr(post.sourcePath)}">複製路徑</button>
            </div>
          </td>
        </tr>
      `;
    }).join('');

    rows = Array.from(document.querySelectorAll('#post-rows tr'));
    bindCopyButtons();
    filterPosts();
  }

  async function loadOverview() {
    const el = document.getElementById('overview');
    try {
      const res = await fetch('/api/admin/content/overview');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      el.innerHTML = `
        <div class="overview-card">
          <span class="overview-value">${data.total ?? 0}</span>
          <span class="overview-label">Total Posts</span>
        </div>
        <div class="overview-card">
          <span class="overview-value">${data.drafts ?? 0}</span>
          <span class="overview-label">Drafts</span>
        </div>
        <div class="overview-card">
          <span class="overview-value">${data.missingType ?? 0}</span>
          <span class="overview-label">Missing Type</span>
        </div>
        <div class="overview-card">
          <span class="overview-value">${data.missingDescription ?? 0}</span>
          <span class="overview-label">Missing Description</span>
        </div>
        <div class="overview-card">
          <span class="overview-value">${data.missingTldr ?? 0}</span>
          <span class="overview-label">Missing TL;DR</span>
        </div>
      `;
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadMissingMetadata() {
    const el = document.getElementById('missing-metadata');
    try {
      const res = await fetch('/api/admin/content/issues');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.issues?.length) {
        el.innerHTML = '<p class="empty">No missing metadata issues found.</p>';
        return;
      }
      el.innerHTML = data.issues.slice(0, 10).map(issue => `
        <div class="issue-item">
          <span class="issue-type">${issue.type}</span>
          <a href="/posts/${issue.slug}" class="issue-slug">${issue.slug}</a>
          <span class="issue-detail">${issue.detail ?? ''}</span>
        </div>
      `).join('');
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadDrafts() {
    const el = document.getElementById('drafts');
    try {
      const res = await fetch('/api/admin/content/drafts');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.drafts?.length) {
        el.innerHTML = '<p class="empty">No drafts found.</p>';
        return;
      }
      el.innerHTML = data.drafts.slice(0, 10).map(draft => `
        <div class="post-item">
          <a href="/posts/${draft.slug}" class="post-slug">${draft.slug}</a>
          <span class="post-date">${formatDate(draft.date)}</span>
        </div>
      `).join('');
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadFreshness() {
    const el = document.getElementById('freshness');
    try {
      const res = await fetch('/api/admin/content/freshness');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.candidates?.length) {
        el.innerHTML = '<p class="empty">No freshness candidates found.</p>';
        return;
      }
      el.innerHTML = data.candidates.slice(0, 10).map(item => `
        <div class="post-item">
          <a href="/posts/${item.slug}" class="post-slug">${item.slug}</a>
          <span class="post-reason">${item.reason ?? 'May need update'}</span>
          <span class="post-date">${formatDate(item.lastModified)}</span>
        </div>
      `).join('');
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadLinkOpportunities() {
    const el = document.getElementById('link-ops');
    try {
      const res = await fetch('/api/admin/content/links');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.opportunities?.length) {
        el.innerHTML = '<p class="empty">No internal link suggestions found.</p>';
        return;
      }
      el.innerHTML = data.opportunities.slice(0, 10).map(opp => `
        <div class="link-item">
          <span class="link-from">${opp.from}</span>
          <span class="link-arrow">→</span>
          <span class="link-to">${opp.to}</span>
          <span class="link-anchor">${opp.anchorText ?? ''}</span>
        </div>
      `).join('');
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  function formatDate(iso) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  const searchInput = document.getElementById('post-search');
  const categoryFilter = document.getElementById('category-filter');
  const statusFilter = document.getElementById('status-filter');
  let rows = Array.from(document.querySelectorAll('#post-rows tr'));
  const resultCount = document.getElementById('result-count');
  const noResults = document.getElementById('no-results');

  function filterPosts() {
    const query = searchInput.value.trim().toLowerCase();
    const category = categoryFilter.value;
    const status = statusFilter.value;
    let visible = 0;

    for (const row of rows) {
      const matchesQuery = !query
        || row.dataset.title?.includes(query)
        || row.dataset.slug?.includes(query)
        || row.dataset.tags?.includes(query);
      const matchesCategory = !category || row.dataset.category === category;
      const matchesStatus = !status
        || row.dataset.status === status
        || (status === 'missing' && row.dataset.missing === 'true');
      const shouldShow = matchesQuery && matchesCategory && matchesStatus;
      row.hidden = !shouldShow;
      if (shouldShow) visible += 1;
    }

    resultCount.textContent = `${visible} 篇`;
    noResults.hidden = visible !== 0;
  }

  searchInput.addEventListener('input', filterPosts);
  categoryFilter.addEventListener('change', filterPosts);
  statusFilter.addEventListener('change', filterPosts);

  loadContent();

  function bindCopyButtons() {
    document.querySelectorAll('.copy-path').forEach((button) => {
      button.addEventListener('click', async () => {
        const path = button.dataset.path;
        if (!path) return;
        await navigator.clipboard.writeText(path);
        const original = button.textContent;
        button.textContent = '已複製';
        setTimeout(() => { button.textContent = original; }, 1400);
      });
    });
  }

  function escapeHTML(value) {
    return String(value ?? '').replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    }[char]));
  }

  function escapeAttr(value) {
    return escapeHTML(value);
  }
</script>

<style>
  .inventory-panel {
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .panel-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1rem 0.25rem;
  }

  .panel-header h2 {
    font-size: 1.05rem;
    margin: 0;
  }

  .result-count {
    border-radius: 999px;
    font-size: 0.85rem;
  }

  .toolbar {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(140px, 220px) minmax(140px, 220px);
    gap: 0.75rem;
    padding: 0 1rem 1rem;
  }

  .post-table-shell :global(.admin-table) {
    min-width: 1050px;
  }

  .col-post { width: 46%; }
  .col-category { width: 8%; }
  .col-status { width: 8%; }
  .col-date { width: 10%; }
  .col-metadata { width: 18%; }
  .col-actions { width: 10%; }

  .post-main {
    min-width: 0;
  }

  .post-title,
  .post-slug,
  .post-path {
    display: block;
  }

  .post-title {
    color: var(--admin-text, #1a1a1a);
    display: -webkit-box;
    font-weight: 650;
    line-height: 1.35;
    max-width: 100%;
    overflow: hidden;
    text-decoration: none;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .post-title:hover {
    color: var(--admin-accent-hover, #2d4a2d);
  }

  .post-slug,
  .post-path {
    overflow: hidden;
    color: var(--admin-text-muted, #4a7c59);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    line-height: 1.35;
    max-width: 100%;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-path {
    color: var(--admin-text-soft, #767676);
  }

  .post-category-cell,
  .post-status-cell,
  .post-date-cell {
    white-space: nowrap;
  }

  .metadata-list,
  .row-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    min-width: 0;
  }

  button.text-link {
    border: none;
    background: transparent;
    padding: 0;
    font-size: inherit;
  }

  .content-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .content-section :global(.admin-panel-header) {
    margin-bottom: 0.75rem;
  }

  .overview-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 1rem;
  }

  .overview-card {
    text-align: center;
  }

  .issue-list, .post-list, .link-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .issue-item, .post-item, .link-item {
    background: var(--admin-surface-subtle, #fbfdfb);
    border: 1px solid var(--admin-border, #d1e8d1);
    border-radius: var(--admin-radius, 8px);
    padding: 0.75rem 1rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .issue-type {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    background: var(--admin-border, #2a2a2a);
    border-radius: 4px;
    color: var(--admin-text-muted, #888);
  }

  .issue-slug, .post-slug {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.85rem;
    color: var(--admin-accent, #4a9e6a);
    min-width: 0;
    overflow: hidden;
    text-decoration: none;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .issue-slug:hover, .post-slug:hover {
    text-decoration: underline;
  }

  .issue-detail, .post-reason, .post-date {
    font-size: 0.8rem;
    color: var(--admin-text-muted, #888);
  }

  .post-date {
    margin-left: auto;
    white-space: nowrap;
  }

  .link-from, .link-to {
    font-family: monospace;
    font-size: 0.85rem;
    color: var(--admin-text, #1a1a1a);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .link-arrow {
    color: var(--admin-text-muted, #888);
  }

  .link-anchor {
    font-size: 0.8rem;
    color: var(--admin-accent, #3b82f6);
    font-style: italic;
  }

  #no-results {
    padding: 1rem;
  }

  @media (max-width: 900px) {
    .content-grid {
      grid-template-columns: 1fr;
    }

    .metric-strip,
    .toolbar {
      grid-template-columns: 1fr 1fr;
    }

    .search-field {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .panel-header {
      display: grid;
    }

    .metric-strip,
    .toolbar {
      grid-template-columns: 1fr;
    }
  }
</style>
