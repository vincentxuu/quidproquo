---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import AdminButton from '../../components/admin/AdminButton.astro';
import AdminField from '../../components/admin/AdminField.astro';
import AdminMetric from '../../components/admin/AdminMetric.astro';
import AdminPanel from '../../components/admin/AdminPanel.astro';
import AdminState from '../../components/admin/AdminState.astro';
import AdminTable from '../../components/admin/AdminTable.astro';
---

<AdminLayout title="Content">
  <div class="admin-page-intro">
    <p class="admin-page-desc">文章庫、草稿狀態、metadata 缺漏與內容流程檢查。</p>
    <AdminButton href="/admin/settings" icon="settings">編輯內容相關設定</AdminButton>
  </div>

  <section class="inventory-panel flush" aria-labelledby="inventory-title">
    <div class="panel-header">
      <div>
        <p class="section-kicker">Inventory</p>
        <h2 id="inventory-title">文章管理</h2>
      </div>
      <span id="result-count" class="result-count">載入中</span>
    </div>

    <div class="metric-strip" aria-label="Content summary">
      <AdminMetric id="metric-total" label="全部文章" />
      <AdminMetric id="metric-published" label="已發布" />
      <AdminMetric id="metric-drafts" label="草稿" />
      <AdminMetric id="metric-missing" label="Metadata 缺漏" />
    </div>

    <div class="toolbar" role="search">
      <AdminField label="搜尋" class="search-field">
        <input id="post-search" type="search" placeholder="標題、slug、tag" autocomplete="off" />
      </AdminField>
      <AdminField label="分類">
        <select id="category-filter">
          <option value="">全部分類</option>
        </select>
      </AdminField>
      <AdminField label="狀態">
        <select id="status-filter">
          <option value="">全部狀態</option>
          <option value="published">已發布</option>
          <option value="draft">草稿</option>
          <option value="missing">Metadata 缺漏</option>
        </select>
      </AdminField>
    </div>

    <AdminTable minWidth="1050px" flush class="post-table-shell">
        <colgroup>
          <col class="col-post" />
          <col class="col-category" />
          <col class="col-status" />
          <col class="col-date" />
          <col class="col-metadata" />
          <col class="col-actions" />
        </colgroup>
        <thead>
          <tr>
            <th scope="col">文章</th>
            <th scope="col">分類</th>
            <th scope="col">狀態</th>
            <th scope="col">日期</th>
            <th scope="col">Metadata</th>
            <th scope="col">操作</th>
          </tr>
        </thead>
        <tbody id="post-rows"></tbody>
    </AdminTable>
    <AdminState id="no-results" hidden>找不到符合條件的文章。試著清除搜尋或改用其他分類。</AdminState>
  </section>

  <div class="content-grid">
    <AdminPanel title="Content Overview" class="content-section">
      <div id="overview" class="overview-cards">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Missing Metadata" class="content-section">
      <div id="missing-metadata" class="issue-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Drafts" class="content-section">
      <div id="drafts" class="post-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Freshness Candidates" description="Posts that may need updates based on age or content type." class="content-section">
      <div id="freshness" class="post-list">Loading...</div>
    </AdminPanel>

    <AdminPanel title="Internal Link Opportunities" description="Suggested internal links from content ops analysis." class="content-section">
      <div id="link-ops" class="link-list">Loading...</div>
    </AdminPanel>
  </div>
</AdminLayout>

<script is:inline>
  function createOverviewValue(label, value) {
    const item = document.createElement('div');
    item.className = 'overview-card';
    const v = document.createElement('span');
    v.className = 'overview-value';
    v.textContent = String(value ?? 0);
    const l = document.createElement('span');
    l.className = 'overview-label';
    l.textContent = label;
    item.append(v, l);
    return item;
  }

  function createPostRow(post) {
    const date = post.date ? new Date(post.date).toLocaleDateString('zh-TW') : 'N/A';
    const dateTime = post.date ? new Date(post.date).toISOString() : '';
    const tags = Array.isArray(post.tags) ? post.tags : [];
    const missing = !post.hasDescription || !post.hasTldr;

    const row = document.createElement('tr');
    row.dataset.title = String(post.title ?? '').toLowerCase();
    row.dataset.slug = String(post.slug ?? '').toLowerCase();
    row.dataset.tags = tags.join(' ').toLowerCase();
    row.dataset.category = String(post.category ?? '');
    row.dataset.status = post.draft ? 'draft' : 'published';
    row.dataset.missing = missing ? 'true' : 'false';

    const main = document.createElement('td');
    main.className = 'post-main';
    const link = document.createElement('a');
    link.href = String(post.href ?? '#');
    link.className = 'post-title';
    link.textContent = String(post.title ?? '');
    const slug = document.createElement('span');
    slug.className = 'post-slug';
    slug.title = String(post.slug ?? '');
    slug.textContent = String(post.slug ?? '');
    const source = document.createElement('span');
    source.className = 'post-path';
    source.title = String(post.sourcePath ?? '');
    source.textContent = String(post.sourcePath ?? '');
    main.append(link, slug, source);

    const category = document.createElement('td');
    category.className = 'post-category-cell';
    const categoryChip = document.createElement('span');
    categoryChip.className = 'pill';
    categoryChip.textContent = String(post.category ?? '');
    category.append(categoryChip);

    const statusCell = document.createElement('td');
    statusCell.className = 'post-status-cell';
    const status = document.createElement('span');
    status.className = `status-pill ${post.draft ? 'is-draft' : 'is-published'}`;
    status.textContent = post.draft ? '草稿' : '已發布';
    statusCell.append(status);

    const dateCell = document.createElement('td');
    dateCell.className = 'post-date-cell';
    const time = document.createElement('time');
    time.dateTime = dateTime;
    time.textContent = date;
    dateCell.append(time);

    const metadata = document.createElement('td');
    const metadataList = document.createElement('div');
    metadataList.className = 'metadata-list';
    const description = document.createElement('span');
    description.className = `metadata-chip ${post.hasDescription ? '' : 'missing'}`.trim();
    description.textContent = 'description';
    const tldr = document.createElement('span');
    tldr.className = `metadata-chip ${post.hasTldr ? '' : 'missing'}`.trim();
    tldr.textContent = 'tldr';
    metadataList.append(description, tldr);
    if (post.type) {
      const typeChip = document.createElement('span');
      typeChip.className = 'metadata-chip';
      typeChip.textContent = String(post.type);
      metadataList.append(typeChip);
    }
    metadata.append(metadataList);

    const actionsCell = document.createElement('td');
    const actions = document.createElement('div');
    actions.className = 'row-actions';
    const view = document.createElement('a');
    view.href = String(post.href ?? '#');
    view.className = 'text-link';
    view.textContent = '查看';
    const copy = document.createElement('button');
    copy.type = 'button';
    copy.className = 'text-link copy-path';
    copy.dataset.path = String(post.sourcePath ?? '');
    copy.textContent = '複製路徑';
    actions.append(view, copy);
    actionsCell.append(actions);

    row.append(main, category, statusCell, dateCell, metadata, actionsCell);
    return row;
  }

  function createIssueItem(issue) {
    const item = document.createElement('div');
    item.className = 'issue-item';
    const type = document.createElement('span');
    type.className = 'issue-type';
    type.textContent = String(issue.type ?? '');
    const slug = document.createElement('a');
    slug.className = 'issue-slug';
    slug.href = `/posts/${issue.slug ?? ''}`;
    slug.textContent = issue.slug ?? '';
    const detail = document.createElement('span');
    detail.className = 'issue-detail';
    detail.textContent = issue.detail ?? '';
    item.append(type, slug, detail);
    return item;
  }

  function createPostItem(post, includeReason = false) {
    const item = document.createElement('div');
    item.className = 'post-item';
    const slug = document.createElement('a');
    slug.className = 'post-slug';
    slug.href = `/posts/${post.slug ?? ''}`;
    slug.textContent = post.slug ?? '';
    item.append(slug);

    if (includeReason) {
      const reason = document.createElement('span');
      reason.className = 'post-reason';
      reason.textContent = post.reason ?? 'May need update';
      item.append(reason);
    }

    const date = document.createElement('span');
    date.className = 'post-date';
    date.textContent = formatDate(post.lastModified || post.date);
    item.append(date);
    return item;
  }

  function createLinkItem(link) {
    const item = document.createElement('div');
    item.className = 'link-item';
    const from = document.createElement('span');
    from.className = 'link-from';
    from.textContent = link.from ?? '';
    const arrow = document.createElement('span');
    arrow.className = 'link-arrow';
    arrow.textContent = '→';
    const to = document.createElement('span');
    to.className = 'link-to';
    to.textContent = link.to ?? '';
    const anchor = document.createElement('span');
    anchor.className = 'link-anchor';
    anchor.textContent = link.anchorText ?? '';
    item.append(from, arrow, to, anchor);
    return item;
  }

  function setLoadingState(el, message, tone = 'error') {
    const p = document.createElement('p');
    p.className = tone;
    p.textContent = message;
    el.replaceChildren(p);
  }

  function bindCopyButtons() {
    document.querySelectorAll('.copy-path').forEach((button) => {
      button.addEventListener('click', async () => {
        const path = button.dataset.path;
        if (!path) return;
        await navigator.clipboard.writeText(path);
        const original = button.textContent;
        button.textContent = '已複製';
        setTimeout(() => {
          button.textContent = original;
        }, 1400);
      });
    });
  }

  async function loadContent() {
    await Promise.all([
      loadInventory(),
      loadOverview(),
      loadMissingMetadata(),
      loadDrafts(),
      loadFreshness(),
      loadLinkOpportunities(),
    ]);
  }

  async function loadInventory() {
    try {
      const res = await fetch('/api/admin/content/inventory');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      renderInventory(data);
    } catch {
      resultCount.textContent = '載入失敗';
      const row = document.createElement('tr');
      const col = document.createElement('td');
      col.colSpan = 6;
      col.className = 'error';
      col.textContent = 'Unable to load inventory';
      row.append(col);
      document.getElementById('post-rows').replaceChildren(row);
    }
  }

  function renderInventory(data) {
    const posts = data.posts || [];
    const summary = data.summary || {};

    document.getElementById('metric-total').textContent = String(summary.total ?? posts.length);
    document.getElementById('metric-published').textContent = String(summary.published ?? posts.length);
    document.getElementById('metric-drafts').textContent = String(summary.drafts ?? 0);
    document.getElementById('metric-missing').textContent = String(summary.metadataMissing ?? 0);

    categoryFilter.textContent = '';
    const allCategory = document.createElement('option');
    allCategory.value = '';
    allCategory.textContent = '全部分類';
    categoryFilter.append(allCategory);
    for (const category of data.categories || []) {
      const option = document.createElement('option');
      option.value = category;
      option.textContent = category;
      categoryFilter.append(option);
    }

    const tbody = document.getElementById('post-rows');
    const frag = document.createDocumentFragment();
    for (const post of posts) {
      frag.append(createPostRow(post));
    }
    tbody.replaceChildren(frag);

    rows = Array.from(document.querySelectorAll('#post-rows tr'));
    bindCopyButtons();
    filterPosts();
  }

  async function loadOverview() {
    const el = document.getElementById('overview');
    try {
      const res = await fetch('/api/admin/content/overview');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      const frag = document.createDocumentFragment();
      frag.append(
        createOverviewValue('Total Posts', data.total ?? 0),
        createOverviewValue('Drafts', data.drafts ?? 0),
        createOverviewValue('Missing Type', data.missingType ?? 0),
        createOverviewValue('Missing Description', data.missingDescription ?? 0),
        createOverviewValue('Missing TL;DR', data.missingTldr ?? 0),
      );
      el.replaceChildren(frag);
    } catch {
      setLoadingState(el, 'Unable to load', 'error');
    }
  }

  async function loadMissingMetadata() {
    const el = document.getElementById('missing-metadata');
    try {
      const res = await fetch('/api/admin/content/issues');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.issues?.length) {
        setLoadingState(el, 'No missing metadata issues found.', 'empty');
        return;
      }
      const frag = document.createDocumentFragment();
      for (const issue of data.issues.slice(0, 10)) {
        frag.append(createIssueItem(issue));
      }
      el.replaceChildren(frag);
    } catch {
      setLoadingState(el, 'Unable to load', 'error');
    }
  }

  async function loadDrafts() {
    const el = document.getElementById('drafts');
    try {
      const res = await fetch('/api/admin/content/drafts');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.drafts?.length) {
        setLoadingState(el, 'No drafts found.', 'empty');
        return;
      }
      const frag = document.createDocumentFragment();
      for (const draft of data.drafts.slice(0, 10)) {
        frag.append(createPostItem(draft));
      }
      el.replaceChildren(frag);
    } catch {
      setLoadingState(el, 'Unable to load', 'error');
    }
  }

  async function loadFreshness() {
    const el = document.getElementById('freshness');
    try {
      const res = await fetch('/api/admin/content/freshness');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.candidates?.length) {
        setLoadingState(el, 'No freshness candidates found.', 'empty');
        return;
      }
      const frag = document.createDocumentFragment();
      for (const item of data.candidates.slice(0, 10)) {
        frag.append(createPostItem(item, true));
      }
      el.replaceChildren(frag);
    } catch {
      setLoadingState(el, 'Unable to load', 'error');
    }
  }

  async function loadLinkOpportunities() {
    const el = document.getElementById('link-ops');
    try {
      const res = await fetch('/api/admin/content/links');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.opportunities?.length) {
        setLoadingState(el, 'No internal link suggestions found.', 'empty');
        return;
      }
      const frag = document.createDocumentFragment();
      for (const opp of data.opportunities.slice(0, 10)) {
        frag.append(createLinkItem(opp));
      }
      el.replaceChildren(frag);
    } catch {
      setLoadingState(el, 'Unable to load', 'error');
    }
  }

  function formatDate(iso) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  const searchInput = document.getElementById('post-search');
  const categoryFilter = document.getElementById('category-filter');
  const statusFilter = document.getElementById('status-filter');
  let rows = Array.from(document.querySelectorAll('#post-rows tr'));
  const resultCount = document.getElementById('result-count');
  const noResults = document.getElementById('no-results');

  function filterPosts() {
    const query = searchInput.value.trim().toLowerCase();
    const category = categoryFilter.value;
    const status = statusFilter.value;
    let visible = 0;

    for (const row of rows) {
      const matchesQuery = !query
        || row.dataset.title?.includes(query)
        || row.dataset.slug?.includes(query)
        || row.dataset.tags?.includes(query);
      const matchesCategory = !category || row.dataset.category === category;
      const matchesStatus = !status
        || row.dataset.status === status
        || (status === 'missing' && row.dataset.missing === 'true');
      const shouldShow = matchesQuery && matchesCategory && matchesStatus;
      row.hidden = !shouldShow;
      if (shouldShow) visible += 1;
    }

    resultCount.textContent = `${visible} 篇`;
    noResults.hidden = visible !== 0;
  }

  searchInput.addEventListener('input', filterPosts);
  categoryFilter.addEventListener('change', filterPosts);
  statusFilter.addEventListener('change', filterPosts);

  loadContent();
</script>


