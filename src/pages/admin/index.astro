---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import Icons from '../../components/Icons.astro';
import AdminButton from '../../components/admin/AdminButton.astro';
import AdminPanel from '../../components/admin/AdminPanel.astro';
---

<AdminLayout title="Dashboard">
  <section class="dashboard-hero">
    <div>
      <p class="hero-kicker">Operations Snapshot</p>
      <h1>內容、RAG 與任務狀態總覽</h1>
      <p>快速確認索引健康度、內容缺漏與近期 pipeline 執行結果。</p>
    </div>
    <div class="hero-actions">
      <AdminButton href="/admin/content" icon="file-text">
        Content Ops
      </AdminButton>
      <AdminButton href="/admin/rag" variant="primary" icon="brain-circuit">
        RAG Console
      </AdminButton>
    </div>
  </section>

  <div class="dashboard-grid">
    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="server-cog" size={16} /></span>
        <h3>System Status</h3>
      </div>
      <div id="system-status" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="brain-circuit" size={16} /></span>
        <h3>RAG Health</h3>
      </div>
      <div id="rag-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="bar-chart-3" size={16} /></span>
        <h3>Index Health</h3>
      </div>
      <div id="index-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="file-text" size={16} /></span>
        <h3>Content Health</h3>
      </div>
      <div id="content-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card wide table-card">
      <div class="section-heading">
        <div>
          <h3>Recent Jobs</h3>
          <p>最近 5 筆 pipeline 執行紀錄。</p>
        </div>
        <a href="/admin/jobs" class="icon-button" title="開啟任務列表">
          <Icons name="arrow-up-right" size={15} />
        </a>
      </div>
      <div id="recent-jobs" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card wide">
      <div class="section-heading">
        <div>
          <h3>Quick Actions</h3>
          <p>常用工作入口。</p>
        </div>
      </div>
      <div class="quick-actions">
        <a href="/admin/ops" class="action-btn"><Icons name="refresh-cw" size={15} />Run Jobs</a>
        <a href="/admin/rag" class="action-btn"><Icons name="settings" size={15} />RAG Settings</a>
        <a href="/admin/content" class="action-btn"><Icons name="file-text" size={15} />Content Ops</a>
        <a href="/admin/stats" class="action-btn"><Icons name="bar-chart-3" size={15} />View Stats</a>
      </div>
    </AdminPanel>
  </div>
</AdminLayout>

<script is:inline>
  function clearNode(el) {
    el.textContent = '';
  }

  function makeLine(label, value) {
    const row = document.createElement('div');
    row.className = 'metric-line';

    const labelEl = document.createElement('span');
    labelEl.textContent = label;
    const valueEl = document.createElement('strong');
    valueEl.textContent = String(value);

    row.append(labelEl, valueEl);
    return row;
  }

  function renderStatusList(statuses) {
    const frag = document.createDocumentFragment();
    if (!statuses?.length) {
      const empty = document.createElement('p');
      empty.className = 'empty';
      empty.textContent = 'No status data';
      frag.append(empty);
      return frag;
    }
    for (const s of statuses) {
      const row = document.createElement('div');
      row.className = 'status-item';
      const dot = document.createElement('span');
      dot.className = `status-indicator ${s?.ok ? 'ok' : 'error'}`;
      const name = document.createElement('span');
      name.textContent = s?.name ?? '';
      const result = document.createElement('strong');
      result.textContent = s?.ok ? 'OK' : 'Issue';
      row.append(dot, name, result);
      frag.append(row);
    }
    return frag;
  }

  function renderJobRows(jobs) {
    const frag = document.createDocumentFragment();
    for (const job of jobs) {
      const row = document.createElement('article');
      row.className = 'job-row';
      const status = document.createElement('span');
      status.className = `job-status status-${job.status}`;
      status.textContent = job.status;

      const pipeline = document.createElement('span');
      pipeline.className = 'job-pipeline';
      pipeline.textContent = job.pipeline_id;

      const id = document.createElement('code');
      id.textContent = job.id;

      const time = document.createElement('span');
      time.className = 'job-time';
      time.textContent = formatTime(job.created_at);

      row.append(status, pipeline, id, time);
      frag.append(row);
    }
    return frag;
  }

  function setLoadError(target, message) {
    const p = document.createElement('p');
    p.className = 'error';
    p.textContent = message;
    clearNode(target);
    target.append(p);
  }

  async function loadDashboard() {
    await Promise.all([
      loadSystemStatus(),
      loadRAGHealth(),
      loadIndexHealth(),
      loadContentHealth(),
      loadRecentJobs(),
    ]);
  }

  async function loadSystemStatus() {
    const el = document.getElementById('system-status');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      clearNode(el);
      el.append(renderStatusList(data.statuses));
    } catch {
      setLoadError(el, 'Unable to load');
    }
  }

  async function loadRAGHealth() {
    const el = document.getElementById('rag-health');
    try {
      const res = await fetch('/api/admin/rag');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      const recentTraces = data.traces?.slice(0, 5) || [];
      clearNode(el);
      el.append(
        makeLine('Queries (7d)', recentTraces.length),
        makeLine('Recent Errors', recentTraces.filter((t) => t.output_summary?.includes('error')).length),
      );
      const link = document.createElement('a');
      link.href = '/admin/rag';
      link.className = 'card-link';
      link.textContent = 'View RAG Settings ->';
      el.append(link);
    } catch {
      setLoadError(el, 'Unable to load');
    }
  }

  async function loadIndexHealth() {
    const el = document.getElementById('index-health');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      clearNode(el);
      el.append(
        makeLine('Post Chunks', data.index?.postChunks ?? 'N/A'),
        makeLine('Doc Chunks', data.index?.docChunks ?? 'N/A'),
        makeLine('Last Embed', data.index?.lastEmbed ?? 'Never'),
      );
    } catch {
      setLoadError(el, 'Unable to load');
    }
  }

  async function loadContentHealth() {
    const el = document.getElementById('content-health');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      clearNode(el);
      el.append(
        makeLine('Total Posts', data.content?.total ?? 'N/A'),
        makeLine('Drafts', data.content?.drafts ?? 'N/A'),
        makeLine('Missing Type', data.content?.missingType ?? 'N/A'),
      );
      const link = document.createElement('a');
      link.href = '/admin/content';
      link.className = 'card-link';
      link.textContent = 'View Content ->';
      el.append(link);
    } catch {
      setLoadError(el, 'Unable to load');
    }
  }

  async function loadRecentJobs() {
    const el = document.getElementById('recent-jobs');
    try {
      const res = await fetch('/api/admin/jobs?limit=5');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.jobs?.length) {
        const empty = document.createElement('p');
        empty.className = 'empty';
        empty.textContent = 'No jobs yet';
        clearNode(el);
        el.append(empty);
        return;
      }
      clearNode(el);
      el.append(renderJobRows(data.jobs));
    } catch {
      setLoadError(el, 'Unable to load');
    }
  }

  function formatTime(iso) {
    if (!iso) return 'N/A';
    const d = new Date(iso);
    return d.toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  loadDashboard();
</script>
