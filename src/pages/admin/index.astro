---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import Icons from '../../components/Icons.astro';
import AdminButton from '../../components/admin/AdminButton.astro';
import AdminPanel from '../../components/admin/AdminPanel.astro';
---

<AdminLayout title="Dashboard">
  <section class="dashboard-hero">
    <div>
      <p class="hero-kicker">Operations Snapshot</p>
      <h1>內容、RAG 與任務狀態總覽</h1>
      <p>快速確認索引健康度、內容缺漏與近期 pipeline 執行結果。</p>
    </div>
    <div class="hero-actions">
      <AdminButton href="/admin/content" icon="file-text">
        Content Ops
      </AdminButton>
      <AdminButton href="/admin/rag" variant="primary" icon="brain-circuit">
        RAG Console
      </AdminButton>
    </div>
  </section>

  <div class="dashboard-grid">
    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="server-cog" size={16} /></span>
        <h3>System Status</h3>
      </div>
      <div id="system-status" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="brain-circuit" size={16} /></span>
        <h3>RAG Health</h3>
      </div>
      <div id="rag-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="bar-chart-3" size={16} /></span>
        <h3>Index Health</h3>
      </div>
      <div id="index-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card metric-card">
      <div class="card-head">
        <span class="card-icon"><Icons name="file-text" size={16} /></span>
        <h3>Content Health</h3>
      </div>
      <div id="content-health" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card wide table-card">
      <div class="section-heading">
        <div>
          <h3>Recent Jobs</h3>
          <p>最近 5 筆 pipeline 執行紀錄。</p>
        </div>
        <a href="/admin/jobs" class="icon-button" title="開啟任務列表">
          <Icons name="arrow-up-right" size={15} />
        </a>
      </div>
      <div id="recent-jobs" class="status-content">Loading...</div>
    </AdminPanel>

    <AdminPanel class="status-card wide">
      <div class="section-heading">
        <div>
          <h3>Quick Actions</h3>
          <p>常用工作入口。</p>
        </div>
      </div>
      <div class="quick-actions">
        <a href="/admin/ops" class="action-btn"><Icons name="refresh-cw" size={15} />Run Jobs</a>
        <a href="/admin/rag" class="action-btn"><Icons name="settings" size={15} />RAG Settings</a>
        <a href="/admin/content" class="action-btn"><Icons name="file-text" size={15} />Content Ops</a>
        <a href="/admin/stats" class="action-btn"><Icons name="bar-chart-3" size={15} />View Stats</a>
      </div>
    </AdminPanel>
  </div>
</AdminLayout>

<script is:inline>
  async function loadDashboard() {
    await Promise.all([
      loadSystemStatus(),
      loadRAGHealth(),
      loadIndexHealth(),
      loadContentHealth(),
      loadRecentJobs(),
    ]);
  }

  async function loadSystemStatus() {
    const el = document.getElementById('system-status');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      el.innerHTML = renderStatusList(data.statuses);
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadRAGHealth() {
    const el = document.getElementById('rag-health');
    try {
      const res = await fetch('/api/admin/rag');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      const recentTraces = data.traces?.slice(0, 5) || [];
      el.innerHTML = `
        <div class="metric-line"><span>Queries (7d)</span><strong>${recentTraces.length}</strong></div>
        <div class="metric-line"><span>Recent Errors</span><strong>${recentTraces.filter(t => t.output_summary?.includes('error')).length}</strong></div>
        <a href="/admin/rag" class="card-link">View RAG Settings -></a>
      `;
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadIndexHealth() {
    const el = document.getElementById('index-health');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      el.innerHTML = `
        <div class="metric-line"><span>Post Chunks</span><strong>${data.index?.postChunks ?? 'N/A'}</strong></div>
        <div class="metric-line"><span>Doc Chunks</span><strong>${data.index?.docChunks ?? 'N/A'}</strong></div>
        <div class="metric-line"><span>Last Embed</span><strong>${data.index?.lastEmbed ?? 'Never'}</strong></div>
      `;
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadContentHealth() {
    const el = document.getElementById('content-health');
    try {
      const res = await fetch('/api/admin/status');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      el.innerHTML = `
        <div class="metric-line"><span>Total Posts</span><strong>${data.content?.total ?? 'N/A'}</strong></div>
        <div class="metric-line"><span>Drafts</span><strong>${data.content?.drafts ?? 'N/A'}</strong></div>
        <div class="metric-line"><span>Missing Type</span><strong>${data.content?.missingType ?? 'N/A'}</strong></div>
        <a href="/admin/content" class="card-link">View Content -></a>
      `;
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  async function loadRecentJobs() {
    const el = document.getElementById('recent-jobs');
    try {
      const res = await fetch('/api/admin/jobs?limit=5');
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      if (!data.jobs?.length) {
        el.innerHTML = '<p class="empty">No jobs yet</p>';
        return;
      }
      el.innerHTML = data.jobs.map(job => `
        <div class="job-row">
          <span class="job-status status-${job.status}">${job.status}</span>
          <span class="job-pipeline">${job.pipeline_id}</span>
          <code>${job.id}</code>
          <span class="job-time">${formatTime(job.created_at)}</span>
        </div>
      `).join('');
    } catch {
      el.innerHTML = '<p class="error">Unable to load</p>';
    }
  }

  function renderStatusList(statuses) {
    if (!statuses?.length) return '<p class="empty">No status data</p>';
    return statuses.map(s => `
      <div class="status-item">
        <span class="status-indicator ${s.ok ? 'ok' : 'error'}"></span>
        <span>${s.name}</span>
        <strong>${s.ok ? 'OK' : 'Issue'}</strong>
      </div>
    `).join('');
  }

  function formatTime(iso) {
    if (!iso) return 'N/A';
    const d = new Date(iso);
    return d.toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  loadDashboard();
</script>

<style>
  .dashboard-hero {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--admin-border);
    border-radius: var(--admin-radius);
    background: linear-gradient(180deg, var(--admin-surface) 0%, var(--brand-50) 100%);
    padding: 1.1rem;
    box-shadow: var(--admin-shadow);
  }

  .hero-kicker {
    margin: 0 0 0.2rem;
    color: var(--admin-text-muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .dashboard-hero h1 {
    margin: 0;
    color: var(--admin-text);
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.25;
    letter-spacing: 0;
  }

  .dashboard-hero p {
    margin: 0.35rem 0 0;
    color: var(--admin-text-muted);
    font-size: 0.9rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .status-card.wide {
    grid-column: span 4;
  }

  .card-head,
  .section-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.9rem;
  }

  .status-card h3 {
    font-size: 0.92rem;
    font-weight: 750;
    margin: 0;
  }

  .status-content {
    font-size: 0.9rem;
  }

  .status-content p {
    margin: 0.5rem 0;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 34px;
    border-top: 1px solid var(--admin-border);
    padding: 0.45rem 0;
  }

  .status-item:first-child {
    border-top: none;
  }

  .status-item strong {
    margin-left: auto;
    color: var(--admin-text-muted);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .status-indicator {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .status-indicator.ok {
    background: var(--admin-success);
  }

  .status-indicator.error {
    background: var(--admin-danger);
  }

  .card-link {
    display: inline-block;
    margin-top: 0.75rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 650;
  }

  .card-link:hover {
    text-decoration: underline;
  }

  .quick-actions {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .quick-actions .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 42px;
    padding: 0.6rem 0.8rem;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 650;
  }

  .job-row {
    display: grid;
    grid-template-columns: 110px minmax(160px, 1fr) minmax(140px, 0.9fr) 150px;
    align-items: center;
    gap: 0.75rem;
    min-height: 44px;
    padding: 0.55rem 0.75rem;
    border-top: 1px solid var(--admin-border);
    min-width: 0;
  }

  .job-row:first-child {
    border-top: none;
  }

  .job-pipeline {
    color: var(--admin-text);
    font-family: monospace;
    font-size: 0.85rem;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .job-row code {
    overflow: hidden;
    color: var(--admin-text-soft);
    font-size: 0.76rem;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .job-time {
    color: var(--admin-text-muted);
    font-size: 0.8rem;
    text-align: right;
    white-space: nowrap;
  }

  .metric-line {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    min-height: 32px;
    border-top: 1px solid var(--admin-border);
    padding: 0.42rem 0;
    min-width: 0;
  }

  .metric-line span,
  .metric-line strong {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .metric-line:first-child {
    border-top: none;
  }

  .metric-line span {
    color: var(--admin-text-muted);
    font-size: 0.8rem;
  }

  .metric-line strong {
    color: var(--admin-text);
    font-size: 0.95rem;
  }

  @media (max-width: 1120px) {
    .dashboard-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .status-card.wide {
      grid-column: span 2;
    }

    .quick-actions {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 768px) {
    .dashboard-hero {
      align-items: stretch;
      flex-direction: column;
    }

    .hero-actions {
      justify-content: stretch;
    }

    .command-button {
      justify-content: center;
      flex: 1;
    }

    .dashboard-grid,
    .quick-actions {
      grid-template-columns: 1fr;
    }

    .status-card.wide {
      grid-column: span 1;
    }

    .job-row {
      grid-template-columns: 1fr;
      align-items: start;
      gap: 0.3rem;
    }

    .job-time {
      text-align: left;
    }
  }
</style>
