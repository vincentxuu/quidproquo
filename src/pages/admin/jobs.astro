---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Jobs">
  <section class="admin-panel">
    <h2>Dead Letter Queue</h2>
    <div id="dead-letter-list">Loading...</div>
  </section>

  <section class="admin-panel">
    <h2>Job Timeline</h2>
    <div id="job-detail">Loading...</div>
  </section>

  <section class="admin-panel">
    <h2>Admin SQL 快查</h2>
    <div id="admin-sql-queries">選取 job 後顯示可複製查詢。</div>
  </section>

<section class="admin-panel">
  <h2>Artifacts</h2>
  <div id="artifact-list">Loading...</div>
</section>
</AdminLayout>

<script is:inline>
  const detail = document.getElementById('job-detail');
  const artifactList = document.getElementById('artifact-list');
  const deadLetterList = document.getElementById('dead-letter-list');
  const id = new URL(location.href).searchParams.get('id');
  const actions = document.createElement('div');
  let currentStatus = '';
  const artifactSqlPrefix = 'SELECT id, job_id, step_id, type, name, path, content_json, created_at FROM admin_job_artifacts';

  async function load() {
    if (!id) {
      await loadList();
      return;
    }

    deadLetterList && (deadLetterList.textContent = '');

    const res = await fetch(`/api/admin/jobs/${encodeURIComponent(id)}`);
    if (!res.ok) {
      detail.textContent = 'Unable to load job.';
      artifactList.textContent = '';
      return;
    }
    const data = await res.json();
    currentStatus = data.job?.status ?? '';
    renderDetail(data.job, data.steps ?? []);
    renderActions(data.job?.status);
    renderArtifacts(data.artifacts ?? []);
    renderAdminQueries(data.job?.id, data.artifacts ?? []);
  }

  async function loadList() {
    const [jobsRes, deadRes] = await Promise.all([
      fetch('/api/admin/jobs?limit=50'),
      fetch('/api/admin/jobs?limit=50&status=dead_letter'),
    ])

    if (!jobsRes.ok) {
      detail.textContent = 'Unable to load jobs.';
      return;
    }
    const jobsData = await jobsRes.json();
    const deadData = deadRes.ok ? await deadRes.json() : { jobs: [] };

    renderJobsList(detail, jobsData.jobs ?? []);
    renderJobsList(deadLetterList, deadData.jobs ?? []);
    artifactList.textContent = 'Select a job to inspect artifacts.';
  }

  function renderJobsList(container, jobs) {
    container.replaceChildren();
    if (!jobs.length) {
      container.textContent = 'No jobs.';
      return;
    }

    for (const job of jobs) {
      const row = document.createElement('article');
      row.className = 'job-row';
      const canCancel = job.status === 'queued' || job.status === 'running' || job.status === 'waiting_review';
      const canApprove = job.status === 'waiting_review';
      const status = document.createElement('span');
      status.className = `job-status status-${job.status}`;
      status.textContent = job.status;

      const pipelineName = document.createElement('strong');
      pipelineName.textContent = job.pipeline_id;

      const jobId = document.createElement('code');
      jobId.textContent = job.id;

      const createdAt = document.createElement('time');
      createdAt.textContent = formatTime(job.created_at);

      row.append(status, pipelineName, jobId, createdAt);

      if (canApprove) {
        row.append(createMiniActionButton('Approve', 'approve', job.id, job.id));
        row.append(createMiniActionButton('Reject', 'reject', job.id, job.id));
      }
      row.append(createMiniActionButton('Rerun', 'rerun', job.id, job.id));
      row.append(createMiniActionButton('Cancel', 'cancel', job.id, job.id, !canCancel));
      row.addEventListener('click', (event) => {
        if (event.target instanceof HTMLButtonElement) return;
        location.href = `/admin/jobs?id=${encodeURIComponent(job.id)}`;
      });
      container.append(row);
    }
  }

  function renderDetail(job, steps) {
    detail.replaceChildren();
    const header = document.createElement('article');
    header.className = 'job-summary';
    const status = document.createElement('span');
    status.className = `job-status status-${job.status}`;
    status.textContent = job.status;
    const pipelineName = document.createElement('strong');
    pipelineName.textContent = job.pipeline_id;
    const jobId = document.createElement('code');
    jobId.textContent = job.id;
    const summary = document.createElement('p');
    summary.textContent = job.output_summary ?? job.error_summary ?? '';
    header.append(status, pipelineName, jobId, summary);
    detail.append(header);

    for (const step of steps) {
      const row = document.createElement('article');
      row.className = 'step-row';
      const status = document.createElement('span');
      status.className = `job-status status-${step.status}`;
      status.textContent = step.status;
      const stage = document.createElement('strong');
      stage.textContent = step.stage_id;
      const kind = document.createElement('span');
      kind.textContent = step.kind;
      const duration = document.createElement('span');
      duration.textContent = `${step.duration_ms ?? 0}ms`;
      const output = document.createElement('p');
      output.textContent = step.output_summary ?? step.error_summary ?? '';
      row.append(status, stage, kind, duration, output);
      detail.append(row);
    }
  }

  function renderAdminQueries(jobId, artifacts) {
    const existing = document.getElementById('admin-sql-queries');
    if (!existing) return;

    existing.replaceChildren();

    const jobButton = document.createElement('button');
    jobButton.type = 'button';
    jobButton.className = 'mini-btn';
    jobButton.textContent = '複製 SQL 查詢 (job 與步驟)';
    const jobSql = `SELECT * FROM admin_jobs WHERE id = '${jobId ?? ''}';\nSELECT * FROM admin_job_steps WHERE job_id = '${jobId ?? ''}' ORDER BY created_at ASC;`;
    jobButton.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(jobSql);
        window.alert('已複製 job/sql 查詢。');
      } catch {
        window.alert('複製失敗，請手動複製查詢。');
      }
    });

    const artifactButton = document.createElement('button');
    artifactButton.type = 'button';
    artifactButton.className = 'mini-btn';
    artifactButton.textContent = '複製 SQL 查詢 (所有 artifacts)';
    artifactButton.addEventListener('click', async () => {
      const artifactIds = artifacts.map((artifact) => `'${artifact.id}'`).join(', ');
      const sql = `SELECT id, job_id, step_id, type, name, path, content_json, created_at\nFROM admin_job_artifacts\nWHERE job_id = '${jobId ?? ''}'\n${artifacts.length ? `AND id IN (${artifactIds})\n` : ''}ORDER BY created_at ASC;`;
      try {
        await navigator.clipboard.writeText(sql);
        window.alert('已複製 artifacts SQL 查詢。');
      } catch {
        window.alert('複製失敗，請手動複製查詢。');
      }
    });

    existing.append(jobButton, artifactButton);
  }

  function renderActions(status) {
    const canCancel = status === 'queued' || status === 'running' || status === 'waiting_review';
    const canApprove = status === 'waiting_review';
    actions.className = 'job-actions';
    actions.replaceChildren();
    actions.append(createActionButton('Rerun', 'rerun'));
    if (canApprove) {
      actions.append(createActionButton('Approve', 'approve'));
      actions.append(createActionButton('Reject', 'reject'));
    }
    actions.append(createActionButton('Cancel', 'cancel', !canCancel));

    detail.prepend(actions);
  }

  async function actOnJob(jobId, action, payload = {}) {
    const res = await fetch(`/api/admin/jobs/${encodeURIComponent(jobId)}`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action, ...payload }),
    });
    const data = await res.json();
    if (!res.ok) {
      window.alert(data.error || 'Job action failed');
      return false;
    }
    await load();
    return true;
  }

  function renderArtifacts(artifacts) {
    artifactList.replaceChildren();
    if (!artifacts.length) {
      artifactList.textContent = 'No artifacts.';
      return;
    }
    const isLocked = currentStatus === 'queued' || currentStatus === 'running';

    for (const artifact of artifacts) {
      const typeLabel = artifact.type || 'artifact';
      const hasEditableContent = !isLocked;
      const rawContent = artifact.content_json ?? '';
      const artifactContent = parseArtifactContent(rawContent, typeLabel);

      const item = document.createElement('details');
      item.className = 'artifact';
      const summary = document.createElement('summary');
      summary.textContent = `${typeLabel}: ${artifact.name ?? artifact.id}`;

      const body = document.createElement('div');
      const textarea = document.createElement('textarea');
      textarea.className = 'artifact-editor';
      textarea.style.width = '100%';
      textarea.style.minHeight = typeLabel === 'markdown_draft' ? '18rem' : '12rem';
      textarea.value = artifactContent;
      textarea.placeholder = isLocked
        ? '此作業正在執行中，完成後才能編輯'
        : rawContent == null || rawContent === ''
          ? '尚未有內容，請在這裡輸入要儲存的內容。'
          : 'Paste editable content JSON or markdown here';
      textarea.disabled = isLocked;

      const toolbar = document.createElement('div');
      toolbar.className = 'artifact-toolbar';
      toolbar.style.marginTop = '0.5rem';
      const save = document.createElement('button');
      save.type = 'button';
      save.className = 'mini-btn';
      save.textContent = hasEditableContent ? '儲存編輯' : 'No content to edit';
      save.disabled = !hasEditableContent;

      const copy = document.createElement('button');
      copy.type = 'button';
      copy.className = 'mini-btn';
      copy.textContent = '複製此 artifact SQL';
      copy.addEventListener('click', async () => {
        const sql = `${artifactSqlPrefix}\nWHERE id = '${artifact.id}' AND job_id = '${artifact.job_id ?? (id ?? '')}';`;
        try {
          await navigator.clipboard.writeText(sql);
          window.alert('已複製 artifact SQL。');
        } catch {
          window.alert('複製失敗，請手動複製查詢。');
        }
      });

      const download = document.createElement('button');
      download.type = 'button';
      download.className = 'mini-btn';
      download.textContent = '下載原始 JSON';
      download.addEventListener('click', () => {
        const payload = JSON.stringify({
          jobId: artifact.job_id ?? (id ?? ''),
          artifactId: artifact.id,
          name: artifact.name ?? '',
          type: typeLabel,
          path: artifact.path ?? '',
          content: rawContent === '' ? '' : rawContent,
        }, null, 2);
        const blob = new Blob([payload], { type: 'application/json;charset=utf-8' });
        const href = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = href;
        a.download = `artifact-${artifact.id}.json`;
        a.click();
        URL.revokeObjectURL(href);
      });
      save.addEventListener('click', async () => {
        if (!hasEditableContent) return;
        const latestContent = textarea.value;
        if (typeLabel === 'json_report') {
          try {
            JSON.parse(latestContent);
          } catch {
            window.alert('json_report 必須是有效 JSON，請修正後再儲存。');
            return;
          }
        }

        const ok = await actOnJob(id, 'update_artifact', {
          artifactId: artifact.id,
          artifactType: artifact.type,
          content: latestContent,
        });
        if (ok) {
          window.alert('Artifact 已儲存。');
        }
      });
      toolbar.append(save);
      toolbar.append(copy, download);

      const hint = document.createElement('small');
      hint.className = 'artifact-hint';
      hint.textContent = artifact.path ? `Path: ${artifact.path}` : '';

      body.append(textarea, toolbar, hint);
      if (artifact.path && !hasEditableContent) {
        const pathOnly = document.createElement('pre');
        pathOnly.textContent = artifact.path;
        body.append(pathOnly);
      }

      item.append(summary, body);
      artifactList.append(item);
    }
  }

  function parseArtifactContent(rawContent, typeLabel) {
    if (!rawContent) return '';
    try {
      const parsed = JSON.parse(rawContent);
      return typeLabel === 'json_report' ? JSON.stringify(parsed, null, 2) : String(parsed);
    } catch {
      return rawContent;
    }
  }

  function formatTime(iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  function createMiniActionButton(label, action, jobId, rowJobId, disabled = false) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `mini-btn ${action}-btn`;
    button.textContent = label;
    if (disabled) button.disabled = true;
    button.addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      if (action === 'reject') {
        const note = window.prompt('請輸入 reject 原因（必填）');
        if (!note?.trim()) {
          window.alert('請輸入 reject 原因後再送出。');
          return;
        }
        await actOnJob(rowJobId || jobId || '', 'reject', { reviewNote: note.trim() });
        return;
      }
      await actOnJob(jobId, action);
    });
    return button;
  }

  function createActionButton(label, action, disabled = false) {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = `action-btn ${action}`;
    button.textContent = label;
    if (disabled) button.disabled = true;
    button.addEventListener('click', async () => {
      if (!id) return;
      if (action === 'reject') {
        const note = window.prompt('請輸入 reject 原因（必填）');
        if (!note?.trim()) {
          window.alert('請輸入 reject 原因後再送出。');
          return;
        }
        await actOnJob(id, 'reject', { reviewNote: note.trim() });
        return;
      }
      await actOnJob(id, action);
    });
    return button;
  }

  load();
</script>
