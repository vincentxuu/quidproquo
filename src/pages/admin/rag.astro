---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { SUPPORTED_SEARCH_TOOL_PROVIDERS } from '../../lib/search-tools';
---

<AdminLayout title="RAG 管理">
  <p class="page-desc">管理 RAG 策略開關、engine/provider 設定、shadow run 與最近 trace timeline。</p>

  <section class="admin-panel">
    <div class="panel-title">
      <div>
        <h2>RAG 設定</h2>
        <p class="section-desc">可編輯 engine、provider、fallback、retrieval flags 與 trace retention。</p>
      </div>
      <span id="settings-status" class="save-status" aria-live="polite"></span>
    </div>
    <form id="settings-form"></form>
    <div class="form-actions">
      <button id="save-settings" type="button">儲存設定</button>
    </div>
  </section>

  <section class="admin-panel">
    <h2>最近追蹤紀錄</h2>
    <div id="trace-list">載入中...</div>
  </section>

  <section class="admin-panel">
    <h2>常用操作</h2>
    <div class="ops-grid">
      <button id="run-embed" type="button">執行 embedding 批次</button>
      <button id="run-smoke" type="button">執行搜尋 smoke test</button>
      <input id="crawl-secret" type="password" placeholder="CRAWL_SECRET for crawl sync" />
      <button id="run-crawl" type="button">執行 crawl sync</button>
    </div>
  </section>

  <section class="admin-panel">
    <h2>Engine Smoke / Eval</h2>
    <div class="ops-grid">
      <label>
        Engine
        <select id="engine-select" class="select">
          <option value="langgraph">langgraph</option>
          <option value="manual">manual</option>
          <option value="llamaindex">llamaindex</option>
        </select>
      </label>
      <input id="engine-smoke-query" type="text" value="RAG 的核心步驟是什麼？" />
      <button id="run-engine-smoke" type="button">執行 engine smoke</button>
      <button id="run-engine-index-manual" type="button">執行 manual index probe</button>
      <button id="run-engine-index-langgraph" type="button">執行 langgraph index probe</button>
      <button id="run-engine-index-llamaindex" type="button">執行 llamaindex index probe</button>
    </div>

    <div class="matrix-controls">
      <span>執行 eval matrix:</span>
      <label><input type="checkbox" id="eval-manual" checked /> manual</label>
      <label><input type="checkbox" id="eval-langgraph" checked /> langgraph</label>
      <label><input type="checkbox" id="eval-llamaindex" checked /> llamaindex</label>
      <input id="eval-cases" type="number" min="1" max="20" value="8" />
      <button id="run-eval-matrix" type="button">執行 eval matrix</button>
    </div>
    <pre id="ops-output">尚未執行操作。</pre>
  </section>

  <section class="admin-panel">
    <h2>Shadow Runs</h2>
    <div id="shadow-list">載入中...</div>
  </section>
</AdminLayout>

<script is:inline>
  const form = document.getElementById('settings-form');
  const traceList = document.getElementById('trace-list');
  const shadowList = document.getElementById('shadow-list');
  const save = document.getElementById('save-settings');
  const opsOutput = document.getElementById('ops-output');
  const engineSelect = document.getElementById('engine-select');
  const smokeQueryInput = document.getElementById('engine-smoke-query');
  const runEngineSmokeBtn = document.getElementById('run-engine-smoke');
  const runEngineMatrixBtn = document.getElementById('run-eval-matrix');
  const runManualIndexBtn = document.getElementById('run-engine-index-manual');
  const runLangGraphIndexBtn = document.getElementById('run-engine-index-langgraph');
  const runLlamaIndexBtn = document.getElementById('run-engine-index-llamaindex');
  const evalManualCheckbox = document.getElementById('eval-manual');
  const evalLanggraphCheckbox = document.getElementById('eval-langgraph');
  const evalLlamaindexCheckbox = document.getElementById('eval-llamaindex');
  const evalCasesInput = document.getElementById('eval-cases');
  const settingsStatus = document.getElementById('settings-status');

  const defaultCaseCount = Number((evalCasesInput && evalCasesInput.value) || '8');
  const settingMeta = [
    { key: 'rag_pipeline_engine', label: 'Pipeline engine', type: 'select', section: 'Routing', options: ['langgraph', 'manual', 'llamaindex'] },
    { key: 'rag_default_provider', label: 'Default provider', type: 'select', section: 'Routing', options: ['groq', 'openai', 'google', 'anthropic', 'gemini', 'cloudflare', 'nvidia', 'cerebras', 'openrouter', 'ollama_cloud', 'ollama'] },
    { key: 'rag_default_model', label: 'Default model', type: 'text', section: 'Routing' },
    { key: 'rag_fallback_provider', label: 'Fallback provider', type: 'select', section: 'Routing', options: ['', 'groq', 'openai', 'google', 'anthropic', 'gemini', 'cloudflare', 'nvidia', 'cerebras', 'openrouter', 'ollama_cloud', 'ollama'] },
    { key: 'rag_fallback_model', label: 'Fallback model', type: 'text', section: 'Routing' },
    { key: 'rag_stage_overrides', label: 'Stage overrides JSON', type: 'textarea', section: 'Routing' },
    { key: 'rag_flag_hyde', label: 'HyDE', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_flag_multi_query', label: 'Multi-query', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_flag_reranker', label: 'Reranker', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_flag_critic', label: 'Critic', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_flag_pageindex', label: 'PageIndex', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_flag_bm25_short_circuit', label: 'BM25 short circuit', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_shadow_mode', label: 'Shadow mode', type: 'boolean', section: 'Retrieval' },
    { key: 'rag_search_tools_enabled', label: 'Search tools enabled', type: 'boolean', section: 'Search tools' },
    {
      key: 'rag_search_tool_providers',
      label: 'Search tool providers',
      type: 'search-tools-multi',
      section: 'Search tools',
      options: SUPPORTED_SEARCH_TOOL_PROVIDERS,
    },
    { key: 'rag_search_tool_max_results', label: 'Search tool max results', type: 'number', section: 'Search tools', min: 1, max: 20, step: 1 },
    { key: 'rag_search_tool_timeout_ms', label: 'Search tool timeout ms', type: 'number', section: 'Search tools', min: 500, max: 30000, step: 100 },
    { key: 'rag_pageindex_max_steps', label: 'PageIndex max steps', type: 'number', section: 'Tuning', min: 1, max: 20, step: 1 },
    { key: 'semantic_cache_threshold', label: 'Semantic cache threshold', type: 'number', section: 'Tuning', min: 0, max: 1, step: 0.01 },
    { key: 'rag_reranker_min_keep', label: 'Reranker min keep', type: 'number', section: 'Tuning', min: 1, max: 20, step: 1 },
    { key: 'rag_mmr_lambda', label: 'MMR lambda', type: 'number', section: 'Tuning', min: 0, max: 1, step: 0.05 },
    { key: 'rag_checkpoint_threshold_ratio', label: 'Checkpoint threshold ratio', type: 'number', section: 'Tuning', min: 0, max: 1, step: 0.05 },
    { key: 'rag_trace_retention_enabled', label: 'Trace retention enabled', type: 'boolean', section: 'Retention' },
    { key: 'rag_trace_retention_prod_days', label: 'Production trace days', type: 'number', section: 'Retention', min: 1, max: 365, step: 1 },
    { key: 'rag_trace_retention_admin_days', label: 'Admin trace days', type: 'number', section: 'Retention', min: 1, max: 365, step: 1 },
    { key: 'rag_trace_retention_prod_native_days', label: 'Production native trace days', type: 'number', section: 'Retention', min: 1, max: 365, step: 1 },
    { key: 'rag_trace_retention_admin_native_days', label: 'Admin native trace days', type: 'number', section: 'Retention', min: 1, max: 365, step: 1 },
    { key: 'rag_trace_retention_native_sample_bps', label: 'Native trace sample bps', type: 'number', section: 'Retention', min: 0, max: 10000, step: 1 },
    { key: 'rag_trace_retention_error_grace_days', label: 'Error grace days', type: 'number', section: 'Retention', min: 0, max: 365, step: 1 },
  ];

  async function load() {
    const res = await fetch('/api/admin/rag');
    if (res.status === 401) {
      const message = document.createElement('p');
      message.textContent = '需要管理員登入。請先登入後台。';
      form.replaceChildren(message);
      traceList.textContent = '';
      shadowList.textContent = '';
      return;
    }
    const data = await res.json();
    renderSettings(data.settings);
      renderTraceRows(traceList, data.traces, '目前沒有追蹤步驟。');
      renderShadowRows(shadowList, data.shadow_runs, '目前沒有 shadow run。');
  }

  function renderSettings(settings) {
    form.replaceChildren();
    const byKey = new Map((settings || []).map(row => [row.key, row]));
    const sections = new Map();
    for (const meta of settingMeta) {
      const group = sections.get(meta.section) || [];
      group.push(meta);
      sections.set(meta.section, group);
    }

    for (const [section, metas] of sections) {
      const fieldset = document.createElement('fieldset');
      fieldset.className = 'settings-group';
      const legend = document.createElement('legend');
      legend.textContent = section;
      fieldset.append(legend);

      for (const meta of metas) {
        const row = byKey.get(meta.key) || { key: meta.key, value: '' };
        const label = document.createElement('label');
        label.className = `setting-row setting-${meta.type}`;
        const labelText = document.createElement('span');
        labelText.textContent = meta.label;

        const control = buildSettingControl(meta, row.value ?? '');
        label.append(labelText, control);
        fieldset.append(label);
      }

      form.append(fieldset);
    }
  }

  function buildSettingControl(meta, value) {
    const safeValue = value ?? '';

    if (meta.type === 'search-tools-multi') {
      const wrapper = document.createElement('div');
      wrapper.className = 'search-tools-provider-control';

      const hiddenInput = document.createElement('input');
      hiddenInput.type = 'hidden';
      hiddenInput.name = meta.key;

      const parsed = (() => {
        if (typeof safeValue !== 'string') return [];
        try {
          const parsedValue = JSON.parse(safeValue);
          if (!Array.isArray(parsedValue)) return [];
          return parsedValue
            .map((item) => String(item ?? '').trim().toLowerCase())
            .filter((item) => !!item);
        } catch {
          return [];
        }
      })();

      const selectedProviders = new Set(parsed);

      for (const provider of (meta.options || [])) {
        const label = document.createElement('label');
        label.className = 'search-tool-check-row';
        const checkbox = document.createElement('input');
        checkbox.type = 'checkbox';
        checkbox.value = provider;
        checkbox.checked = selectedProviders.has(provider);
        checkbox.addEventListener('change', () => {
          const checked = wrapper.querySelectorAll('input[type=\"checkbox\"]:checked');
          const next = Array.from(checked).map((item) => String(item.value || '').trim().toLowerCase()).filter(Boolean);
          hiddenInput.value = JSON.stringify(next);
        });
        label.append(checkbox);
        label.append(document.createTextNode(provider));
        wrapper.append(label);
      }

      hiddenInput.value = JSON.stringify(Array.from(selectedProviders));
      wrapper.append(hiddenInput);
      return wrapper;
    }

    if (meta.type === 'select') {
      const select = document.createElement('select');
      select.name = meta.key;
      for (const optionValue of meta.options) {
        const option = document.createElement('option');
        option.value = optionValue;
        option.textContent = optionValue || 'none';
        option.selected = optionValue === safeValue;
        select.append(option);
      }
      return select;
    }

    if (meta.type === 'textarea') {
      const textarea = document.createElement('textarea');
      textarea.name = meta.key;
      textarea.rows = 4;
      textarea.spellcheck = false;
      textarea.value = safeValue || '{}';
      return textarea;
    }

    if (meta.type === 'boolean') {
      const input = document.createElement('input');
      input.name = meta.key;
      input.type = 'checkbox';
      input.checked = safeValue === '1' || safeValue === 'true';
      return input;
    }

    const input = document.createElement('input');
    input.name = meta.key;
    input.type = meta.type || 'text';
    if (meta.min !== undefined) input.min = String(meta.min);
    if (meta.max !== undefined) input.max = String(meta.max);
    if (meta.step !== undefined) input.step = String(meta.step);
    input.value = safeValue ?? '';
    return input;
  }

  function renderTraceRows(root, rows, emptyText) {
    root.replaceChildren();
    if (!rows.length) {
      root.append(textParagraph(emptyText));
      return;
    }
    for (const row of rows) {
      const article = document.createElement('article');
      article.className = 'trace-row';
      const engine = document.createElement('span');
      const stage = document.createElement('strong');
      stage.textContent = row.stage ?? 'unknown';
      const duration = document.createElement('span');
      duration.textContent = `${row.duration_ms ?? 0}ms`;
      const nativeTrace = document.createElement('span');
      if (row.native_trace_summary || row.native_trace) {
        nativeTrace.textContent = 'native trace';
        nativeTrace.className = 'native-badge';
      }
      if (row.pipeline_engine) {
        engine.textContent = `engine=${row.pipeline_engine}`;
      }
      const trace = document.createElement('code');
      const traceLink = document.createElement('a');
      traceLink.className = 'trace-link';
      traceLink.href = `/admin/traces?trace_id=${encodeURIComponent(row.trace_id ?? '')}`;
      traceLink.textContent = row.trace_id ?? '';
      traceLink.rel = 'noopener noreferrer';
      trace.append(traceLink);
      const output = document.createElement('p');
      output.textContent = row.output_summary ?? '';

      if (engine.textContent) article.append(engine);
      article.append(stage, duration, trace, output);
      if (nativeTrace.textContent) article.append(nativeTrace);
      root.append(article);
    }
  }

  function renderShadowRows(root, rows, emptyText) {
    root.replaceChildren();
    if (!rows.length) {
      root.append(textParagraph(emptyText));
      return;
    }
    for (const row of rows) {
      const article = document.createElement('article');
      article.className = 'trace-row';
      const query = document.createElement('strong');
      query.textContent = row.query ?? '';
      const score = document.createElement('span');
      score.textContent = `primary ${row.primary_confidence ?? 'n/a'} / shadow ${row.shadow_confidence ?? 'n/a'}`;
      const trace = document.createElement('code');
      trace.textContent = row.trace_id ?? '';
      article.append(query, score, trace);
      root.append(article);
    }
  }

  function textParagraph(text) {
    const p = document.createElement('p');
    p.textContent = text;
    return p;
  }

  save.addEventListener('click', async () => {
    const settings = {};
    for (const meta of settingMeta) {
      const control = form.elements[meta.key];
      if (!control) continue;
      if (meta.type === 'boolean') {
        settings[meta.key] = control.checked ? '1' : '0';
      } else {
        settings[meta.key] = control.value;
      }
    }

    try {
      JSON.parse(settings.rag_stage_overrides || '{}');
    } catch {
      settingsStatus.textContent = 'Stage overrides 必須是有效 JSON。';
      return;
    }
    try {
      const providers = settings.rag_search_tool_providers?.trim();
      if (providers) {
        const parsed = JSON.parse(providers)
        if (!Array.isArray(parsed)) {
          settingsStatus.textContent = 'Search tool providers 必須是 JSON 陣列（例如 ["jina", "cloudflare", "posts", "docs", "tavily", "firecrawl", "exa", "linkup", "brave", "bocha", "brightdata", "serper", "serpapi"]）。';
          return;
        }
      }
    } catch {
      settingsStatus.textContent = 'Search tool providers 必須是 JSON 陣列（例如 ["jina", "cloudflare", "posts", "docs", "tavily", "firecrawl", "exa", "linkup", "brave", "bocha", "brightdata", "serper", "serpapi"]）。';
      return;
    }

    settingsStatus.textContent = '儲存中...';
    const res = await fetch('/api/admin/rag', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ settings }),
    });
    if (!res.ok) {
      settingsStatus.textContent = '儲存失敗。';
      return;
    }
    settingsStatus.textContent = '已儲存。';
    await load();
    setTimeout(() => { settingsStatus.textContent = ''; }, 2400);
  });

  document.getElementById('run-embed').addEventListener('click', async () => {
    opsOutput.textContent = '正在執行 embedding 批次...';
    const res = await fetch('/api/admin/pipelines', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        pipelineId: 'embed-sync',
        input: { sources: ['posts', 'docs'], offset: 0, limit: 50 },
      }),
    });
    opsOutput.textContent = JSON.stringify(await res.json(), null, 2);
  });

  document.getElementById('run-smoke').addEventListener('click', async () => {
    opsOutput.textContent = '正在執行搜尋 smoke test...';
    const res = await fetch('/api/search?q=RAG&mode=hybrid&limit=5');
    opsOutput.textContent = JSON.stringify(await res.json(), null, 2);
  });

  document.getElementById('run-crawl').addEventListener('click', async () => {
    opsOutput.textContent = '正在執行 crawl sync...';
    const secret = document.getElementById('crawl-secret').value;
    const res = await fetch('/api/crawl/sync', { method: 'POST', headers: { 'X-Crawl-Secret': secret } });
    opsOutput.textContent = JSON.stringify(await res.json(), null, 2);
  });

  runEngineSmokeBtn.addEventListener('click', async () => {
    const engine = engineSelect.value;
    const query = smokeQueryInput.value.trim() || 'RAG 的核心步驟是什麼？';
    opsOutput.textContent = `正在對 ${engine} 執行 smoke test...`;
    const res = await fetch('/api/admin/rag-smoke', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ engine, query }),
    });
    opsOutput.textContent = JSON.stringify(await res.json(), null, 2);
  });

  async function runEngineProbe(engine) {
    opsOutput.textContent = `正在對 ${engine} 執行 index probe...`;
    const res = await fetch('/api/admin/rag-smoke', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        engine,
        query: `index:${engine}`,
        mode: 'index',
        indexProfile: {
          sourceFilters: ['posts', 'docs'],
          offset: 0,
          limit: 40,
        },
      }),
    });
    opsOutput.textContent = JSON.stringify(await res.json(), null, 2);
  }

  runManualIndexBtn.addEventListener('click', () => void runEngineProbe('manual'));
  runLangGraphIndexBtn.addEventListener('click', () => void runEngineProbe('langgraph'));
  runLlamaIndexBtn.addEventListener('click', () => void runEngineProbe('llamaindex'));

  runEngineMatrixBtn.addEventListener('click', async () => {
    const selectedEngines = [];
    if (evalManualCheckbox.checked) selectedEngines.push('manual');
    if (evalLanggraphCheckbox.checked) selectedEngines.push('langgraph');
    if (evalLlamaindexCheckbox.checked) selectedEngines.push('llamaindex');
    if (!selectedEngines.length) {
      opsOutput.textContent = '請至少選一個 engine 再執行 matrix。';
      return;
    }
    const caseCount = Math.max(1, Math.min(20, Number(evalCasesInput.value || defaultCaseCount)));
    opsOutput.textContent = `正在對 ${selectedEngines.join(', ')} 執行 eval matrix...`;
    const res = await fetch('/api/admin/rag-eval', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        engines: selectedEngines,
        cases: caseCount,
      }),
    });
    const data = await res.json();
    if (!res.ok) {
      opsOutput.textContent = JSON.stringify(data, null, 2);
      return;
    }
    const perEngine = Object.entries(data.perEngine || {}).map(([engine, summary]) =>
      `${engine}: faithfulness=${summary.faithfulness.toFixed(3)} relevance=${summary.answerRelevance.toFixed(3)} recall=${summary.contextRecall.toFixed(3)} passed=${summary.passed}/${summary.count}`
    );
    opsOutput.textContent = `${data.completedAt}\n${perEngine.join('\n')}\n\n${JSON.stringify(data.rows, null, 2)}`;
  });

  load();
</script>
