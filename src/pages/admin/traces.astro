---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="Traces">
  <div class="traces-header">
    <p class="page-desc">Query trace timeline and RAG pipeline execution details.</p>
  </div>

  <div class="filters-bar">
    <div class="filter-group">
      <input type="text" id="filter-trace-id" placeholder="Trace ID" class="input" />
      <input type="date" id="filter-date" class="input" />
      <select id="filter-stage" class="select">
        <option value="">All Stages</option>
        <option value="planner">Planner</option>
        <option value="research">Research</option>
        <option value="normalize">Normalize</option>
        <option value="writer">Writer</option>
        <option value="critic">Critic</option>
      </select>
      <select id="filter-status" class="select">
        <option value="">All Status</option>
        <option value="success">Success</option>
        <option value="error">Error</option>
      </select>
      <button id="apply-filters" class="btn">Search</button>
      <button id="clear-filters" class="btn-secondary">Clear</button>
    </div>
  </div>

  <div class="traces-container">
    <section class="traces-list-section">
      <h2>Recent Traces</h2>
      <div id="traces-list" class="traces-list">Loading...</div>
    </section>

    <section class="trace-detail-section" id="trace-detail" style="display: none;">
      <h2>Trace Timeline</h2>
      <div id="trace-timeline" class="timeline"></div>
    </section>
  </div>
</AdminLayout>

<script is:inline>
  let currentFilters = {};

  async function loadTraces() {
    const el = document.getElementById('traces-list');
    try {
      const params = new URLSearchParams();
      if (currentFilters.traceId) params.set('trace_id', currentFilters.traceId);
      if (currentFilters.date) params.set('date', currentFilters.date);
      if (currentFilters.stage) params.set('stage', currentFilters.stage);

      const res = await fetch(`/api/admin/traces?${params.toString()}`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      renderTraces(data.traces || []);
    } catch {
      el.innerHTML = '<p class="error">Unable to load traces</p>';
    }
  }

  function renderTraces(traces) {
    const el = document.getElementById('traces-list');
    if (!traces.length) {
      el.innerHTML = '<p class="empty">No traces found.</p>';
      return;
    }

    el.innerHTML = traces.map(trace => `
      <div class="trace-card" data-trace-id="${trace.trace_id}" onclick="selectTrace('${trace.trace_id}')">
        <div class="trace-header">
          <span class="trace-stage">${trace.stage || 'unknown'}</span>
          <span class="trace-duration">${trace.duration_ms ?? 0}ms</span>
          <span class="trace-time">${formatTime(trace.started_at)}</span>
        </div>
        <div class="trace-id">
          <code>${trace.trace_id}</code>
        </div>
        ${trace.output_summary ? `<p class="trace-summary">${truncate(trace.output_summary, 100)}</p>` : ''}
        ${trace.error_summary ? `<p class="trace-error">${truncate(trace.error_summary, 100)}</p>` : ''}
      </div>
    `).join('');
  }

  async function selectTrace(traceId) {
    const detailSection = document.getElementById('trace-detail');
    const timeline = document.getElementById('trace-timeline');

    // Highlight selected card
    document.querySelectorAll('.trace-card').forEach(el => el.classList.remove('selected'));
    document.querySelector(`.trace-card[data-trace-id="${traceId}"]`)?.classList.add('selected');

    try {
      const res = await fetch(`/api/admin/traces/${traceId}`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();

      detailSection.style.display = 'block';
      timeline.innerHTML = renderTimeline(data.steps || []);
    } catch {
      timeline.innerHTML = '<p class="error">Unable to load trace details</p>';
    }
  }

  function renderTimeline(steps) {
    if (!steps.length) {
      return '<p class="empty">No steps recorded.</p>';
    }

    return `
      <div class="timeline-container">
        ${steps.map((step, idx) => `
          <div class="timeline-step">
            <div class="timeline-marker">${idx + 1}</div>
            <div class="timeline-content">
              <div class="step-header">
                <span class="step-stage">${step.stage || 'unknown'}</span>
                <span class="step-duration">${step.duration_ms ?? 0}ms</span>
                <span class="step-status status-${step.error_summary ? 'error' : 'success'}">
                  ${step.error_summary ? 'Error' : 'Success'}
                </span>
              </div>
              ${step.input_summary ? `
                <div class="step-section">
                  <h4>Input</h4>
                  <pre class="step-code">${escapeHtml(truncate(step.input_summary, 200))}</pre>
                </div>
              ` : ''}
              ${step.output_summary ? `
                <div class="step-section">
                  <h4>Output</h4>
                  <pre class="step-code">${escapeHtml(truncate(step.output_summary, 200))}</pre>
                </div>
              ` : ''}
              ${step.error_summary ? `
                <div class="step-section error">
                  <h4>Error</h4>
                  <pre class="step-code error">${escapeHtml(step.error_summary)}</pre>
                </div>
              ` : ''}
              ${step.metadata_json ? `
                <div class="step-meta">
                  ${renderMetadata(step.metadata_json)}
                </div>
              ` : ''}
            </div>
          </div>
        `).join('')}
      </div>
    `;
  }

  function renderMetadata(jsonStr) {
    try {
      const meta = JSON.parse(jsonStr);
      const parts = [];
      if (meta.provider) parts.push(`<span class="meta-item">Provider: ${meta.provider}</span>`);
      if (meta.model) parts.push(`<span class="meta-item">Model: ${meta.model}</span>`);
      if (meta.tokens_in) parts.push(`<span class="meta-item">Tokens In: ${meta.tokens_in}</span>`);
      if (meta.tokens_out) parts.push(`<span class="meta-item">Tokens Out: ${meta.tokens_out}</span>`);
      return parts.join('');
    } catch {
      return '';
    }
  }

  function formatTime(iso) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }

  function truncate(str, len) {
    if (!str) return '';
    return str.length > len ? str.slice(0, len) + '...' : str;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }

  // Event handlers
  document.getElementById('apply-filters').addEventListener('click', () => {
    currentFilters = {
      traceId: document.getElementById('filter-trace-id').value,
      date: document.getElementById('filter-date').value,
      stage: document.getElementById('filter-stage').value,
      status: document.getElementById('filter-status').value,
    };
    loadTraces();
  });

  document.getElementById('clear-filters').addEventListener('click', () => {
    document.getElementById('filter-trace-id').value = '';
    document.getElementById('filter-date').value = '';
    document.getElementById('filter-stage').value = '';
    document.getElementById('filter-status').value = '';
    currentFilters = {};
    loadTraces();
  });

  // Make selectTrace globally accessible
  window.selectTrace = selectTrace;

  // Initial load
  loadTraces();
</script>

<style>
  .page-desc {
    color: var(--admin-text-muted, #888);
    margin-bottom: 1rem;
  }

  .filters-bar {
    margin-bottom: 1.5rem;
  }

  .filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }

  .input, .select {
    padding: 0.5rem 0.75rem;
    background: var(--admin-bg, #0f0f0f);
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 6px;
    color: var(--admin-text, #e0e0e0);
    font-size: 0.85rem;
  }

  .input:focus, .select:focus {
    outline: none;
    border-color: var(--admin-accent, #3b82f6);
  }

  .btn {
    padding: 0.5rem 1rem;
    background: var(--admin-accent, #3b82f6);
    color: white;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
  }

  .btn-secondary {
    padding: 0.5rem 1rem;
    background: transparent;
    color: var(--admin-text-muted, #888);
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 6px;
    cursor: pointer;
    font-size: 0.85rem;
  }

  .traces-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .traces-list-section h2,
  .trace-detail-section h2 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--admin-text-muted, #888);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .traces-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-height: 70vh;
    overflow-y: auto;
  }

  .trace-card {
    background: var(--admin-surface, #1a1a1a);
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 8px;
    padding: 0.75rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .trace-card:hover {
    border-color: var(--admin-accent, #3b82f6);
  }

  .trace-card.selected {
    border-color: var(--admin-accent, #3b82f6);
    background: rgba(59, 130, 246, 0.1);
  }

  .trace-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .trace-stage {
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--admin-accent, #3b82f6);
  }

  .trace-duration {
    font-size: 0.8rem;
    color: var(--admin-text-muted, #888);
  }

  .trace-time {
    margin-left: auto;
    font-size: 0.75rem;
    color: var(--admin-text-muted, #888);
  }

  .trace-id code {
    font-size: 0.75rem;
    color: var(--admin-text-muted, #888);
  }

  .trace-summary {
    font-size: 0.8rem;
    color: var(--admin-text, #e0e0e0);
    margin-top: 0.5rem;
  }

  .trace-error {
    font-size: 0.8rem;
    color: #f87171;
    margin-top: 0.5rem;
  }

  .timeline-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .timeline-step {
    display: flex;
    gap: 1rem;
  }

  .timeline-marker {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--admin-accent, #3b82f6);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .timeline-content {
    flex: 1;
    background: var(--admin-surface, #1a1a1a);
    border: 1px solid var(--admin-border, #2a2a2a);
    border-radius: 8px;
    padding: 1rem;
  }

  .step-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
  }

  .step-stage {
    font-weight: 600;
    color: var(--admin-text, #e0e0e0);
  }

  .step-duration {
    font-size: 0.8rem;
    color: var(--admin-text-muted, #888);
  }

  .step-status {
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .status-success { background: #166534; color: #bbf7d0; }
  .status-error { background: #7f1d1d; color: #fecaca; }

  .step-section {
    margin-top: 0.75rem;
  }

  .step-section h4 {
    font-size: 0.75rem;
    color: var(--admin-text-muted, #888);
    margin-bottom: 0.35rem;
  }

  .step-code {
    background: var(--admin-bg, #0f0f0f);
    border-radius: 6px;
    padding: 0.5rem;
    font-size: 0.8rem;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .step-code.error {
    color: #f87171;
  }

  .step-meta {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-item {
    font-size: 0.75rem;
    color: var(--admin-text-muted, #888);
    background: var(--admin-border, #2a2a2a);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .error { color: #ef4444; }
  .empty { color: var(--admin-text-muted, #888); }

  @media (max-width: 900px) {
    .traces-container {
      grid-template-columns: 1fr;
    }
  }
</style>
