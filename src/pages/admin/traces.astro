---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
---

<AdminLayout title="追蹤紀錄">
  <div class="traces-header">
    <p class="page-desc">查詢 RAG trace timeline、pipeline 執行細節，並管理 trace retention。</p>
  </div>

  <div class="filters-bar">
    <div class="filter-group">
      <input type="text" id="filter-trace-id" placeholder="Trace ID" class="input" />
      <input type="date" id="filter-date" class="input" />
      <select id="filter-stage" class="select">
        <option value="">全部階段</option>
        <option value="planner">Planner</option>
        <option value="research">Research</option>
        <option value="normalize">Normalize</option>
        <option value="writer">Writer</option>
        <option value="critic">Critic</option>
      </select>
      <select id="filter-status" class="select">
        <option value="">全部狀態</option>
        <option value="success">成功</option>
        <option value="error">錯誤</option>
      </select>
      <button id="apply-filters" class="btn">搜尋</button>
      <button id="clear-filters" class="btn-secondary">清除</button>
    </div>
  </div>

  <section class="retention-panel">
    <div>
      <h2>Trace Retention</h2>
      <p>依 RAG retention 設定清理過期 trace。先 dry run 查看預計刪除數，再執行清理。</p>
    </div>
    <div class="retention-controls">
      <label>
        範圍
        <select id="retention-scope" class="select">
          <option value="all">全部</option>
          <option value="production">Production</option>
          <option value="admin">Admin / Eval</option>
        </select>
      </label>
      <button id="retention-dry-run" class="btn-secondary" type="button">預覽清理</button>
      <button id="retention-run" class="btn danger" type="button">執行清理</button>
    </div>
    <pre id="retention-output">尚未執行 retention。</pre>
  </section>

  <div class="traces-container">
    <section class="traces-list-section">
      <h2>最近追蹤紀錄</h2>
      <div id="traces-list" class="traces-list">載入中...</div>
    </section>

    <section class="trace-detail-section is-hidden" id="trace-detail">
      <h2>Trace Timeline</h2>
      <div id="trace-detail-actions" class="trace-detail-actions is-hidden">
        <label class="trace-filter-toggle">
          <input type="checkbox" id="filter-fallback-only" />
          僅顯示 fallback 映射步驟
        </label>
        <label class="trace-filter-toggle">
          <input type="checkbox" id="filter-unobserved-only" />
          僅顯示未觀測步驟
        </label>
      </div>
      <div id="trace-timeline" class="timeline"></div>
    </section>
  </div>
</AdminLayout>

<script is:inline>
  let currentFilters = {};
  let currentTraceDetail = null;

  function createStatusPill(status) {
    const statusPill = document.createElement('span');
    statusPill.className = `status-pill status-${status || 'success'}`;
    statusPill.textContent = String(status || 'success').toUpperCase();
    return statusPill;
  }

  function createMetaText(label, value, tone = 'meta-item') {
    const span = document.createElement('span');
    span.className = tone;
    span.textContent = `${label}: ${value}`;
    return span;
  }

  function renderEmptyState(container, message, tone = 'empty') {
    const p = document.createElement('p');
    p.className = tone;
    p.textContent = message;
    container.replaceChildren(p);
  }

  function renderTraceError(container, message) {
    const p = document.createElement('p');
    p.className = 'error';
    p.textContent = message;
    container.replaceChildren(p);
  }

  function buildTraceListUrlParams() {
    const params = new URLSearchParams();
    if (currentFilters.traceId) params.set('trace_id', currentFilters.traceId);
    if (currentFilters.date) params.set('date', currentFilters.date);
    if (currentFilters.stage) params.set('stage', currentFilters.stage);
    if (currentFilters.status) params.set('status', currentFilters.status);
    return params.toString();
  }

  async function loadTraces() {
    const el = document.getElementById('traces-list');
    try {
      const res = await fetch(`/api/admin/traces?${buildTraceListUrlParams()}`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      const traces = data.traces || [];
      renderTraces(traces);
      const traceFound = currentFilters.traceId
        ? traces.some(trace => trace.trace_id === currentFilters.traceId)
        : false;
      if (!traces.length || (currentFilters.traceId && !traceFound)) {
        hideTraceDetail();
      }
      syncFilterUrl();
    } catch {
      renderTraceError(el, '無法載入追蹤紀錄');
      hideTraceDetail();
    }
  }

  function hideTraceDetail() {
    const detailSection = document.getElementById('trace-detail');
    const timeline = document.getElementById('trace-timeline');
    const filterInput = document.getElementById('filter-fallback-only');
    const unobservedFilterInput = document.getElementById('filter-unobserved-only');
    const filterWrap = document.getElementById('trace-detail-actions');
    currentTraceDetail = null;
    if (filterInput) filterInput.checked = false;
    if (unobservedFilterInput) unobservedFilterInput.checked = false;
    if (filterWrap) filterWrap.classList.add('is-hidden');
    if (detailSection) detailSection.classList.add('is-hidden');
    if (timeline) timeline.replaceChildren();
  }

  function syncFilterUrl() {
    const search = new URLSearchParams();
    if (currentFilters.traceId) search.set('trace_id', currentFilters.traceId);
    if (currentFilters.date) search.set('date', currentFilters.date);
    if (currentFilters.stage) search.set('stage', currentFilters.stage);
    if (currentFilters.status) search.set('status', currentFilters.status);
    const next = `${window.location.pathname}${search.toString() ? `?${search.toString()}` : ''}`;
    window.history.replaceState({}, '', next);
  }

  function hydrateFiltersFromUrl() {
    const search = new URLSearchParams(window.location.search);
    currentFilters = {
      traceId: search.get('trace_id') ?? '',
      date: search.get('date') ?? '',
      stage: search.get('stage') ?? '',
      status: search.get('status') ?? '',
    };

    document.getElementById('filter-trace-id').value = currentFilters.traceId;
    document.getElementById('filter-date').value = currentFilters.date;
    document.getElementById('filter-stage').value = currentFilters.stage;
    document.getElementById('filter-status').value = currentFilters.status;
  }

  function renderTraces(traces) {
    const el = document.getElementById('traces-list');
    if (!traces.length) {
      renderEmptyState(el, '找不到追蹤紀錄。');
      return;
    }

    const frag = document.createDocumentFragment();

    for (const trace of traces) {
      const card = document.createElement('div');
      card.className = 'trace-card';
      card.dataset.traceId = String(trace.trace_id ?? '');

      const header = document.createElement('div');
      header.className = 'trace-header';

      const stage = document.createElement('span');
      stage.className = 'trace-stage';
      stage.textContent = trace.stage || 'unknown';

      const duration = document.createElement('span');
      duration.className = 'trace-duration';
      duration.textContent = `${String(trace.duration_ms ?? 0)}ms`;

      header.append(stage, duration);

      if (trace.pipeline_engine) {
        header.append(createMetaText('engine', String(trace.pipeline_engine), 'meta-item'));
      }

      if (trace.trace_scope) {
        header.append(createMetaText('scope', String(trace.trace_scope), 'meta-item'));
      }

      const langfuse = document.createElement('span');
      langfuse.className = `meta-item langfuse-status ${trace.has_langfuse_trace ? 'on' : 'off'}`;
      langfuse.textContent = `Langfuse: ${trace.has_langfuse_trace ? '已連結' : '未設定'}`;
      header.append(langfuse);

      if (trace.native_trace || trace.native_trace_summary) {
        const nativeBadge = document.createElement('span');
        nativeBadge.className = 'native-badge';
        nativeBadge.textContent = 'native trace';
        header.append(nativeBadge);
      }

      header.append(createStatusPill(trace.status || 'success'));

      const time = document.createElement('span');
      time.className = 'trace-time';
      time.textContent = formatTime(trace.started_at);
      header.append(time);

      const traceIdRow = document.createElement('div');
      traceIdRow.className = 'trace-id';
      const code = document.createElement('code');
      code.textContent = String(trace.trace_id ?? '');
      traceIdRow.append(code);

      card.append(header, traceIdRow);

      if (trace.langfuse_trace_url) {
        const links = document.createElement('div');
        links.className = 'trace-links';
        const link = document.createElement('a');
        link.className = 'langfuse-link';
        link.href = String(trace.langfuse_trace_url);
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
        link.textContent = 'Langfuse';
        links.append(link);
        card.append(links);

        link.addEventListener('click', (event) => {
          event.stopPropagation();
        });
      }

      if (trace.output_summary) {
        const summary = document.createElement('p');
        summary.className = 'trace-summary';
        summary.textContent = truncate(trace.output_summary, 100);
        card.append(summary);
      }

      if (trace.error_summary) {
        const err = document.createElement('p');
        err.className = 'trace-error';
        err.textContent = truncate(trace.error_summary, 100);
        card.append(err);
      }

      card.addEventListener('click', () => {
        const traceId = card.dataset.traceId || '';
        if (traceId) void selectTrace(traceId);
      });

      frag.append(card);
    }

    el.replaceChildren(frag);
  }

  async function selectTrace(traceId) {
    if (!traceId) return;
    currentFilters.traceId = traceId;
    document.getElementById('filter-trace-id').value = traceId;
    const detailSection = document.getElementById('trace-detail');

    // Highlight selected card
    document.querySelectorAll('.trace-card').forEach((el) => {
      if ((el.dataset?.traceId ?? '') === traceId) {
        el.classList.add('selected');
      } else {
        el.classList.remove('selected');
      }
    });

    try {
      const res = await fetch(`/api/admin/traces/${traceId}`);
      if (!res.ok) throw new Error('Failed');
      const data = await res.json();
      currentTraceDetail = data;
      detailSection.classList.remove('is-hidden');
      renderTraceDetail(data);
    } catch {
      const timeline = document.getElementById('trace-timeline');
      renderTraceError(timeline, '無法載入 trace 細節');
    }
    syncFilterUrl();
  }

  function renderTraceDetail(data) {
    const timeline = document.getElementById('trace-timeline');
    const detailActions = document.getElementById('trace-detail-actions');
    if (!timeline) return;

    const showFallbackOnly = document.getElementById('filter-fallback-only')?.checked;
    const showUnobservedOnly = document.getElementById('filter-unobserved-only')?.checked;
    const fragment = document.createDocumentFragment();

    if (data.langfuse_trace_url) {
      const links = document.createElement('div');
      links.className = 'timeline-links';
      const link = document.createElement('a');
      link.className = 'langfuse-link';
      link.href = String(data.langfuse_trace_url);
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
      link.textContent = '在 Langfuse 開啟';
      links.append(link);
      fragment.append(links);
    }

    if (data.trace_scope) {
      const scopeBadge = document.createElement('div');
      scopeBadge.className = 'trace-scope';
      scopeBadge.textContent = String(data.trace_scope);
      fragment.append(scopeBadge);
    }

    const nativeBlock = renderNativeTraceBlock(data.native_trace);
    if (nativeBlock) fragment.append(nativeBlock);
    fragment.append(renderTimeline(data.steps || [], showFallbackOnly, showUnobservedOnly));

    timeline.replaceChildren(fragment);
    if (detailActions) detailActions.classList.remove('is-hidden');
  }

  function renderNativeTraceBlock(nativeTrace) {
    if (!nativeTrace) return null;

    const section = document.createElement('div');
    section.className = 'native-trace';
    const title = document.createElement('h3');
    title.textContent = 'Native Trace';
    const code = document.createElement('pre');
    code.className = 'step-code';
    code.textContent = JSON.stringify(nativeTrace, null, 2);
    section.append(title, code);
    return section;
  }

  function renderTimeline(steps, showFallbackOnly = false, showUnobservedOnly = false) {
    const filteredSteps = (steps || []).filter((step) => {
      if (!showFallbackOnly && !showUnobservedOnly) return true;
      const mappingMode = getStepMappingMode(step.metadata_json);
      const spanObserved = getStepObserved(step.metadata_json);
      if (showFallbackOnly && mappingMode !== 'fallback') return false;
      if (showUnobservedOnly && spanObserved !== false) return false;
      return true;
    });

    if (!filteredSteps.length) {
      let emptyMessage = '目前沒有紀錄步驟。';
      if (showFallbackOnly && showUnobservedOnly) {
        emptyMessage = '找不到 fallback 且未觀測的步驟。';
      } else if (showFallbackOnly) {
        emptyMessage = '找不到 fallback 映射步驟。';
      } else if (showUnobservedOnly) {
        emptyMessage = '找不到未觀測步驟。';
      }
      const empty = document.createElement('p');
      empty.className = 'empty';
      empty.textContent = emptyMessage;
      return empty;
    }

    const timeline = document.createElement('div');
    timeline.className = 'timeline-container';

    for (const [index, step] of filteredSteps.entries()) {
      const stepRow = document.createElement('div');
      stepRow.className = 'timeline-step';

      const marker = document.createElement('div');
      marker.className = 'timeline-marker';
      marker.textContent = String(index + 1);

      const content = document.createElement('div');
      content.className = 'timeline-content';

      const header = document.createElement('div');
      header.className = 'step-header';
      const stage = document.createElement('span');
      stage.className = 'step-stage';
      stage.textContent = step.stage || 'unknown';
      const duration = document.createElement('span');
      duration.className = 'step-duration';
      duration.textContent = `${step.duration_ms ?? 0}ms`;
      const status = document.createElement('span');
      status.className = `step-status status-${step.error_summary ? 'error' : 'success'}`;
      status.textContent = step.error_summary ? '錯誤' : '成功';
      header.append(stage, duration, status);
      content.append(header);

      if (step.input_summary) {
        const section = document.createElement('div');
        section.className = 'step-section';
        const h4 = document.createElement('h4');
        h4.textContent = '輸入';
        const pre = document.createElement('pre');
        pre.className = 'step-code';
        pre.textContent = truncate(step.input_summary, 200);
        section.append(h4, pre);
        content.append(section);
      }

      if (step.output_summary) {
        const section = document.createElement('div');
        section.className = 'step-section';
        const h4 = document.createElement('h4');
        h4.textContent = '輸出';
        const pre = document.createElement('pre');
        pre.className = 'step-code';
        pre.textContent = truncate(step.output_summary, 200);
        section.append(h4, pre);
        content.append(section);
      }

      if (step.error_summary) {
        const section = document.createElement('div');
        section.className = 'step-section error';
        const h4 = document.createElement('h4');
        h4.textContent = '錯誤';
        const pre = document.createElement('pre');
        pre.className = 'step-code error';
        pre.textContent = step.error_summary;
        section.append(h4, pre);
        content.append(section);
      }

      if (step.metadata_json) {
        const metadata = renderMetadata(step.metadata_json);
        if (metadata.childNodes.length > 0) {
          const metaWrap = document.createElement('div');
          metaWrap.className = 'step-meta';
          metaWrap.append(metadata);
          content.append(metaWrap);
        }
      }

      stepRow.append(marker, content);
      timeline.append(stepRow);
    }

    return timeline;
  }

  function getStepMappingMode(metadataJson) {
    const meta = parseMetadata(metadataJson);
    return meta?.span_mapping_mode ?? null;
  }

  function getStepObserved(metadataJson) {
    const meta = parseMetadata(metadataJson);
    return meta?.span_observed ?? null;
  }

  function renderMetadata(jsonStr) {
    const fragment = document.createDocumentFragment();
    const meta = parseMetadata(jsonStr);
    if (!meta) return fragment;

    const pipeline = meta.pipeline_engine || meta.pipelineEngine;
    if (pipeline) fragment.append(createMetaText('Engine', pipeline));
    if (meta.trace_scope) fragment.append(createMetaText('範圍', meta.trace_scope));
    if (meta.provider) fragment.append(createMetaText('Provider', meta.provider));
    if (meta.model) fragment.append(createMetaText('Model', meta.model));
    if (meta.tokens?.input) fragment.append(createMetaText('輸入 tokens', meta.tokens.input));
    if (meta.tokens?.output) fragment.append(createMetaText('輸出 tokens', meta.tokens.output));
    if (meta.span_mapping_mode) fragment.append(createMetaText('Span mapping', meta.span_mapping_mode));
    fragment.append(createMetaText('Span observed', meta.span_observed ? '是' : '否'));

    if (Array.isArray(meta.model_usage) && meta.model_usage.length) {
      const unique = [...new Set(meta.model_usage.map((item) => item.model))].filter(Boolean);
      if (unique.length) fragment.append(createMetaText('Models', unique.join(', ')));
    }

    return fragment;
  }

  function parseMetadata(jsonStr) {
    if (!jsonStr) return null;
    try {
      return JSON.parse(jsonStr);
    } catch {
      return null;
    }
  }

  function formatTime(iso) {
    if (!iso) return 'N/A';
    return new Date(iso).toLocaleString('zh-TW', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit', second: '2-digit' });
  }

  function truncate(str, len) {
    if (!str) return '';
    return str.length > len ? str.slice(0, len) + '...' : str;
  }

  // Event handlers
  document.getElementById('apply-filters').addEventListener('click', () => {
    currentFilters = {
      traceId: document.getElementById('filter-trace-id').value,
      date: document.getElementById('filter-date').value,
      stage: document.getElementById('filter-stage').value,
      status: document.getElementById('filter-status').value,
    };
    loadTraces();
  });

  document.getElementById('clear-filters').addEventListener('click', () => {
    document.getElementById('filter-trace-id').value = '';
    document.getElementById('filter-date').value = '';
    document.getElementById('filter-stage').value = '';
    document.getElementById('filter-status').value = '';
    currentFilters = {};
    loadTraces();
  });

  document.getElementById('filter-fallback-only').addEventListener('change', () => {
    if (!currentTraceDetail) return;
    renderTraceDetail(currentTraceDetail);
  });

  document.getElementById('filter-unobserved-only').addEventListener('change', () => {
    if (!currentTraceDetail) return;
    renderTraceDetail(currentTraceDetail);
  });

  document.getElementById('retention-dry-run').addEventListener('click', async () => {
    await runRetention(true);
  });

  document.getElementById('retention-run').addEventListener('click', async () => {
    const ok = window.confirm('確定要依 retention 設定刪除過期 trace？這個動作無法從後台復原。');
    if (!ok) return;
    await runRetention(false);
    await loadTraces();
  });

  async function runRetention(dryRun) {
    const output = document.getElementById('retention-output');
    const scope = document.getElementById('retention-scope').value;
    output.textContent = dryRun ? '正在預覽 retention 清理...' : '正在執行 retention 清理...';
    try {
      const res = await fetch('/api/admin/traces/retention', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ scope, dryRun }),
      });
      const data = await res.json();
      output.textContent = formatRetentionResult(data);
    } catch (error) {
      output.textContent = `retention 執行失敗：${error instanceof Error ? error.message : '未知錯誤'}`;
    }
  }

  function formatRetentionResult(data) {
    if (!data?.ok) return JSON.stringify(data, null, 2);
    const planned = data.planned || {};
    const del = data.delete || {};
    const settings = data.settings || {};
    return [
      data.dryRun ? '模式：預覽，不會刪除資料' : '模式：已執行清理',
      `範圍：${data.scope}`,
      `候選 traces：${planned.candidateTraceCount ?? 0}`,
      `預計刪除 non-native traces：${planned.deleteNonNativeTraceCount ?? 0}`,
      `預計刪除 native traces：${planned.deleteNativeTraceCount ?? 0}`,
      `刪除 non-native steps：${del.nonNativeSteps ?? 0}`,
      `刪除 native trace rows：${del.nativeTraceRows ?? 0}`,
      `設定：production=${settings.prodDays ?? 'n/a'} 天，admin=${settings.adminDays ?? 'n/a'} 天，production native=${settings.prodNativeDays ?? 'n/a'} 天，admin native=${settings.adminNativeDays ?? 'n/a'} 天`,
      data.completedAt ? `完成時間：${formatTime(data.completedAt)}` : '',
    ].filter(Boolean).join('\n');
  }

  hydrateFiltersFromUrl();
  // Initial load
  if (currentFilters.traceId) {
    loadTraces().then(() => {
      if (currentFilters.traceId) {
        void selectTrace(currentFilters.traceId);
      }
    });
  } else {
    loadTraces();
  }
</script>
