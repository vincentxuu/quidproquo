---
// src/pages/deep-research/index.astro
import { useState } from 'react';
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>深度研究工具</title>
  <link rel="stylesheet" href="https://unpkg.com/tailwindcss@^2/dist/tailwind.min.css">
</head>
<body class="bg-gray-50">
  <div class="container mx-auto py-12 px-4 max-w-4xl">
    <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">🔎 深度研究請求產生器</h1>

    {#if error}
      <div class="p-4 mb-4 bg-red-100 text-red-800 rounded text-center">
        ⚠️ {error}
      </div>
    {/if}

    <form on:submit={handleSubmit} class="bg-white p-6 rounded-lg shadow-md space-y-6">
      <!-- 研究主題 -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-2">
          研究主題（中/英皆可）
        </label>
        <textarea
          class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-3 border"
          rows="4"
          placeholder="例如：AI 代理的最新趨勢是什麼？"
          bind:value={brief}
        ></textarea>
      </div>

      <!-- 參數設定 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            最多子問題數
          </label>
          <input
            type="number"
            min="1"
            max="10"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
            value={maxQueries}
            on:change={(e) => setMaxQueries(parseInt(e.target.value) || 3)}
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            每次回覆的 Token 數上限
          </label>
          <input
            type="number"
            min="64"
            max="1024"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
            value={maxTokens}
            on:change={(e) => setMaxTokens(parseInt(e.target.value) || 256)}
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            首選的模型提供者
          </label>
          <select
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
            value={providerPref}
            on:change={(e) => setProviderPref(e.target.value)}
          >
            <option value="groq">Groq (最便宜)</option>
            <option value="openai">OpenAI GPT-4</option>
            <option value="google">Google Gemini</option>
          </select>
        </div>
      </div>

      <!-- 送出按鈕 -->
      <button
        type="submit"
        class="w-full bg-indigo-600 text-white py-3 px-4 rounded-md hover:bg-indigo-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        disabled={loading}
      >
        {#if loading}
          🚀 正在產生中…
        {:else}
          產生研究報告
        {/if}
      </button>
    </form>

    {/* 結果顯示 */}
    {#if result}
      <section class="mt-8 p-6 bg-white rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-4 text-gray-800">✅ 研究完成！</h2>
        <p class="mb-4 text-gray-700"><strong>簡短說明：</strong> {result.summary}</p>
        <a
          href={result.reportUrl}
          target="_blank"
          rel="noopener"
          class="inline-block bg-indigo-500 text-white py-2 px-4 rounded-md hover:bg-indigo-600 transition-colors"
        >
          📄 開啟完整報告
        </a>
      </section>
    {/if}
  </div>

  <script>
    // React 狀態管理
    const [brief, setBrief] = useState('');
    const [maxQueries, setMaxQueries] = useState(3);
    const [maxTokens, setMaxTokens] = useState(256);
    const [providerPref, setProviderPref] = useState('groq');
    const [loading, setLoading] = useState(false);
    const [result, setResult] = useState(null);
    const [error, setError] = useState('');

    // 提交表單
    const handleSubmit = async (e) => {
      e.preventDefault();
      setLoading(true);
      setError('');

      try {
        const payload = {
          brief,
          config: {
            maxQueries,
            maxTokens,
            providerPref,
          },
        };

        const response = await fetch('/api/deep-research', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || '請求失敗');
        }

        setResult(data);
      } catch (err) {
        setError(err.message);
      } finally {
        setLoading(false);
      }
    };
  </script>
</body>
</html>