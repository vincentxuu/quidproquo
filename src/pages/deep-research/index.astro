---
---

<!DOCTYPE html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>深度研究工具</title>
    <link rel="stylesheet" href="https://unpkg.com/tailwindcss@^2/dist/tailwind.min.css" />
  </head>
  <body class="bg-gray-50">
    <div class="container mx-auto py-12 px-4 max-w-4xl">
      <h1 class="text-3xl font-bold mb-6 text-center text-gray-800">🔎 深度研究請求產生器</h1>

      <div id="error-box" class="hidden p-4 mb-4 bg-red-100 text-red-800 rounded text-center"></div>
      <a
        id="login-cta"
        href="/login"
        class="hidden mb-4 inline-block bg-red-500 text-white py-2 px-4 rounded-md hover:bg-red-600 transition-colors"
      >
        前往登入
      </a>

      <form id="deep-research-form" class="bg-white p-6 rounded-lg shadow-md space-y-6">
        <div>
          <label for="brief" class="block text-sm font-medium text-gray-700 mb-2">研究主題（中/英皆可）</label>
          <textarea
            id="brief"
            name="brief"
            class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-3 border"
            rows="4"
            placeholder="例如：AI 代理的最新趨勢是什麼？"
            required
          ></textarea>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="maxQueries" class="block text-sm font-medium text-gray-700 mb-2">最多子問題數</label>
            <input
              id="maxQueries"
              name="maxQueries"
              type="number"
              min="1"
              max="10"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
              value="3"
            />
          </div>

          <div>
            <label for="maxTokens" class="block text-sm font-medium text-gray-700 mb-2">每次回覆的 Token 數上限</label>
            <input
              id="maxTokens"
              name="maxTokens"
              type="number"
              min="64"
              max="1024"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
              value="256"
            />
          </div>

          <div>
            <label for="providerPref" class="block text-sm font-medium text-gray-700 mb-2">首選的模型提供者</label>
            <select
              id="providerPref"
              name="providerPref"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
            >
              <option value="groq">Groq (最便宜)</option>
              <option value="openai">OpenAI GPT-4</option>
              <option value="google">Google Gemini</option>
            </select>
          </div>

          <div>
            <label for="maxSearchCalls" class="block text-sm font-medium text-gray-700 mb-2">每個子問題最多搜尋次數</label>
            <input
              id="maxSearchCalls"
              name="maxSearchCalls"
              type="number"
              min="1"
              max="10"
              class="mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border"
              value="3"
            />
          </div>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full bg-indigo-600 text-white py-3 px-4 rounded-md hover:bg-indigo-700 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="submit-text">產生研究報告</span>
        </button>
      </form>

      <section id="result-box" class="hidden mt-8 p-6 bg-white rounded-lg shadow-md">
        <h2 class="text-2xl font-semibold mb-4 text-gray-800">✅ 研究完成！</h2>
        <p id="result-summary" class="mb-4 text-gray-700"><strong>簡短說明：</strong> </p>
        <a
          id="result-link"
          href="#"
          target="_blank"
          rel="noopener"
          class="inline-block bg-indigo-500 text-white py-2 px-4 rounded-md hover:bg-indigo-600 transition-colors"
        >
          📄 開啟完整報告
        </a>
      </section>
    </div>

    <script>
      const form = document.querySelector('#deep-research-form');
      const submitButton = document.querySelector('#submit-btn');
      const submitText = document.querySelector('#submit-text');
      const errorBox = document.querySelector('#error-box');
      const loginCta = document.querySelector('#login-cta');
      const resultBox = document.querySelector('#result-box');
      const resultSummary = document.querySelector('#result-summary');
      const resultLink = document.querySelector('#result-link');

      const getInputNumber = (name, fallback) => {
        const raw = form.elements[name]?.value;
        const parsed = Number.parseInt(raw, 10);
        return Number.isFinite(parsed) ? parsed : fallback;
      };

      const hide = (el) => {
        el.classList.add('hidden');
      };

      const show = (el) => {
        el.classList.remove('hidden');
      };

      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        errorBox.textContent = '';
        hide(errorBox);
        hide(loginCta);
        hide(resultBox);
        resultSummary.textContent = '';
        submitButton.disabled = true;
        submitText.textContent = '🚀 正在產生中…';

        const payload = {
          brief: form.elements.brief.value.trim(),
          config: {
            maxQueries: getInputNumber('maxQueries', 3),
            maxTokens: getInputNumber('maxTokens', 256),
            providerPref: form.elements.providerPref.value,
            maxSearchCalls: getInputNumber('maxSearchCalls', 3),
          },
        };

        if (!payload.brief) {
          errorBox.textContent = '請填寫研究主題。';
          show(errorBox);
          submitButton.disabled = false;
          submitText.textContent = '產生研究報告';
          return;
        }

        try {
          const response = await fetch('/api/deep-research', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            if (response.status === 401 || response.status === 403) {
              const loginCta = document.querySelector('#login-cta');
              if (loginCta) {
                loginCta.classList.remove('hidden');
              }
              throw new Error('請先登入或確認權限後再重試。');
            }
            if (response.status === 429) {
              throw new Error('請求過於頻繁，請稍後再試。');
            }

            const text = await response.text();
            throw new Error(text || '請求失敗');
          }

          const result = await response.json();
          if (!result?.reportUrl) {
            throw new Error('回傳資料格式不完整');
          }

          resultSummary.innerHTML = `<strong>簡短說明：</strong> ${result.summary}`;
          resultLink.href = result.reportUrl;
          show(resultBox);
        } catch (err) {
          errorBox.textContent = `⚠️ ${err.message || '發生未預期錯誤'}`;
          show(errorBox);
        } finally {
          submitButton.disabled = false;
          submitText.textContent = '產生研究報告';
        }
      });
    </script>
  </body>
</html>
