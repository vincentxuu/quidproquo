  }

  if (fillAgentSkillsTemplateButton) {
    fillAgentSkillsTemplateButton.addEventListener('click', () => {
      setAgentSkillsTemplate();
      if (agentSkillsStatus) {
        agentSkillsStatus.textContent = '已套用標準範例。';
      }
    });
  }
  if (saveAgentSkillsButton) {
    saveAgentSkillsButton.addEventListener('click', async () => {
      if (!agentSkillsInput) return;
      const skillsParse = normalizeAgentSkillsText(agentSkillsInput.value);
      if (!skillsParse.valid) {
        if (agentSkillsStatus) {
          agentSkillsStatus.textContent = skillsParse.error || 'SKILL 規格格式不正確';
        }
        return;
      }
      if (!saveAgentSkillsButton) return;
      const originalLabel = saveAgentSkillsButton.textContent;
      saveAgentSkillsButton.disabled = true;
      if (originalLabel) {
        saveAgentSkillsButton.textContent = '儲存中…';
      }
      try {
        const response = await fetch('/api/admin/agent-skills', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ raw: agentSkillsInput.value.trim() }),
        });
        if (!response.ok) {
          throw new Error('save_failed');
        }
        const payload = await response.json().catch(() => ({}));
        if (agentSkillsStatus) {
          agentSkillsStatus.textContent = payload?.raw ? `已儲存共用 agentSkills（${payload.raw.length} 字）` : '已儲存共用 agentSkills（空內容）';
        }
      } catch {
        if (agentSkillsStatus) {
          agentSkillsStatus.textContent = '儲存共用 agentSkills 失敗，請稍後再試。';
        }
      } finally {
        saveAgentSkillsButton.disabled = false;
        if (originalLabel) {
          saveAgentSkillsButton.textContent = originalLabel;
        }
      }
    });
  }
  if (agentSkillsInput) {
    agentSkillsInput.addEventListener('input', () => {
      refreshAgentSkillsSelects();
    });
  }

  const loadAgentSkillsLibrary = async () => {
    if (!agentSkillsInput || agentSkillsInput.value.trim()) return;
    try {
      const response = await fetch('/api/admin/agent-skills');
      if (!response.ok) return;
      const payload = await response.json().catch(() => null);
      const raw = typeof payload?.raw === 'string' ? payload.raw.trim() : '';
      if (!raw) return;
      agentSkillsInput.value = raw;
      refreshAgentSkillsSelects();
      if (agentSkillsStatus) {
        agentSkillsStatus.textContent = '已載入共用 agentSkills。';
      }
    } catch {
      // ignore
    }
  };

  const createOption = (value, label) => {
    const option = document.createElement('option');
    option.value = value;
    option.textContent = label;
    return option;
  };

  const normalize = (value) => String(value ?? '').trim();
  const normalizeAgentSkillsText = (text) => {
    const source = normalize(text).trim();
    if (!source) {
      return {
        raw: '',
        entries: [],
        valid: true,
        error: '',
      };
    }

    const blocks = [];
    const metaBlockRegex = /^---\s*\r?\n([\s\S]*?)\r?\n---/gm;
    let match;
    while ((match = metaBlockRegex.exec(source)) !== null) {
      const block = match[1] ?? '';
      const nameMatch = block.match(/(^|\r?\n)name:\s*(.+)\s*$/m);
      const descriptionMatch = block.match(/(^|\r?\n)description:\s*(.+)\s*$/m);
      if (nameMatch && descriptionMatch) {
        blocks.push({
          name: nameMatch[2].trim(),
          description: descriptionMatch[2].trim(),
        });
      }
    }

    if (!blocks.length) {
      const looksLikeFrontMatter = /(^|\r?\n)---\r?\n/.test(source);
      return {
        raw: source,
        entries: [],
        valid: false,
        error: looksLikeFrontMatter ? '未找到完整的 skill 定義欄位（name/description）。' : '請以 SKILL.md frontmatter 格式貼上，至少要有 `name` 與 `description`。',
      };
    }

    return {
      raw: source,
      entries: blocks,
      valid: true,
      error: '',
    };
  };

  const extractAgentSkillsFromText = (text) => {
    const source = normalize(text).trim();
    if (!source) return [];
    const names = [];
    const metaBlockRegex = /^---\s*\r?\n([\s\S]*?)\r?\n---/gm;
    let match;
    while ((match = metaBlockRegex.exec(source)) !== null) {
      const block = match[1] ?? '';
      const nameMatch = block.match(/(^|\r?\n)name:\s*(.+)\s*$/m);
      if (!nameMatch) continue;
      const name = String(nameMatch[2] ?? '').trim().toLowerCase();
      if (name) names.push(name);
    }
    return Array.from(new Set(names));
  };

  const getAgentSkillsFromInput = () => extractAgentSkillsFromText(agentSkillsInput?.value ?? '');
  const toSelectValues = (select) => {
    const values = [];
    for (const option of Array.from(select?.selectedOptions ?? [])) {
      const value = String(option?.value ?? '').trim().toLowerCase();
      if (value) values.push(value);
    }
    return values;
  };
  const setSelectValues = (select, values = []) => {
    if (!select) return;
    const normalized = new Set(
      Array.from(values || [])
        .map((value) => String(value ?? '').trim().toLowerCase())
        .filter(Boolean),
    );
    for (const option of Array.from(select.options ?? [])) {
      option.selected = normalized.has(option.value);
    }
  };
  const setAgentSkillSelection = (select, values = []) => setSelectValues(select, values);
  const toSearchToolProviderValues = (select) => {
    const values = [];
    for (const option of Array.from(select?.selectedOptions ?? [])) {
      const value = String(option?.value ?? '').trim().toLowerCase();
      if (value) values.push(value);
    }
    return values;
  };

  const setSearchToolProviderSelection = (select, values = []) => {
    setSelectValues(select, values);
  };

  const hydrateSearchToolProviderSelect = (select) => {
    if (!select) return;
    select.replaceChildren();
    for (const provider of SEARCH_TOOL_PROVIDERS) {
      select.append(createOption(provider, provider));
    }
  };

  const setAgentSkillsTemplate = () => {
    if (!agentSkillsInput) return;
    agentSkillsInput.value = AGENT_SKILLS_TEMPLATE.trim();
    refreshAgentSkillsSelects();
  };

  const hydrateSearchToolProviderSelects = () => {
    hydrateSearchToolProviderSelect(searchToolProvidersSelect);
    hydrateSearchToolProviderSelect(plannerSearchToolProvidersSelect);
    hydrateSearchToolProviderSelect(researchSearchToolProvidersSelect);
    hydrateSearchToolProviderSelect(writerSearchToolProvidersSelect);
    hydrateSearchToolProviderSelect(criticSearchToolProvidersSelect);
    hydrateAgentSkillsSelect(agentSkillsSelect);
    hydrateAgentSkillsSelect(plannerAgentSkillsSelect);
    hydrateAgentSkillsSelect(researchAgentSkillsSelect);
    hydrateAgentSkillsSelect(writerAgentSkillsSelect);
    hydrateAgentSkillsSelect(criticAgentSkillsSelect);
  };

  const hydrateAgentSkillsSelect = (select, customAgentSkills = []) => {
    if (!select) return;
    const previous = toSelectValues(select);
    select.replaceChildren();
    const customSkills = Array.from(new Set(Array.isArray(customAgentSkills) ? customAgentSkills : []));
    const allSkills = [...AGENT_SKILLS];
    for (const skill of customSkills) {
      const normalized = String(skill).trim().toLowerCase();
      if (normalized && !allSkills.includes(normalized)) {
        allSkills.push(normalized);
      }
    }
    for (const skill of allSkills) {
      select.append(createOption(skill, skill));
    }
    setAgentSkillSelection(select, previous);
  };

  const refreshAgentSkillsSelects = () => {
    const customAgentSkills = getAgentSkillsFromInput();
    hydrateAgentSkillsSelect(agentSkillsSelect, customAgentSkills);
    hydrateAgentSkillsSelect(plannerAgentSkillsSelect, customAgentSkills);
    hydrateAgentSkillsSelect(researchAgentSkillsSelect, customAgentSkills);
    hydrateAgentSkillsSelect(writerAgentSkillsSelect, customAgentSkills);
    hydrateAgentSkillsSelect(criticAgentSkillsSelect, customAgentSkills);
  };

  const syncStageSearchToolsFromGlobal = (stage) => {
    const key = String(stage || '').trim();
    const stageSelect = stageSearchToolProviderSelects[key];
    if (!stageSelect) return;
    setSearchToolProviderSelection(stageSelect, toSearchToolProviderValues(searchToolProvidersSelect));
  };

  const syncStageAgentSkillsFromGlobal = (stage) => {
    const key = String(stage || '').trim();
    const stageSelect = stageAgentSkillSelects[key];
    if (!stageSelect) return;
    setAgentSkillSelection(stageSelect, toSelectValues(agentSkillsSelect));
  };

  const loadModelCatalog = async () => {
    let providers = Object.keys(defaultProviderModels);
    let catalog = [];

    try {
      const response = await fetch('/api/admin/providers');
      if (!response.ok) throw new Error('provider catalog not available');
      const payload = await response.json();
      providers = Array.isArray(payload.providers) ? payload.providers : providers;
      if (!providers.length) {
        providers = Object.keys(defaultProviderModels);
      }
      catalog = Array.isArray(payload.catalog?.models) ? payload.catalog.models : [];
    } catch {
      // keep fallback defaults
    }

    providerSelect.replaceChildren();
    for (const provider of providers) {
      providerSelect.append(createOption(provider, provider));
    }

    if (providerSelect.options.length > 0) {
      providerSelect.value = providerSelect.options[0].value;
    }
    providerState.catalog = catalog;
    providerState.providers = providers;
    syncModels();
    if (catalog.length === 0) {
      modelSource.textContent = '未能載入 provider catalog，使用預設模型清單。';
    }
  };

  const syncModels = () => {
    const provider = providerSelect.value;
    const providerEntries = Array.isArray(providerState.catalog) ? providerState.catalog : [];
    const options = [];

    for (const item of providerEntries) {
      if (item?.provider === provider && typeof item?.model === 'string' && item.model.trim()) {
        const suffix = item.enabled === false ? '（未啟用）' : '';
        options.push({ value: item.model.trim(), label: `${item.model.trim()}${suffix}` });
      }
    }

    if (!options.length) {
      for (const fallback of defaultProviderModels[provider] ?? []) {
        options.push({ value: fallback, label: fallback });
      }
    }

    modelSelect.replaceChildren();
    for (const entry of options) {
      modelSelect.append(createOption(entry.value, entry.label));
    }
    if (modelSelect.options.length > 0) {
      modelSelect.value = modelSelect.options[0].value;
      modelSource.textContent = `已載入 provider (${provider}) 模型清單：${modelSelect.options.length} 筆。`;
    } else {
      modelSelect.append(createOption('', '尚未可用模型'));
      modelSource.textContent = `provider (${provider}) 目前未提供可用模型，請先在「模型供應商」頁面建立條目。`;
    }
  };

  providerSelect.addEventListener('change', () => {
    syncModels();
  });

  const applyInitialQueryParams = () => {
    const params = new URLSearchParams(window.location.search);
    const brief = params.get('brief');
    const providerPref = normalize(params.get('providerPref') || params.get('provider') || '');
    const model = normalize(params.get('model') || '');
    const maxQueries = normalize(params.get('maxQueries') || '');
    const maxTokens = normalize(params.get('maxTokens') || '');
    const maxSearchCalls = normalize(params.get('maxSearchCalls') || '');
    const agentSkillsRaw = params.get('agentSkillsRaw');

    if (brief && form.elements.brief) {
      form.elements.brief.value = brief;
    }
    if (maxQueries && form.elements.maxQueries) {
      form.elements.maxQueries.value = String(clampIntInRange(maxQueries, 3, 1, 10));
    }
    if (maxTokens && form.elements.maxTokens) {
      form.elements.maxTokens.value = String(clampIntInRange(maxTokens, 2048, 256, 4096));
    }
    if (maxSearchCalls && form.elements.maxSearchCalls) {
      form.elements.maxSearchCalls.value = String(clampIntInRange(maxSearchCalls, 3, 1, 8));
    }
    if (agentSkillsRaw && agentSkillsInput) {
      agentSkillsInput.value = agentSkillsRaw;
      refreshAgentSkillsSelects();
    }
    if (providerPref && providerState.providers.includes(providerPref)) {
      providerSelect.value = providerPref;
      syncModels();
    }
    if (model) {
      const hasModel = Array.from(modelSelect.options ?? []).some((option) => option.value === model);
      if (hasModel) {
        modelSelect.value = model;
      }
    }
    if (providerPref || model || agentSkillsRaw) {
      if (modeSelect) modeSelect.value = 'custom';
      setModeDescription('custom');
      updateCustomModelActions('custom');
      captureCustomModelSnapshot();
    }
  };

  hydrateSearchToolProviderSelects();
  for (const button of document.querySelectorAll('.stage-search-tool-sync')) {
    button.addEventListener('click', () => {
      const stage = button.dataset?.stage || '';
      syncStageSearchToolsFromGlobal(stage);
    });
  }
  for (const button of document.querySelectorAll('.stage-agent-skill-sync')) {
    button.addEventListener('click', () => {
      const stage = button.dataset?.stage || '';
      syncStageAgentSkillsFromGlobal(stage);
    });
  }

  loadModelCatalog().then(async () => {
    await loadAgentSkillsLibrary();
    applyInitialQueryParams();
    if (modeSelect) {
      applyPresetProfile(modeSelect.value);
    }
  });

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    errorBox.textContent = '';
    hide(errorBox);
    hide(loginCta);
    hide(resultBox);
    resultSummary.textContent = '';
    submitButton.disabled = true;
    submitText.textContent = '正在產生中…';

    const payload = {
      brief: normalize(form.elements.brief.value),
      config: {
        providerPref: providerSelect.value,
        model: normalize(modelSelect.value),
        maxQueries: clampInt('maxQueries', 3),
        maxTokens: clampInt('maxTokens', 2048),
        maxSearchCalls: clampInt('maxSearchCalls', 3),
      },
    };

    if (advancedProfile?.checked) {
      payload.config.searchProfile = {
        maxAbstractResults: clampIntInRange(maxAbstractResultsInput?.value, 4, 1, 20),
        maxPostResults: clampIntInRange(maxPostResultsInput?.value, 8, 1, 30),
        maxDocResults: clampIntInRange(maxDocResultsInput?.value, 5, 1, 30),
        maxWebSearchResults: clampIntInRange(maxWebSearchResultsInput?.value, 4, 1, 20),
        maxPageIndexSeeds: clampIntInRange(maxPageIndexSeedsInput?.value, 3, 1, 6),
      };
      payload.config.sourceProfile = {
        pageIndexMaxSteps: clampIntInRange(pageIndexMaxStepsInput?.value, 5, 1, 10),
      };
      payload.config.resultProfile = {
        writerContextSources: clampIntInRange(writerContextSourcesInput?.value, 8, 1, 40),
      };
      payload.config.enableFlags = {
        hydeEnabled: !!enableHydeInput?.checked,
        multiQueryEnabled: !!enableMultiQueryInput?.checked,
        searchToolsEnabled: !!enableSearchToolsInput?.checked,
        bm25ShortCircuitEnabled: !!enableBm25ShortCircuitInput?.checked,
        pageIndexEnabled: !!enablePageIndexInput?.checked,
        plannerEnabled: !!enablePlannerInput?.checked,
        researchEnabled: !!enableResearchAgentInput?.checked,
        writerEnabled: !!enableWriterInput?.checked,
        criticEnabled: !!enableCriticInput?.checked,
        rerankerEnabled: !!enableRerankerInput?.checked,
      };
      payload.config.searchToolProfile = {
        providers: toSearchToolProviderValues(searchToolProvidersSelect),
        maxResults: clampIntInRange(searchToolMaxResultsInput?.value, 4, 1, 20),
        timeoutMs: clampIntInRange(searchToolTimeoutMsInput?.value, 8000, 1000, 60000),
      };
      payload.config.searchToolProfiles = {
        planner: {
          enabled: !!enableSearchToolsPlannerInput?.checked,
          providers: toSearchToolProviderValues(plannerSearchToolProvidersSelect),
        },
        research: {
          enabled: !!enableSearchToolsResearchInput?.checked,
          providers: toSearchToolProviderValues(researchSearchToolProvidersSelect),
        },
        writer: {
          enabled: !!enableSearchToolsWriterInput?.checked,
          providers: toSearchToolProviderValues(writerSearchToolProvidersSelect),
        },
        critic: {
          enabled: !!enableSearchToolsCriticInput?.checked,
          providers: toSearchToolProviderValues(criticSearchToolProvidersSelect),
        },
      };
      payload.config.agentSkillsProfile = {
        skills: toSelectValues(agentSkillsSelect),
      };
      payload.config.agentSkillsProfiles = {
        planner: {
          skills: toSelectValues(plannerAgentSkillsSelect),
        },
        research: {
          skills: toSelectValues(researchAgentSkillsSelect),
        },
        writer: {
          skills: toSelectValues(writerAgentSkillsSelect),
        },
        critic: {
          skills: toSelectValues(criticAgentSkillsSelect),
        },
      };
      const skillsParse = normalizeAgentSkillsText(agentSkillsInput?.value);
      if (!skillsParse.valid) {
        if (agentSkillsStatus) {
          agentSkillsStatus.textContent = skillsParse.error || 'SKILL 規格格式不正確';
        }
        show(agentSkillsStatus);
        errorBox.textContent = 'agentSkills 規格需要修正為標準格式。';
        show(errorBox);
        submitButton.disabled = false;
        submitText.textContent = '產生研究報告';
        return;
      }
      payload.config.agentSkills = {
        raw: skillsParse.raw,
        entries: skillsParse.entries,
      };
    }

    if (customTokenProfile?.checked) {
      payload.config.tokenProfile = {
        planner: clampIntInRange(plannerTokensInput?.value, clampInt('maxTokens', 2048), 256, 1024),
        research: clampIntInRange(researchTokensInput?.value, clampInt('maxTokens', 2048), 256, 2048),
        writer: clampIntInRange(writerTokensInput?.value, 2048, 1024, 4096),
        critic: clampIntInRange(criticTokensInput?.value, 1024, 512, 2048),
      };
    }

    if (!payload.brief) {
      errorBox.textContent = '請先填寫研究主題。';
      show(errorBox);
      submitButton.disabled = false;
      submitText.textContent = '產生研究報告';
      return;
    }

    try {
      const response = await fetch('/api/deep-research', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      if (!response.ok) {
        if (response.status === 401 || response.status === 403) {
          show(loginCta);
          throw new Error('請先登入或確認權限後再重試。');
        }
        if (response.status === 429) {
          throw new Error('請求過於頻繁，請稍後再試。');
        }
        const text = await response.text();
        throw new Error(text || '請求失敗');
      }

      const result = await response.json();
      if (!result?.reportUrl) {
        throw new Error('回傳資料格式不完整');
      }

      resultSummary.textContent = `簡短說明：${result.summary}`;
      resultLink.href = result.reportUrl;
      show(resultBox);
    } catch (error) {
      errorBox.textContent = `⚠️ ${error?.message || '發生未預期錯誤'}`;
      show(errorBox);
    } finally {
      submitButton.disabled = false;
      submitText.textContent = '產生研究報告';
    }
  });
</script>
