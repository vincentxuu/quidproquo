        researchEnabled: false,
        writerEnabled: false,
        criticEnabled: true,
        rerankerEnabled: false,
      },
      searchToolProfile: {
        providers: SEARCH_TOOL_PROVIDERS_FALLBACK,
        maxResults: 4,
        timeoutMs: 8000,
      },
      searchToolProfiles: {
        planner: { enabled: false },
        research: { enabled: false },
        writer: { enabled: false },
        critic: { enabled: false },
      },
      agentSkillsProfile: {
        skills: ['using-agent-skills'],
      },
      agentSkillsProfiles: {
        planner: { skills: ['spec-driven-development', 'planning-and-task-breakdown'] },
        research: { skills: ['source-driven-development', 'doubt-driven-development'] },
        writer: { skills: ['context-engineering', 'api-and-interface-design'] },
        critic: { skills: ['code-review-and-quality', 'code-simplification'] },
      },
    },
    balanced: {
      providerPref: 'openai',
      model: 'gpt-4.1-mini',
      maxTokens: 2048,
      maxQueries: 3,
      maxSearchCalls: 3,
      tokenProfile: {
        planner: 512,
        research: 1024,
        writer: 2048,
        critic: 1024,
      },
      searchProfile: {
        maxAbstractResults: 4,
        maxPostResults: 8,
        maxDocResults: 5,
        maxWebSearchResults: 4,
        maxPageIndexSeeds: 3,
      },
      sourceProfile: {
        pageIndexMaxSteps: 5,
      },
      resultProfile: {
        writerContextSources: 8,
      },
      enableFlags: {
        plannerEnabled: true,
        hydeEnabled: true,
        multiQueryEnabled: true,
        searchToolsEnabled: true,
        bm25ShortCircuitEnabled: true,
        pageIndexEnabled: true,
        researchEnabled: true,
        writerEnabled: true,
        criticEnabled: true,
        rerankerEnabled: false,
      },
      searchToolProfile: {
        providers: SEARCH_TOOL_PROVIDERS_FALLBACK,
        maxResults: 4,
        timeoutMs: 8000,
      },
      searchToolProfiles: {
        planner: { enabled: false },
        research: { enabled: true },
        writer: { enabled: false },
        critic: { enabled: false },
      },
      agentSkillsProfile: {
        skills: ['using-agent-skills', 'planning-and-task-breakdown'],
      },
      agentSkillsProfiles: {
        planner: { skills: ['spec-driven-development', 'planning-and-task-breakdown'] },
