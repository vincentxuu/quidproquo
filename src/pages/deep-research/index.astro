    if (agentSkillsInput && !agentSkillsInput.value.trim()) {
      setAgentSkillsTemplate();
    } else {
      refreshAgentSkillsSelects();
    }
    if (agentSkillsStatus) {
      const statusText = toSelectValues(agentSkillsSelect).length
        ? '已套用標準範例，請依專案需求修改每份 skill 的內容。'
        : '可先貼上 SKILL.md，缺少 name/description 會影響使用效果。';
      agentSkillsStatus.textContent = statusText;
