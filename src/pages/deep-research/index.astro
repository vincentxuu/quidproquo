      syncModels();
    }
    if (forceModel && model) {
      const targetModel = String(model).trim();
      const hasModel = Array.from(modelSelect.options ?? []).some((option) => option.value === targetModel);
      if (targetModel && hasModel) {
        modelSelect.value = targetModel;
      }
    }
  };

  if (customTokenProfile && tokenProfileSettings) {
