---
// src/pages/en/index.astro
export const prerender = true;

import PostLayout from '../../layouts/PostLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { useTranslations } from '../../i18n/utils';
import { getSeriesHref } from '../../utils/series';
import { getPublishedPosts, sortPostsByPinnedAndDateDesc } from '../../utils/content';

const t = useTranslations('en');
const posts = sortPostsByPinnedAndDateDesc(await getPublishedPosts('en'));
---
<PostLayout title="quidproquo" lang="en" description="Tech, climbing, surfing, coffee, and everything else." ogImage="https://quidproquo.cc/og/home.png">
  <Fragment slot="head">
    <link rel="alternate" hreflang="zh-TW" href="https://quidproquo.cc/" />
    <link rel="alternate" hreflang="en" href="https://quidproquo.cc/en/" />
    <link rel="alternate" hreflang="x-default" href="https://quidproquo.cc/" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'quidproquo',
      url: 'https://quidproquo.cc',
      description: 'Tech, climbing, surfing, coffee, and everything else.',
      inLanguage: 'en',
      author: { '@type': 'Person', name: 'xiaoxu' },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: 'https://quidproquo.cc/search?q={search_term_string}' },
        'query-input': 'required name=search_term_string',
      },
    }).replace(/</g, '\\u003c')} />
  </Fragment>
  <div class="untranslated-banner" id="untranslated-banner" role="status" hidden>
    <span>{t('untranslated.banner')}</span>
    <button type="button" id="untranslated-dismiss" aria-label={t('untranslated.dismiss')}>&times;</button>
  </div>
  <h1>quidproquo</h1>
  <p class="subtitle">{t('site.tagline')}</p>
  <section class="about">
    <p>A personal blog by xiaoxu — covering software engineering, AI agents, climbing, surfing, coffee, and whatever else I'm obsessing over. Written mostly in Traditional Chinese; posts tagged <code>en</code> are in English.</p>
  </section>
  {posts.map(post => (
    <PostCard
      slug={post.id}
      title={post.data.title}
      date={post.data.date}
      category={post.data.category}
      tags={post.data.tags}
      description={post.data.description}
      tldr={post.data.tldr}
      readingTime={post.data.readingTime}
      lang="en"
      type={post.data.type}
      pinned={post.data.pinned}
      seriesName={post.data.series?.name}
      seriesHref={post.data.series ? getSeriesHref(post.data.series.name, 'en') : undefined}
    />
  ))}
</PostLayout>

<script is:inline>
  (function () {
    const url = new URL(window.location.href);
    if (!url.searchParams.has('untranslated')) return;
    const banner = document.getElementById('untranslated-banner');
    if (!banner) return;
    banner.hidden = false;
    const dismiss = document.getElementById('untranslated-dismiss');
    dismiss?.addEventListener('click', function () {
      banner.remove();
      url.searchParams.delete('untranslated');
      window.history.replaceState({}, '', url.pathname + url.search + url.hash);
    });
  })();
</script>

<style>
  .untranslated-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 0.7rem 1rem;
    background: var(--info-bg);
    border: 1px solid var(--info-border);
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .untranslated-banner button {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }
  .untranslated-banner button:hover { color: var(--text-primary); }
  h1 { margin-bottom: 0.25rem; font-size: 2rem; font-weight: 900; letter-spacing: -1px; color: var(--brand-900); }
  .subtitle { color: var(--text-secondary); margin-bottom: 2rem; font-size: 0.9rem; }
  .about {
    margin-bottom: 2rem;
    padding: 1rem 1.25rem;
    background: var(--bg-subtle);
    border-radius: 8px;
    border-left: 3px solid var(--brand-500);
  }
  .about p {
    margin: 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .about code {
    background: var(--brand-100);
    color: var(--brand-700);
    padding: 0.1em 0.35em;
    border-radius: 3px;
    font-size: 0.9em;
  }
</style>
