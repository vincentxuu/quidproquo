---
// src/pages/index.astro
export const prerender = true;

import PostLayout from '../layouts/PostLayout.astro';
import PostCard from '../components/PostCard.astro';
import { useTranslations } from '../i18n/utils';
import { getSeriesHref } from '../utils/series';
import { getPublishedPosts, sortPostsByPinnedAndDateDesc } from '../utils/content';

const t = useTranslations('zh-TW');
const posts = sortPostsByPinnedAndDateDesc(await getPublishedPosts('zh-TW'));
---
<PostLayout title="quidproquo" lang="zh-TW" description="AI、技術、產品，攀岩、衝浪、咖啡，以及其他一切。" ogImage="https://quidproquo.cc/og/home.png">
  <Fragment slot="head">
    <link rel="alternate" hreflang="zh-TW" href="https://quidproquo.cc/" />
    <link rel="alternate" hreflang="en" href="https://quidproquo.cc/en/" />
    <link rel="alternate" hreflang="x-default" href="https://quidproquo.cc/" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'quidproquo',
      url: 'https://quidproquo.cc',
      description: 'AI、技術、產品，攀岩、衝浪、咖啡，以及其他一切。',
      inLanguage: 'zh-TW',
      author: { '@type': 'Person', name: 'xiaoxu' },
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: 'https://quidproquo.cc/search?q={search_term_string}' },
        'query-input': 'required name=search_term_string',
      },
    }).replace(/</g, '\\u003c')} />
  </Fragment>
  <div class="untranslated-banner" id="untranslated-banner" role="status" hidden>
    <span>{t('untranslated.banner')}</span>
    <button type="button" id="untranslated-dismiss" aria-label={t('untranslated.dismiss')}>&times;</button>
  </div>
  <h1>quidproquo</h1>
  <p class="subtitle">{t('site.tagline')}</p>
  <div class="about">
    <p>
      <em>Quid pro quo</em> <span class="pronunciation">/ˌkwɪd proʊ ˈkwoʊ/</span> — 拉丁語，「以某物換某物」，也就是等價交換。
    </p>
    <p>
      這裡記錄 AI、技術、產品思考，以及打造產品的過程——也有攀岩、衝浪、咖啡。不只是存起來，而是換成對別人也有用的東西，然後多給一點。
    </p>
    <a href="/posts/product/2026-03-12-quidproquo-blog-from-scratch#名字的由來" class="name-link">名字的由來 →</a>
  </div>
  {posts.map(post => (
    <PostCard
      slug={post.id}
      title={post.data.title}
      date={post.data.date}
      category={post.data.category}
      tags={post.data.tags}
      description={post.data.description}
      tldr={post.data.tldr}
      readingTime={post.data.readingTime}
      lang="zh-TW"
      type={post.data.type}
      pinned={post.data.pinned}
      seriesName={post.data.series?.name}
      seriesHref={post.data.series ? getSeriesHref(post.data.series.name, 'zh-TW') : undefined}
    />
  ))}
</PostLayout>

<script is:inline>
  (function () {
    const url = new URL(window.location.href);
    if (!url.searchParams.has('untranslated')) return;
    const banner = document.getElementById('untranslated-banner');
    if (!banner) return;
    banner.hidden = false;
    const dismiss = document.getElementById('untranslated-dismiss');
    dismiss?.addEventListener('click', function () {
      banner.remove();
      url.searchParams.delete('untranslated');
      window.history.replaceState({}, '', url.pathname + url.search + url.hash);
    });
  })();
</script>

<style>
  .untranslated-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 0.7rem 1rem;
    background: var(--info-bg);
    border: 1px solid var(--info-border);
    border-radius: 8px;
    font-size: 0.85rem;
    color: var(--text-primary);
  }
  .untranslated-banner button {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }
  .untranslated-banner button:hover { color: var(--text-primary); }
  h1 { margin-bottom: 0.25rem; font-size: 2rem; font-weight: 900; letter-spacing: -1px; color: var(--brand-900); }
  .subtitle { color: var(--text-secondary); margin-bottom: 1rem; font-size: 0.9rem; }
  .about {
    border-left: 3px solid var(--border);
    padding-left: 1rem;
    margin-bottom: 2.5rem;
    color: var(--text-secondary);
    font-size: 0.88rem;
    line-height: 1.75;
  }
  .about p { margin: 0 0 0.5rem; }
  .about p:last-child { margin-bottom: 0; }
  .name-link { display: inline-block; margin-top: 0.25rem; color: var(--brand-500); text-decoration: none; font-size: 0.85rem; }
  .name-link:hover { color: var(--brand-900); }
  .pronunciation { font-size: 0.8em; color: var(--text-muted); font-style: normal; letter-spacing: 0.02em; }
</style>
