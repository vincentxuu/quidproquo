---
// src/pages/posts/[...slug].astro
export const prerender = true;

import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import Icons from '../../components/Icons.astro';
import { getRelatedPosts } from '../../utils/relatedPosts';
import { getSeriesNav } from '../../utils/seriesNav';
import { useTranslations, type Lang } from '../../i18n/utils';
import { getPublishedPosts, isPublishedPost, sortPostsByDateDesc } from '../../utils/content';
import { getSeriesHref } from '../../utils/series';
import { DEFAULT_GLOSSARY_TERMS, normalizeGlossaryTerms } from '../../lib/glossary/terms';

export async function getStaticPaths() {
  const allPosts = await getPublishedPosts();
  return allPosts.map(post => ({
    params: { slug: post.id },
    props: { post, allPosts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content, headings } = await render(post);
const lang = post.data.lang as Lang;
const t = useTranslations(lang);

const sortedPosts = sortPostsByDateDesc(
  allPosts.filter(p => isPublishedPost(p) && p.data.lang === lang)
);
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : undefined;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : undefined;

const relatedPosts = getRelatedPosts(post, allPosts);
const seriesNav = getSeriesNav(post, allPosts);
const seriesHref = post.data.series ? getSeriesHref(post.data.series.name, lang) : undefined;
const readingTime = post.data.readingTime ?? 1;
const categoriesBase = lang === 'en' ? '/en/categories' : '/categories';
const tagsBase = lang === 'en' ? '/en/tags' : '/tags';
const dateStr = post.data.date.toLocaleDateString(lang === 'en' ? 'en-US' : 'zh-TW', { year: 'numeric', month: 'short', day: 'numeric' });
const glossaryEntries = normalizeGlossaryTerms([
  ...(post.data.glossary ?? []),
  ...DEFAULT_GLOSSARY_TERMS,
]);

const ogImage = `${Astro.site ?? 'https://quidproquo.cc'}/og/${post.id}.png`;
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://quidproquo.cc';
const postUrl = `${siteUrl}/posts/${post.id}`;

const blogPostingLD = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description ?? post.data.tldr ?? '',
  image: ogImage,
  datePublished: post.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'xiaoxu',
    url: siteUrl,
  },
  publisher: {
    '@type': 'Organization',
    name: 'quidproquo',
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
  keywords: post.data.tags.join(', '),
};

const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: lang === 'en' ? 'Home' : '首頁',
      item: lang === 'en' ? `${siteUrl}/en` : siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: post.data.category,
      item: `${siteUrl}${categoriesBase}/${post.data.category}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: postUrl,
    },
  ],
};
---
<PostLayout
  title={post.data.title}
  description={post.data.description ?? post.data.tldr}
  lang={lang}
  ogImage={ogImage}
  articleDate={post.data.date}
  articleTags={post.data.tags}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingLD).replace(/</g, '\\u003c')} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbLD).replace(/</g, '\\u003c')} />
  </Fragment>

  <!-- Hero Section (like DJ MYG) -->
  <div class="hero">
    <div class="hero-content">
      <h1>{post.data.title}</h1>
      <div class="hero-meta">
        <span class="hero-meta-item">
          <Icons name="clock" size={14} />
          {dateStr}
        </span>
        <span class="hero-meta-item">
          <Icons name="clock" size={14} />
          {readingTime} {t('post.reading-time')}
        </span>
      </div>
    </div>
    <div class="hero-wave">
      <svg viewBox="0 0 1200 120" preserveAspectRatio="none">
        <path d="M0,60 C200,100 400,20 600,60 C800,100 1000,20 1200,60 L1200,120 L0,120 Z" fill="var(--bg-page)"/>
      </svg>
    </div>
  </div>

  <article>
    <!-- Breadcrumb (like DJ MYG) -->
    <div class="breadcrumb">
      <a href={lang === 'en' ? '/en' : '/'} class="breadcrumb-link">
        <Icons name="chevron-left" size={11} />
        {t('nav.home')}
      </a>
      <span class="breadcrumb-sep">&rsaquo;</span>
      <a href={`${categoriesBase}/${post.data.category}`} class="breadcrumb-cat">
        {post.data.category}
      </a>
    </div>

    <!-- TL;DR -->
    {post.data.tldr && (
      <div class="tldr">
        <span class="tldr-label">TL;DR</span>
        {post.data.tldr}
      </div>
    )}

    <!-- Tags -->
    {post.data.tags.length > 0 && (
      <div class="tags">
        {post.data.tags.map(tag => (
          <a href={`${tagsBase}/${tag}`} class="tag-pill">#{tag}</a>
        ))}
      </div>
    )}

    <!-- TOC -->
    {headings.length > 0 && (
      <div class="toc">
        <div class="toc-header">
          <Icons name="list" size={14} />
          <span>{t('post.toc')}</span>
        </div>
        <ol>
          {headings.filter(h => h.depth === 2).map(h => (
            <li>
              <a href={`#${h.slug}`}>{h.text}</a>
              {headings.filter(sub => {
                if (sub.depth !== 3) return false;
                const h2idx = headings.findIndex(x => x.slug === h.slug);
                const subidx = headings.findIndex(x => x.slug === sub.slug);
                if (subidx < h2idx) return false;
                const nextH2 = headings.findIndex((x, i) => x.depth === 2 && i > h2idx);
                return nextH2 === -1 || subidx < nextH2;
              }).length > 0 && (
                <ol>
                  {headings.filter(sub => {
                    if (sub.depth !== 3) return false;
                    const h2idx = headings.findIndex(x => x.slug === h.slug);
                    const subidx = headings.findIndex(x => x.slug === sub.slug);
                    if (subidx < h2idx) return false;
                    const nextH2 = headings.findIndex((x, i) => x.depth === 2 && i > h2idx);
                    return nextH2 === -1 || subidx < nextH2;
                  }).map(sub => (
                    <li><a href={`#${sub.slug}`}>{sub.text}</a></li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </div>
    )}

    <!-- Series nav -->
    {seriesNav && (
      <div class="series-box">
        <div class="series-header">
          <Icons name="book-open" size={14} />
          <span>
            {t('post.series')}:
            {' '}
            {seriesHref ? <a href={seriesHref} class="series-link">{seriesNav.name}</a> : seriesNav.name}
            {' '}
            ({seriesNav.current} / {seriesNav.total})
          </span>
        </div>
        <div class="series-nav">
          {seriesNav.prev ? (
            <a href={`/posts/${seriesNav.prev.slug}`} class="series-prev">
              <Icons name="chevron-left" size={12} />
              {seriesNav.prev.title}
            </a>
          ) : <span />}
          {seriesNav.next && (
            <a href={`/posts/${seriesNav.next.slug}`} class="series-next">
              {seriesNav.next.title}
              <Icons name="chevron-right" size={12} />
            </a>
          )}
        </div>
      </div>
    )}

    <!-- Content -->
    <div class="content">
      <Content />
    </div>

    <script
      is:inline
      id="glossary-data"
      type="application/json"
      data-post-slug={post.id}
      set:html={JSON.stringify(glossaryEntries).replace(/</g, '\\u003c')}
    />

    <div class="glossary-popover" id="glossary-popover" role="dialog" aria-live="polite" hidden>
      <div class="glossary-popover-head">
        <div>
          <div class="glossary-eyebrow">Glossary</div>
          <div class="glossary-title" id="glossary-title"></div>
        </div>
        <div class="glossary-level" role="group" aria-label="Explanation depth">
          <button type="button" data-glossary-level="beginner">初學</button>
          <button type="button" data-glossary-level="advanced">進階</button>
        </div>
      </div>
      <p class="glossary-definition" id="glossary-definition">Loading...</p>
      <p class="glossary-context" id="glossary-context"></p>
      <div class="glossary-reading" id="glossary-reading"></div>
    </div>

    <!-- Prev / Next -->
    {(prevPost || nextPost) && (
      <nav class="post-nav">
        {prevPost ? (
          <a href={`/posts/${prevPost.id}`} class="post-nav-prev">
            <span class="post-nav-label">
              <Icons name="chevron-left" size={13} />
              {t('post.prev')}
            </span>
            <span class="post-nav-title">{prevPost.data.title}</span>
          </a>
        ) : <span />}
        {nextPost && (
          <a href={`/posts/${nextPost.id}`} class="post-nav-next">
            <span class="post-nav-label">
              {t('post.next')}
              <Icons name="chevron-right" size={13} />
            </span>
            <span class="post-nav-title">{nextPost.data.title}</span>
          </a>
        )}
      </nav>
    )}

    <!-- Related articles -->
    {relatedPosts.length > 0 && (
      <section class="related">
        <h3>
          <Icons name="link" size={14} />
          {t('post.related')} · #{post.data.tags[0]}
        </h3>
        <div class="related-list">
          {relatedPosts.map(p => (
            <a href={`/posts/${p.id}`} class="related-item">
              <span class="related-title">{p.data.title}</span>
              <span class="related-time">
                <Icons name="clock" size={11} />
                {p.data.readingTime ?? 1} min
              </span>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</PostLayout>

<style>
  /* ── Hero Section (like DJ MYG) ── */
  .hero {
    position: relative;
    background: linear-gradient(135deg, #1a2332 0%, #0f1419 50%, #1a2332 100%);
    margin: -1rem -1.5rem 0;
    padding: 3rem 1.5rem 4rem;
    text-align: center;
    overflow: hidden;
  }
  @media (max-width: 640px) {
    .hero { margin-left: -1rem; margin-right: -1rem; padding-left: 1rem; padding-right: 1rem; }
  }
  @media (max-width: 400px) {
    .hero { margin-left: -0.75rem; margin-right: -0.75rem; padding-left: 0.75rem; padding-right: 0.75rem; }
  }
  :global(:root:not([data-theme="dark"])) .hero {
    background: linear-gradient(135deg, #2d4a2d 0%, #1a2e1a 50%, #2d4a2d 100%);
  }
  .hero-content { position: relative; z-index: 1; max-width: 700px; margin: 0 auto; }
  .hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    letter-spacing: -0.5px;
    line-height: 1.25;
    margin: 0 0 1rem;
    color: #ffffff;
  }
  .hero-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.6);
  }
  .hero-meta-item {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  /* Wave divider */
  .hero-wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    line-height: 0;
  }
  .hero-wave svg {
    width: 100%;
    height: 40px;
  }

  /* ── Breadcrumb ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
    margin-top: 1.5rem;
    font-size: 0.82rem;
  }
  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .breadcrumb-link:hover { color: var(--text-secondary); }
  .breadcrumb-sep { color: var(--text-muted); }
  .breadcrumb-cat {
    color: var(--brand-500);
    text-decoration: none;
    font-weight: 600;
  }
  .breadcrumb-cat:hover { color: var(--brand-900); }

  /* TL;DR */
  .tldr { background: var(--bg-subtle); border-left: 3px solid var(--brand-500); padding: 0.75rem 1rem; border-radius: 0 6px 6px 0; margin-bottom: 1rem; font-size: 0.88rem; line-height: 1.6; color: var(--text-primary); }
  .tldr-label { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--brand-500); font-weight: 700; display: block; margin-bottom: 0.3rem; }

  /* Tags */
  .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; margin-bottom: 1.25rem; }

  /* TOC */
  .toc {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    background: var(--bg-subtle);
    margin-bottom: 1.5rem;
  }
  .toc-header { display: flex; align-items: center; gap: 0.4rem; font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-secondary); margin-bottom: 0.6rem; }
  .toc ol { padding-left: 1.2rem; margin: 0; font-size: 0.83rem; line-height: 1.9; color: var(--brand-700); }
  .toc ol ol { font-size: 0.78rem; color: var(--text-secondary); }
  .toc a { color: inherit; text-decoration: none; }
  .toc a:hover { color: var(--brand-500); }

  /* Series box */
  .series-box { border: 1px solid var(--border); border-radius: 8px; padding: 0.85rem 1rem; background: var(--bg-subtle); margin-bottom: 1.5rem; }
  .series-header { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; font-weight: 700; color: var(--text-secondary); margin-bottom: 0.5rem; }
  .series-link { color: inherit; text-decoration: none; border-bottom: 1px solid transparent; }
  .series-link:hover { border-bottom-color: currentColor; }
  .series-nav { display: flex; justify-content: space-between; font-size: 0.8rem; }
  .series-prev, .series-next { display: flex; align-items: center; gap: 0.25rem; color: var(--brand-500); text-decoration: none; }
  .series-prev:hover, .series-next:hover { color: var(--brand-900); }

  /* Post nav */
  .post-nav { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--border); }
  @media (max-width: 480px) {
    .post-nav { grid-template-columns: 1fr; }
    .post-nav-next { text-align: left; }
    .post-nav-next .post-nav-label { justify-content: flex-start; }
  }
  .post-nav-prev, .post-nav-next { border: 1px solid var(--border); border-radius: 8px; padding: 0.75rem; text-decoration: none; color: var(--text-primary); transition: border-color 0.15s; }
  .post-nav-prev:hover, .post-nav-next:hover { border-color: var(--brand-500); }
  .post-nav-next { text-align: right; }
  .post-nav-label { display: flex; align-items: center; gap: 0.25rem; font-size: 0.68rem; color: var(--text-muted); margin-bottom: 0.3rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .post-nav-next .post-nav-label { justify-content: flex-end; }
  .post-nav-title { font-size: 0.85rem; font-weight: 600; line-height: 1.3; display: block; }

  /* Related */
  .related h3 { display: flex; align-items: center; gap: 0.4rem; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 0.85rem; }
  .related-list { display: flex; flex-direction: column; gap: 0.5rem; }
  .related-item { display: flex; justify-content: space-between; align-items: baseline; padding: 0.65rem 0.8rem; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: var(--text-primary); transition: border-color 0.15s; }
  .related-item:hover { border-color: var(--brand-500); }
  .related-title { font-size: 0.88rem; font-weight: 600; line-height: 1.3; }
  .related-time { display: flex; align-items: center; gap: 0.2rem; font-size: 0.72rem; color: var(--text-muted); flex-shrink: 0; margin-left: 0.75rem; }

  :global(.glossary-term) {
    border: 0;
    border-bottom: 1px dotted var(--brand-500);
    background: color-mix(in srgb, var(--brand-100) 55%, transparent);
    color: var(--text-primary);
    padding: 0 0.08em;
    border-radius: 3px;
    font: inherit;
    cursor: help;
  }
  :global(.glossary-term:hover),
  :global(.glossary-term:focus-visible) {
    background: var(--brand-100);
    color: var(--brand-900);
  }
  .glossary-popover {
    position: fixed;
    z-index: 80;
    width: min(360px, calc(100vw - 2rem));
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg-card);
    color: var(--text-primary);
    box-shadow: var(--shadow-floating);
    padding: 0.9rem;
    font-size: 0.86rem;
    line-height: 1.6;
  }
  .glossary-popover-head {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    align-items: flex-start;
    margin-bottom: 0.65rem;
  }
  .glossary-eyebrow {
    font-size: 0.64rem;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }
  .glossary-title {
    font-size: 0.98rem;
    font-weight: 800;
    color: var(--brand-900);
    overflow-wrap: anywhere;
  }
  .glossary-level {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .glossary-level button {
    border: 0;
    background: transparent;
    color: var(--text-secondary);
    padding: 0.22rem 0.45rem;
    font: inherit;
    font-size: 0.7rem;
    line-height: 1.2;
    cursor: pointer;
  }
  .glossary-level button.active {
    background: var(--brand-900);
    color: var(--bg-page);
  }
  .glossary-definition,
  .glossary-context {
    margin: 0 0 0.55rem;
  }
  .glossary-context {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  .glossary-reading {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .glossary-reading a {
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--brand-500);
    padding: 0.15rem 0.45rem;
    text-decoration: none;
    font-size: 0.74rem;
  }
  .glossary-reading a:hover {
    border-color: var(--brand-500);
    color: var(--brand-900);
  }
  @media (max-width: 520px) {
    .glossary-popover {
      left: 1rem !important;
      right: 1rem;
      width: auto;
    }
  }
</style>

<script>
  // Wrap tables in scrollable container for mobile
  document.querySelectorAll('.content table').forEach(table => {
    const wrapper = document.createElement('div');
    wrapper.className = 'table-scroll';
    table.parentNode!.insertBefore(wrapper, table);
    wrapper.appendChild(table);
  });

  // Attach copy buttons to all pre blocks (macOS-style, positioned in the header bar)
  document.querySelectorAll('.content pre').forEach(pre => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.setAttribute('aria-label', 'Copy code');
    btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
    btn.addEventListener('click', async () => {
      const code = (pre.querySelector('code') as HTMLElement)?.innerText ?? (pre as HTMLElement).innerText;
      await navigator.clipboard.writeText(code);
      btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
      setTimeout(() => {
        btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
      }, 2000);
    });
    pre.appendChild(btn);
  });

  // Inline glossary: mark known terms and load contextual explanations on demand.
  const glossaryData = document.getElementById('glossary-data') as HTMLScriptElement | null;
  const glossaryPopover = document.getElementById('glossary-popover') as HTMLElement | null;
  const glossaryTitle = document.getElementById('glossary-title');
  const glossaryDefinition = document.getElementById('glossary-definition');
  const glossaryContext = document.getElementById('glossary-context');
  const glossaryReading = document.getElementById('glossary-reading') as HTMLElement | null;

  type GlossaryEntry = {
    term: string;
    aliases?: string[];
    definition?: string;
    advanced?: string;
    context?: string;
    links?: Array<{ label: string; url: string }>;
  };

  type GlossaryResponse = {
    term: string;
    level: 'beginner' | 'advanced';
    definition: string;
    context: string;
    reading: Array<{ label: string; url: string }>;
    source: 'ai' | 'local';
  };

  const glossaryEntries: GlossaryEntry[] = glossaryData?.textContent
    ? JSON.parse(glossaryData.textContent)
    : [];
  const glossarySlug = glossaryData?.dataset.postSlug ?? '';
  const glossaryCache = new Map<string, GlossaryResponse>();
  const glossaryPending = new Map<string, Promise<GlossaryResponse>>();
  let glossaryLevel = (localStorage.getItem('glossary-level') === 'advanced' ? 'advanced' : 'beginner') as 'beginner' | 'advanced';
  let glossaryHideTimer: number | undefined;
  let activeGlossaryButton: HTMLElement | null = null;

  function escapeRegExp(value: string) {
    return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function isAsciiWord(value: string) {
    return /[A-Za-z0-9_-]/.test(value);
  }

  function isValidBoundary(text: string, index: number, length: number) {
    const before = text[index - 1] ?? '';
    const after = text[index + length] ?? '';
    return !isAsciiWord(before) && !isAsciiWord(after);
  }

  function sentenceAround(node: HTMLElement) {
    const text = node.closest('p, li, td, blockquote')?.textContent?.replace(/\s+/g, ' ').trim() ?? '';
    return text.length > 420 ? `${text.slice(0, 419)}…` : text;
  }

  function glossaryEntryFor(value: string) {
    const key = value.toLowerCase();
    return glossaryEntries.find(entry => {
      if (entry.term.toLowerCase() === key) return true;
      return entry.aliases?.some(alias => alias.toLowerCase() === key);
    });
  }

  function markGlossaryTerms() {
    if (!glossaryEntries.length) return;
    const terms = glossaryEntries
      .flatMap(entry => [entry.term, ...(entry.aliases ?? [])])
      .filter(term => term.length >= 2)
      .sort((a, b) => b.length - a.length);
    if (!terms.length) return;

    const pattern = new RegExp(terms.map(escapeRegExp).join('|'), 'gi');
    const content = document.querySelector('.content');
    if (!content) return;

    const walker = document.createTreeWalker(content, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        const parent = node.parentElement;
        if (!parent || !node.textContent?.trim()) return NodeFilter.FILTER_REJECT;
        if (parent.closest('a, button, pre, code, h1, h2, h3, h4, h5, h6, script, style, .glossary-term')) {
          return NodeFilter.FILTER_REJECT;
        }
        pattern.lastIndex = 0;
        return pattern.test(node.textContent) ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_REJECT;
      },
    });

    const nodes: Text[] = [];
    while (walker.nextNode()) nodes.push(walker.currentNode as Text);

    nodes.forEach(node => {
      const text = node.textContent ?? '';
      const fragment = document.createDocumentFragment();
      let lastIndex = 0;
      pattern.lastIndex = 0;
      for (const match of text.matchAll(pattern)) {
        const value = match[0];
        const index = match.index ?? 0;
        if (!isValidBoundary(text, index, value.length)) continue;
        const entry = glossaryEntryFor(value);
        if (!entry) continue;
        fragment.append(document.createTextNode(text.slice(lastIndex, index)));
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'glossary-term';
        button.dataset.term = entry.term;
        button.textContent = value;
        fragment.append(button);
        lastIndex = index + value.length;
      }
      if (lastIndex === 0) return;
      fragment.append(document.createTextNode(text.slice(lastIndex)));
      node.parentNode?.replaceChild(fragment, node);
    });
  }

  function setGlossaryLevel(level: 'beginner' | 'advanced') {
    glossaryLevel = level;
    localStorage.setItem('glossary-level', level);
    glossaryPopover?.querySelectorAll<HTMLButtonElement>('[data-glossary-level]').forEach(button => {
      button.classList.toggle('active', button.dataset.glossaryLevel === level);
    });
  }

  function positionGlossaryPopover(anchor: HTMLElement) {
    if (!glossaryPopover) return;
    const rect = anchor.getBoundingClientRect();
    const gap = 8;
    const width = Math.min(360, window.innerWidth - 32);
    const left = Math.max(16, Math.min(rect.left, window.innerWidth - width - 16));
    const top = rect.bottom + gap + 220 > window.innerHeight
      ? Math.max(16, rect.top - gap - 220)
      : rect.bottom + gap;
    glossaryPopover.style.left = `${left}px`;
    glossaryPopover.style.top = `${top}px`;
  }

  function renderGlossary(data: GlossaryResponse) {
    if (!glossaryTitle || !glossaryDefinition || !glossaryContext || !glossaryReading) return;
    glossaryTitle.textContent = data.term;
    glossaryDefinition.textContent = data.definition;
    glossaryContext.textContent = data.context;
    glossaryReading.textContent = '';
    data.reading.slice(0, 3).forEach(link => {
      const anchor = document.createElement('a');
      anchor.href = link.url;
      anchor.textContent = link.label;
      glossaryReading.appendChild(anchor);
    });
  }

  function localGlossaryResponse(term: string, level: 'beginner' | 'advanced', context: string, seed?: GlossaryEntry): GlossaryResponse {
    const definition = level === 'advanced'
      ? seed?.advanced ?? seed?.definition
      : seed?.definition ?? seed?.advanced;

    return {
      term,
      level,
      definition: definition ?? `${term} 是本文中的技術名詞。`,
      context: seed?.context ?? context,
      reading: seed?.links?.length
        ? seed.links
        : [{ label: `搜尋 ${term}`, url: `/search?q=${encodeURIComponent(term)}&mode=rag` }],
      source: 'local',
    };
  }

  async function loadGlossary(button: HTMLElement) {
    if (!glossaryPopover) return;
    window.clearTimeout(glossaryHideTimer);
    activeGlossaryButton = button;
    const term = button.dataset.term ?? button.textContent?.trim() ?? '';
    const seed = glossaryEntryFor(term);
    const context = sentenceAround(button);
    const cacheKey = `${term}:${glossaryLevel}:${context}`;
    setGlossaryLevel(glossaryLevel);
    glossaryPopover.hidden = false;
    positionGlossaryPopover(button);

    if (glossaryCache.has(cacheKey)) {
      renderGlossary(glossaryCache.get(cacheKey)!);
      return;
    }

    const localResponse = localGlossaryResponse(term, glossaryLevel, context, seed);
    renderGlossary({
      term,
      level: glossaryLevel,
      definition: 'Loading...',
      context: '正在整理本文脈絡中的說明。',
      reading: [],
      source: 'local',
    });

    let pending = glossaryPending.get(cacheKey);
    if (!pending) {
      pending = fetch('/api/glossary/explain', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ term, level: glossaryLevel, context, slug: glossarySlug, seed }),
      })
        .then(res => res.ok ? res.json() : localResponse)
        .catch(() => localResponse) as Promise<GlossaryResponse>;
      glossaryPending.set(cacheKey, pending);
    }

    const response = await pending;
    glossaryPending.delete(cacheKey);
    glossaryCache.set(cacheKey, response);
    if (activeGlossaryButton === button) {
      renderGlossary(response);
      positionGlossaryPopover(button);
    }
  }

  function hideGlossarySoon() {
    glossaryHideTimer = window.setTimeout(() => {
      if (glossaryPopover) glossaryPopover.hidden = true;
      activeGlossaryButton = null;
    }, 180);
  }

  markGlossaryTerms();
  document.querySelectorAll<HTMLElement>('.glossary-term').forEach(button => {
    button.addEventListener('mouseenter', () => loadGlossary(button));
    button.addEventListener('focus', () => loadGlossary(button));
    button.addEventListener('mouseleave', hideGlossarySoon);
    button.addEventListener('blur', hideGlossarySoon);
    button.addEventListener('click', () => loadGlossary(button));
  });
  glossaryPopover?.addEventListener('mouseenter', () => window.clearTimeout(glossaryHideTimer));
  glossaryPopover?.addEventListener('mouseleave', hideGlossarySoon);
  glossaryPopover?.querySelectorAll<HTMLButtonElement>('[data-glossary-level]').forEach(button => {
    button.addEventListener('click', () => {
      setGlossaryLevel(button.dataset.glossaryLevel === 'advanced' ? 'advanced' : 'beginner');
      if (activeGlossaryButton) loadGlossary(activeGlossaryButton);
    });
  });
  setGlossaryLevel(glossaryLevel);
</script>

<style is:global>
  /* Copy button — positioned in the macOS header bar area */
  .copy-btn {
    position: absolute;
    top: 0.45rem;
    right: 0.75rem;
    background: transparent;
    color: rgba(255,255,255,0.4);
    border: none;
    border-radius: 4px;
    padding: 0.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    transition: color 0.15s;
    z-index: 1;
  }
  .copy-btn:hover { color: rgba(255,255,255,0.8); }
</style>
