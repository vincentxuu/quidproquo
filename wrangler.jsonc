{
	"name": "quidproquo",
	"account_id": "1ff43f0d4c3ad3bd98ce5ab767546a68",
	"compatibility_date": "2026-03-10",
	"routes": [
		{
			"pattern": "quidproquo.cc",
			"custom_domain": true
		},
		{
			"pattern": "www.quidproquo.cc",
			"custom_domain": true
		}
	],
	"compatibility_flags": [
		"nodejs_compat"
	],
	"triggers": {
		"crons": [
			"*/15 * * * *",
			"0 2 * * SUN",
			"0 3 * * *",
			"0 4 * * SUN",
			"0 5 * * SUN"
		]
	},
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "98171882182147d0b340b0b127c1e1cd"
		},
		{
			"binding": "RATE",
			"id": "83f09dbb6f7a4135a84557a4b3f98596"
		},
		{
			"binding": "DEEP_RESEARCH_KV",
			"id": "4fff0920cd1040f6b18407857140fabd",
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "quidproquo-db",
			"database_id": "c6ae78f5-3d07-44b9-854d-eb439c6902b1"
		}
	],
	"vectorize": [
		{
			"binding": "VECTORIZE_INDEX",
			"index_name": "quidproquo-vectors"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"queues": {
		"producers": [
			{
				"binding": "AGENT_QUEUE",
				"queue": "agent-queue"
			}
		],
		"consumers": [
			{
				"queue": "agent-queue",
				"max_batch_size": 1,
				"max_batch_timeout": 5,
				"max_retries": 3,
				"dead_letter_queue": "agent-queue-dlq"
			}
		]
	},
	"vars": {
		"LLM_PROVIDER": "groq",
		"AGENT_OS_ENABLED": "true",
		"AGENT_OS_PLANNER": "false",
		"AGENT_OS_RESEARCH": "false",
		"AGENT_OS_WRITER": "false",
		"AGENT_OS_CRITIC": "true",
		"AGENT_OS_MEMORY_R2": "false",
		"AGENT_OS_TOOLS_MCP_EXTERNAL": "false",
		"AGENT_OS_SCHEDULER_QUEUES": "false",
		"AGENT_EVIDENCE_ENABLED": "false",
		"AGENT_CONSOLE_ENABLED": "true",
		"AGENT_ARTIFACT_ENABLED": "false",
		"AGENT_ARTIFACT_R2_OFFLOAD": "false",
		"AGENT_ARTIFACT_CSV": "false",
		"AGENT_ARTIFACT_PDF": "false",
		"AGENT_ARTIFACT_PPTX": "false",
		"AGENT_ARTIFACT_NOTION": "false",
		"AGENT_ARTIFACT_SLACK": "false",
		"AGENT_ARTIFACT_GITHUB_ISSUE": "false",
		"AGENT_ARTIFACT_GITHUB_PR": "false",
		"AGENT_ARTIFACT_EMAIL": "false",
		"AGENT_PROVIDERS_ENABLED": "false",
		"AGENT_PROVIDERS_LLM_OPENAI": "false",
		"AGENT_PROVIDERS_LLM_ANTHROPIC": "false",
		"AGENT_PROVIDERS_LLM_GEMINI": "false",
		"AGENT_PROVIDERS_LLM_GROQ": "false",
		"AGENT_PROVIDERS_LLM_OPENROUTER": "false",
		"AGENT_PROVIDERS_SEARCH_TAVILY": "false",
		"AGENT_PROVIDERS_SEARCH_EXA": "false",
		"AGENT_PROVIDERS_SEARCH_JINA": "false",
		"AGENT_PROVIDERS_READER_JINA": "false",
		"AGENT_PROVIDERS_READER_FIRECRAWL": "false",
		"AGENT_PROVIDERS_READER_BROWSER": "false",
		"AGENT_PROVIDERS_READER_DIRECT_FETCH": "false",
		"AGENT_PROVIDERS_KNOWLEDGE_NOTION": "false",
		"AGENT_PROVIDERS_KNOWLEDGE_GITHUB": "false",
		"AGENT_PROVIDERS_KNOWLEDGE_DRIVE": "false",
		"AGENT_PROVIDERS_KNOWLEDGE_SQL": "false",
		"AGENT_PROVIDERS_ACTION_GITHUB_ISSUE": "false",
		"AGENT_PROVIDERS_ACTION_GITHUB_COMMENT": "false",
		"AGENT_PROVIDERS_ACTION_SLACK": "false",
		"AGENT_PROVIDERS_ACTION_NOTION": "false",
		"AGENT_PROVIDERS_ACTION_EMAIL": "false",
		"AGENT_PROVIDERS_ROUTING_FALLBACK": "false",
		"AGENT_PROVIDERS_ROUTING_HEALTH_CHECKS": "false",
		"AGENT_PROVIDERS_ROUTING_LOAD_BALANCE": "false",
		"AGENT_PROVIDERS_ROUTING_RATE_LIMITS": "false",
		"AGENT_POLICY_ENABLED": "false",
		"AGENT_POLICY_BUDGET_ENFORCE": "false",
		"AGENT_POLICY_PROVIDER_ENFORCE": "false",
		"AGENT_POLICY_QUALITY_ENFORCE": "false",
		"AGENT_POLICY_SECURITY_ENFORCE": "false",
		"AGENT_POLICY_HUMAN_GATES": "false",
		"AGENT_FLOW_ENABLED": "false",
		"AGENT_FLOW_DURABLE_EXECUTION": "false",
		"AGENT_FLOW_DEEP_RESEARCH": "false",
		"PIPELINES_PORTED_TO_FLOW": "false",
		"ADMIN_PIPELINES_REDIRECT_TO_FLOW": "false",
		"ADMIN_JOBS_WRITES_ENABLED": "true",
		"PIPELINE_CONTENT_OPS_USE_FLOW": "false",
		"PIPELINE_POST_QUALITY_USE_FLOW": "false",
		"PIPELINE_EMBED_SYNC_USE_FLOW": "false",
		"PIPELINE_CRAWL_SYNC_USE_FLOW": "false",
		"PIPELINE_TRANSLATION_USE_FLOW": "false",
		"PIPELINE_RESEARCH_BRIEF_USE_FLOW": "false",
		"PIPELINE_YOUTUBE_BRIEF_USE_FLOW": "false",
		"PIPELINE_GLOSSARY_GAP_USE_FLOW": "false",
		"PIPELINE_FRESHNESS_REVIEW_USE_FLOW": "false",
		"PIPELINE_SERIES_SUGGESTIONS_USE_FLOW": "false",
		"PIPELINE_KNOWLEDGE_GRAPH_PROTOTYPE_USE_FLOW": "false",
		"PIPELINE_METADATA_SUGGESTIONS_USE_FLOW": "false",
		"PIPELINE_INTERNAL_LINKS_USE_FLOW": "false"
	},
	"r2_buckets": [
		{
			"binding": "R2_IMAGES",
			"bucket_name": "quidproquo-images"
		},
		{
			"binding": "R2_AGENT_MEMORY",
			"bucket_name": "quidproquo-agent-memory"
		},
		{
			"binding": "R2_AGENT_ARTIFACT",
			"bucket_name": "quidproquo-agent-artifact"
		}
	],
	"env": {
		"preview": {
			"name": "quidproquo-preview"
		}
	}
}
