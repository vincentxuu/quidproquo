{
	"name": "quidproquo",
	"account_id": "1ff43f0d4c3ad3bd98ce5ab767546a68",
	"compatibility_date": "2026-03-10",
	"routes": [
		{
			"pattern": "quidproquo.cc",
			"custom_domain": true
		},
		{
			"pattern": "www.quidproquo.cc",
			"custom_domain": true
		}
	],
	"compatibility_flags": [
		"nodejs_compat"
	],
	"triggers": {
		"crons": [
			"0 2 * * SUN",
			"0 3 * * *",
			"0 4 * * SUN",
			"0 5 * * SUN"
		]
	},
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist"
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "98171882182147d0b340b0b127c1e1cd"
		},
		{
			"binding": "RATE",
			"id": "83f09dbb6f7a4135a84557a4b3f98596"
		},
		{
			"binding": "DEEP_RESEARCH_KV",
			"id": "4fff0920cd1040f6b18407857140fabd",
			"remote": true
		}
	],
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "quidproquo-db",
			"database_id": "c6ae78f5-3d07-44b9-854d-eb439c6902b1"
		}
	],
	"vectorize": [
		{
			"binding": "VECTORIZE_INDEX",
			"index_name": "quidproquo-vectors"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"vars": {
		"LLM_PROVIDER": "groq"
	},
	"r2_buckets": [
		{
			"binding": "R2_IMAGES",
			"bucket_name": "quidproquo-images"
		}
	],
	"env": {
		"preview": {
			"name": "quidproquo-preview"
		}
	}
}